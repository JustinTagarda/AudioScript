<Window x:Class="AudioScript.SeparateRowWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AudioScript"
        Title="Separate Row"
        Icon="pack://application:,,,/assets/AudioScript.ico"
        Width="760"
        MinWidth="680"
        MinHeight="260"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="SeparateRowTextEditorTextBoxStyle"
               TargetType="{x:Type TextBox}"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Padding"
                    Value="4,0"/>
            <Setter Property="Margin"
                    Value="0"/>
            <Setter Property="Background"
                    Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="BorderBrush"
                    Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="TextAlignment"
                    Value="Left"/>
            <Setter Property="VerticalContentAlignment"
                    Value="Top"/>
            <Setter Property="TextWrapping"
                    Value="Wrap"/>
            <Setter Property="AcceptsReturn"
                    Value="True"/>
            <Setter Property="AcceptsTab"
                    Value="False"/>
            <Setter Property="VerticalScrollBarVisibility"
                    Value="Disabled"/>
            <Setter Property="HorizontalScrollBarVisibility"
                    Value="Disabled"/>
            <Setter Property="CaretBrush"
                    Value="White"/>
            <Setter Property="SelectionBrush"
                    Value="#33FFFFFF"/>
            <Setter Property="SelectionTextBrush"
                    Value="White"/>
            <Setter Property="UndoLimit"
                    Value="100"/>
            <Setter Property="KeyboardNavigation.DirectionalNavigation"
                    Value="Contained"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource ControlCornerRadius}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              VerticalAlignment="Top"
              Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="22"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Width="80"
                    Height="30"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                <TextBlock Text="{Binding FirstRowStartText, Mode=OneWay}"
                           Margin="8,3,6,3"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </Border>
            <TextBlock Grid.Column="1"
                       VerticalAlignment="Top"
                       HorizontalAlignment="Center"
                       Text="-"/>
            <local:TimelineNumericUpDown Grid.Column="2"
                                         Width="80"
                                         Height="30"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Top"
                                         Value="{Binding SplitOffset, Mode=TwoWay}"
                                         Minimum="{Binding MinSplitOffset, Mode=OneWay}"
                                         Maximum="{Binding MaxSplitOffset, Mode=OneWay}"
                                         Increment="00:00:01"/>
            <TextBox Grid.Column="3"
                     Margin="8,0,0,0"
                     VerticalAlignment="Top"
                     Style="{StaticResource SeparateRowTextEditorTextBoxStyle}"
                     Text="{Binding FirstRowText, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Top"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     MinHeight="56"/>
        </Grid>

        <Grid Grid.Row="1"
              VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="22"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <local:TimelineNumericUpDown Grid.Column="0"
                                         Width="80"
                                         Height="30"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Top"
                                         Value="{Binding SplitOffset, Mode=TwoWay}"
                                         Minimum="{Binding MinSplitOffset, Mode=OneWay}"
                                         Maximum="{Binding MaxSplitOffset, Mode=OneWay}"
                                         Increment="00:00:01"/>
            <TextBlock Grid.Column="1"
                       VerticalAlignment="Top"
                       HorizontalAlignment="Center"
                       Text="-"/>
            <Border Grid.Column="2"
                    Width="80"
                    Height="30"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                <TextBlock Text="{Binding SecondRowEndText, Mode=OneWay}"
                           Margin="8,3,6,3"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </Border>
            <TextBox Grid.Column="3"
                     Margin="8,0,0,0"
                     VerticalAlignment="Top"
                     Style="{StaticResource SeparateRowTextEditorTextBoxStyle}"
                     Text="{Binding SecondRowText, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Top"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     MinHeight="56"/>
        </Grid>

        <TextBlock Grid.Row="3"
                   Margin="0,10,0,0"
                   Foreground="#FFE81123"
                   Text="{Binding ValidationErrorText}"
                   TextWrapping="Wrap">
            <TextBlock.Style>
                <Style TargetType="{x:Type TextBlock}">
                    <Setter Property="Visibility"
                            Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ValidationErrorText}"
                                     Value="">
                            <Setter Property="Visibility"
                                    Value="Hidden"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button MinWidth="110"
                    MinHeight="28"
                    Padding="12,6"
                    Tag="&#xE711;"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Margin="0,0,8,0"
                    Content="Cancel"
                    Click="CancelButton_Click"/>
            <Button MinWidth="110"
                    MinHeight="28"
                    Padding="12,6"
                    Tag="&#xE73E;"
                    Style="{StaticResource ToolbarPrimaryButtonStyle}"
                    Content="OK"
                    Click="OkButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
