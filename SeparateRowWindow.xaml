<Window x:Class="AudioScript.SeparateRowWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Split Transcription"
        Icon="pack://application:,,,/assets/AudioScript.ico"
        Width="860"
        MinWidth="760"
        MinHeight="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="SeparateRowTextEditorTextBoxStyle"
               TargetType="{x:Type TextBox}"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Padding"
                    Value="8"/>
            <Setter Property="Margin"
                    Value="0"/>
            <Setter Property="Background"
                    Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="BorderBrush"
                    Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="TextAlignment"
                    Value="Left"/>
            <Setter Property="VerticalContentAlignment"
                    Value="Top"/>
            <Setter Property="TextWrapping"
                    Value="Wrap"/>
            <Setter Property="AcceptsReturn"
                    Value="True"/>
            <Setter Property="AcceptsTab"
                    Value="True"/>
            <Setter Property="VerticalScrollBarVisibility"
                    Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility"
                    Value="Disabled"/>
            <Setter Property="CaretBrush"
                    Value="#FFE7E7E7"/>
            <Setter Property="SelectionBrush"
                    Value="#33FFFFFF"/>
            <Setter Property="SelectionTextBrush"
                    Value="White"/>
            <Setter Property="UndoLimit"
                    Value="0"/>
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Margin="0,0,0,8"
                   TextWrapping="Wrap"
                   Text="Place the caret in the text where row 2 should start. Split results are trimmed at the start and end before they are saved."/>

        <TextBox x:Name="OriginalTextBox"
                 Grid.Row="1"
                 Style="{StaticResource SeparateRowTextEditorTextBoxStyle}"
                 Text="{Binding OriginalText, Mode=OneWay}"
                 SelectionChanged="OriginalTextBox_SelectionChanged"
                 MinHeight="130"/>

        <Grid Grid.Row="2"
              Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="8"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                    CornerRadius="4">
                <TextBlock Text="{Binding FirstRowText, Mode=OneWay}"
                           TextWrapping="Wrap"/>
            </Border>

            <Border Grid.Column="2"
                    Padding="8"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                    CornerRadius="4">
                <TextBlock Text="{Binding SecondRowText, Mode=OneWay}"
                           TextWrapping="Wrap"/>
            </Border>
        </Grid>

        <TextBlock Grid.Row="3"
                   Margin="0,10,0,0"
                   Foreground="#FFE81123"
                   Text="{Binding ValidationErrorText}"
                   TextWrapping="Wrap">
            <TextBlock.Style>
                <Style TargetType="{x:Type TextBlock}">
                    <Setter Property="Visibility"
                            Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ValidationErrorText}"
                                     Value="">
                            <Setter Property="Visibility"
                                    Value="Hidden"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button MinWidth="110"
                    MinHeight="28"
                    Padding="12,6"
                    Tag="&#xE711;"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Margin="0,0,8,0"
                    Content="Cancel"
                    Click="CancelButton_Click"/>
            <Button MinWidth="110"
                    MinHeight="28"
                    Padding="12,6"
                    Tag="&#xE73E;"
                    Style="{StaticResource ToolbarPrimaryButtonStyle}"
                    Content="OK"
                    Click="OkButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
