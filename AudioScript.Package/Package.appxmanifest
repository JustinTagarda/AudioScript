<?xml version="1.0" encoding="utf-8"?>
<!--
  Package.appxmanifest – Microsoft Store / MSIX packaging identity for AudioScript.
  Store builds store downloaded models and user-created app data under the package
  LocalState folder, not beside the installed app binaries. This keeps the Store
  installer small and lets Windows manage package-owned app data on uninstall.

  BEFORE SUBMITTING TO THE STORE:
  1. Create (or sign in to) your app in Partner Center:
       https://partner.microsoft.com/dashboard
  2. Under "Product identity", copy the three values that Microsoft assigns:
       • Package/Identity Name       → replace "PACKAGE_IDENTITY_NAME" below
       • Package/Identity Publisher  → replace "CN=PUBLISHER_CN" below
       • PublisherDisplayName        → replace "PUBLISHER_DISPLAY_NAME" below
  3. Confirm the Version matches AudioScript.csproj <Version> (currently 2.0.9.0).
-->
<Package xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10" xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10" xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities" IgnorableNamespaces="uap rescap">
  <!-- ═══════════════════════════════════════════════════════════════════
       IDENTITY  –  Values must match your Partner Center app registration
       ═══════════════════════════════════════════════════════════════════ -->
  <Identity Name="JustinTagardaSoftware.AudioScript" Publisher="CN=68EC506E-4B5E-416B-93E8-BA707CA3BE0F" Version="2.0.10.0" />
  <!-- ═══════════════════════════════════════════════════════════════════
       PROPERTIES
       ═══════════════════════════════════════════════════════════════════ -->
  <Properties>
    <DisplayName>AudioScript</DisplayName>
    <PublisherDisplayName>JustinTagarda</PublisherDisplayName>
    <!-- 50×50 PNG required by the Store listing -->
    <Logo>assets\StoreLogo.png</Logo>
  </Properties>
  <!-- ═══════════════════════════════════════════════════════════════════
       PLATFORM TARGETS
       Minimum: Windows 10 1809 (needed for modern WPF + Fluent theme APIs)
       ═══════════════════════════════════════════════════════════════════ -->
  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.26100.0" />
  </Dependencies>
  <!-- ═══════════════════════════════════════════════════════════════════
       RESOURCES
       ═══════════════════════════════════════════════════════════════════ -->
  <Resources>
    <Resource Language="en-us" />
  </Resources>
  <!-- ═══════════════════════════════════════════════════════════════════
       APPLICATIONS
       $targetnametoken$ is substituted by MSBuild with the actual .exe name.
       ═══════════════════════════════════════════════════════════════════ -->
  <Applications>
    <Application Id="App" Executable="AudioScript.exe" EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements DisplayName="AudioScript" Description="Offline audio transcription for local files and live playback capture." BackgroundColor="transparent" Square150x150Logo="assets\Square150x150Logo.png" Square44x44Logo="assets\Square44x44Logo.png">
        <uap:DefaultTile ShortName="AudioScript" Wide310x150Logo="assets\Wide310x150Logo.png" Square310x310Logo="assets\Square310x310Logo.png" />
        <uap:SplashScreen Image="assets\SplashScreen.png" />
      </uap:VisualElements>
    </Application>
  </Applications>
  <!-- ═══════════════════════════════════════════════════════════════════
       CAPABILITIES
       • internetClient  – required for optional model downloads
       • runFullTrust    – required for all packaged WPF/Win32 desktop apps;
                           enables WinForms APIs, WASAPI loopback capture and file-system access that
                           standard sandboxed apps cannot use
       ═══════════════════════════════════════════════════════════════════ -->
  <Capabilities>
    <Capability Name="internetClient" />
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>