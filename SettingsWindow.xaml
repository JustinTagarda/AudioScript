<Window x:Class="AudioScript.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Settings"
        Icon="pack://application:,,,/assets/AudioScript.ico"
        Width="700"
        Height="630"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="Manual"
        ShowInTaskbar="False">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="FluentComboBoxItemStyle"
               TargetType="{x:Type ComboBoxItem}"
               BasedOn="{StaticResource {x:Type ComboBoxItem}}"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="14"
                BorderThickness="1"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                CornerRadius="8">
            <StackPanel Orientation="Horizontal">
                    <StackPanel Width="320">
                        <TextBlock Text="Transcription engine"
                                   Margin="0,0,0,6"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <ComboBox Padding="6,0"
                                  ItemsSource="{Binding Engines}"
                                  SelectedItem="{Binding SelectedEngine, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  DisplayMemberPath="DisplayName"
                                  IsEnabled="{Binding IsEngineSelectionEnabled}"
                                  ItemContainerStyle="{StaticResource FluentComboBoxItemStyle}"/>
                    </StackPanel>

                    <StackPanel Width="220"
                                Margin="12,0,0,0">
                        <TextBlock Text="Theme"
                                   Margin="0,0,0,6"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <ComboBox Padding="6,0"
                                  ItemsSource="{Binding ThemeOptions}"
                                  SelectedValuePath="Preference"
                                  SelectedValue="{Binding SelectedThemePreference, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  DisplayMemberPath="DisplayName"
                                  ItemContainerStyle="{StaticResource FluentComboBoxItemStyle}"/>
                    </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1"
              Margin="0,12,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Install additional engines (optional)"
                       FontWeight="SemiBold"
                       FontSize="14"
                       Margin="0,0,0,10"/>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False">
                <ItemsControl x:Name="ModelsItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10"
                                    Padding="12"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0"
                                                Grid.Column="0"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"/>
                                        <Border Margin="10,0,0,0"
                                                Padding="8,2"
                                                CornerRadius="6"
                                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                BorderThickness="1">
                                            <TextBlock Text="{Binding StatusText}"
                                                       FontSize="11"/>
                                        </Border>
                                        <TextBlock Text="{Binding SizeText}"
                                                   Margin="10,0,0,0"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0"
                                                Grid.Column="1"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right">
                                        <Button Content="Install"
                                                MinWidth="86"
                                                Tag="&#xE896;"
                                                Style="{StaticResource ToolbarPrimaryButtonStyle}"
                                                Visibility="{Binding ShowInstallButton, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                IsEnabled="{Binding CanInstall}"
                                                Click="InstallButton_Click"/>
                                        <Button Content="Uninstall"
                                                MinWidth="94"
                                                Tag="&#xE74D;"
                                                Style="{StaticResource ToolbarDestructiveButtonStyle}"
                                                Visibility="{Binding CanUninstall, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                Click="UninstallButton_Click"/>
                                        <Button Content="Cancel"
                                                MinWidth="82"
                                                Margin="8,0,0,0"
                                                Tag="&#xE711;"
                                                Style="{StaticResource ToolbarButtonStyle}"
                                                Visibility="{Binding CanCancel, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                Click="CancelInstallButton_Click"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1"
                                                Grid.Column="0"
                                                Grid.ColumnSpan="2"
                                                Margin="0,8,0,0">
                                        <TextBlock Text="{Binding Description}"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Benefits}"
                                                   Margin="0,4,0,0"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Notes}"
                                                   Margin="0,4,0,0"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="Wrap"/>
                                        <StackPanel Margin="0,8,0,0"
                                                    Visibility="{Binding ShowPremiumUpsell, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="{Binding PremiumUpsellText}"
                                                       Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                                       TextWrapping="Wrap"/>
                                            <Button Content="Get Premium in Microsoft Store"
                                                    Margin="0,6,0,0"
                                                    MinWidth="220"
                                                    HorizontalAlignment="Left"
                                                    Tag="&#xE8D4;"
                                                    Style="{StaticResource ToolbarButtonStyle}"
                                                    Click="GetPremiumButton_Click"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2"
                                                Grid.Column="0"
                                                Grid.ColumnSpan="2"
                                                Margin="0,10,0,0"
                                                Visibility="{Binding CanCancel, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <ProgressBar Height="8"
                                                     Minimum="0"
                                                     Maximum="100"
                                                     Value="{Binding ProgressPercent, Mode=OneWay}"/>
                                        <TextBlock Text="{Binding ProgressText}"
                                                   Margin="0,5,0,0"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   FontSize="11"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Close"
                    MinWidth="88"
                    Tag="&#xE711;"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
