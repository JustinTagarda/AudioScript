<Application x:Class="VoxTranscriber.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <Style x:Key="ButtonChromeStyle"
                TargetType="Button">
            <Setter Property="FontFamily"
                    Value="Segoe UI Variable Text"/>
            <Setter Property="FontSize"
                    Value="10.5"/>
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="Margin"
                    Value="1"/>
            <Setter Property="Padding"
                    Value="4"/>
            <Setter Property="MinHeight"
                    Value="28"/>
            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>
            <Setter Property="HorizontalContentAlignment"
                    Value="Center"/>
            <Setter Property="UseLayoutRounding"
                    Value="True"/>
            <Setter Property="SnapsToDevicePixels"
                    Value="True"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle"
                TargetType="Button"
                BasedOn="{StaticResource ButtonChromeStyle}">
            <Setter Property="Background"
                    Value="#FF1B86AA"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="BorderBrush"
                    Value="#FF1B86AA"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Background"
                            Value="#FF187798"/>
                    <Setter Property="BorderBrush"
                            Value="#FF187798"/>
                </Trigger>
                <Trigger Property="IsPressed"
                         Value="True">
                    <Setter Property="Background"
                            Value="#FF146580"/>
                    <Setter Property="BorderBrush"
                            Value="#FF146580"/>
                </Trigger>
                <Trigger Property="IsEnabled"
                         Value="False">
                    <Setter Property="Background"
                            Value="#FFE0E8EC"/>
                    <Setter Property="BorderBrush"
                            Value="#FFD1DCE2"/>
                    <Setter Property="Foreground"
                            Value="#FF8A9DA9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButtonStyle"
                TargetType="Button"
                BasedOn="{StaticResource ButtonChromeStyle}">
            <Setter Property="Background"
                    Value="#FFE45D4B"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="BorderBrush"
                    Value="#FFE45D4B"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Background"
                            Value="#FFD04E3F"/>
                    <Setter Property="BorderBrush"
                            Value="#FFD04E3F"/>
                </Trigger>
                <Trigger Property="IsPressed"
                         Value="True">
                    <Setter Property="Background"
                            Value="#FFBA4436"/>
                    <Setter Property="BorderBrush"
                            Value="#FFBA4436"/>
                </Trigger>
                <Trigger Property="IsEnabled"
                         Value="False">
                    <Setter Property="Background"
                            Value="#FFE9D6D3"/>
                    <Setter Property="BorderBrush"
                            Value="#FFE0C8C4"/>
                    <Setter Property="Foreground"
                            Value="#FFA8918D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle"
                TargetType="Button"
                BasedOn="{StaticResource ButtonChromeStyle}">
            <Setter Property="Background"
                    Value="#FFF8FBFC"/>
            <Setter Property="Foreground"
                    Value="#FF234F61"/>
            <Setter Property="BorderBrush"
                    Value="#FFB8CBD5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Background"
                            Value="#FFEFF6F9"/>
                    <Setter Property="BorderBrush"
                            Value="#FF9FB7C3"/>
                </Trigger>
                <Trigger Property="IsPressed"
                         Value="True">
                    <Setter Property="Background"
                            Value="#FFE6F0F5"/>
                    <Setter Property="BorderBrush"
                            Value="#FF8FAAB7"/>
                </Trigger>
                <Trigger Property="IsEnabled"
                         Value="False">
                    <Setter Property="Background"
                            Value="#FFF1F6F8"/>
                    <Setter Property="BorderBrush"
                            Value="#FFD9E3E8"/>
                    <Setter Property="Foreground"
                            Value="#FFA0B0B9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CompactSecondaryButtonStyle"
                TargetType="Button"
                BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="FontSize"
                    Value="10.5"/>
            <Setter Property="Padding"
                    Value="4"/>
            <Setter Property="MinHeight"
                    Value="26"/>
            <Setter Property="MinWidth"
                    Value="128"/>
            <Setter Property="Margin"
                    Value="0,4,0,2"/>
            <Setter Property="HorizontalAlignment"
                    Value="Left"/>
        </Style>

        <Style x:Key="ToggleButtonChromeStyle"
                TargetType="ToggleButton">
            <Setter Property="FontFamily"
                    Value="Segoe UI Variable Text"/>
            <Setter Property="FontSize"
                    Value="10.5"/>
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="Margin"
                    Value="1"/>
            <Setter Property="Padding"
                    Value="4"/>
            <Setter Property="MinHeight"
                    Value="28"/>
            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>
            <Setter Property="HorizontalContentAlignment"
                    Value="Center"/>
            <Setter Property="UseLayoutRounding"
                    Value="True"/>
            <Setter Property="SnapsToDevicePixels"
                    Value="True"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter Property="Opacity"
                                        Value="0.92"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryToggleButtonStyle"
                TargetType="ToggleButton"
                BasedOn="{StaticResource ToggleButtonChromeStyle}">
            <Setter Property="Background"
                    Value="#FFF8FBFC"/>
            <Setter Property="Foreground"
                    Value="#FF234F61"/>
            <Setter Property="BorderBrush"
                    Value="#FFB8CBD5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Background"
                            Value="#FFEFF6F9"/>
                    <Setter Property="BorderBrush"
                            Value="#FF9FB7C3"/>
                </Trigger>
                <Trigger Property="IsPressed"
                         Value="True">
                    <Setter Property="Background"
                            Value="#FFE6F0F5"/>
                    <Setter Property="BorderBrush"
                            Value="#FF8FAAB7"/>
                </Trigger>
                <Trigger Property="IsChecked"
                         Value="True">
                    <Setter Property="Background"
                            Value="#FFE7F4F9"/>
                    <Setter Property="BorderBrush"
                            Value="#FFC6DDE7"/>
                    <Setter Property="Foreground"
                            Value="#FF15232D"/>
                </Trigger>
                <Trigger Property="IsEnabled"
                         Value="False">
                    <Setter Property="Background"
                            Value="#FFF1F6F8"/>
                    <Setter Property="BorderBrush"
                            Value="#FFD9E3E8"/>
                    <Setter Property="Foreground"
                            Value="#FFA0B0B9"/>
                    <Setter Property="Opacity"
                            Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CompactSecondaryToggleButtonStyle"
                TargetType="ToggleButton"
                BasedOn="{StaticResource SecondaryToggleButtonStyle}">
            <Setter Property="FontSize"
                    Value="10.5"/>
            <Setter Property="Padding"
                    Value="4"/>
            <Setter Property="MinHeight"
                    Value="26"/>
            <Setter Property="Margin"
                    Value="0"/>
            <Setter Property="HorizontalAlignment"
                    Value="Left"/>
        </Style>

    </Application.Resources>
</Application>


