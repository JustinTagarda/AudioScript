<Window x:Class="VoxTranscriber.UpdateRequiredDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Update Required"
        Icon="pack://application:,,,/Assets/VoxTranscriber.ico"
        Width="480"
        MinWidth="420"
        MinHeight="220"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#FFF4F7F8">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#CCFFFFFF"
                BorderBrush="#55B7CAD2"
                BorderThickness="1"
                CornerRadius="14"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Width="52"
                        Height="52"
                        HorizontalAlignment="Left"
                        Background="#FFF3E4D4"
                        BorderBrush="#FFE4BE8C"
                        BorderThickness="1"
                        CornerRadius="26">
                    <Viewbox Width="24"
                             Height="24"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center">
                        <Grid Width="24"
                              Height="24">
                            <Path Fill="#FFBE7E2A"
                                  Data="M12,2.4 C6.7,2.4 2.4,6.7 2.4,12 C2.4,17.3 6.7,21.6 12,21.6 C17.3,21.6 21.6,17.3 21.6,12 C21.6,6.7 17.3,2.4 12,2.4 Z"/>
                            <Path Fill="#FFFFFFFF"
                                  Data="M11.15,6.7 H12.85 V13.55 H11.15 Z M11.15,15.5 H12.85 V17.3 H11.15 Z"/>
                        </Grid>
                    </Viewbox>
                </Border>

                <TextBlock Grid.Row="1"
                           Margin="0,16,0,0"
                           Text="A newer version is required"
                           FontFamily="Bahnschrift"
                           FontSize="24"
                           Foreground="#FF15232D"
                           TextWrapping="Wrap" />

                <TextBlock x:Name="UpdateMessageText"
                           Grid.Row="2"
                           Margin="0,12,0,0"
                           FontFamily="Segoe UI Variable Text"
                           FontSize="13"
                           Foreground="#FF49616F"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="OK"
                    Width="104"
                    MinHeight="34"
                    Style="{StaticResource ActionButtonStyle}"
                    Click="OkButton_Click" />
        </StackPanel>
    </Grid>
</Window>


