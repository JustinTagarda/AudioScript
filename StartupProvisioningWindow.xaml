<Window x:Class="AudioScript.StartupProvisioningWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:AudioScript.ViewModels"
        mc:Ignorable="d"
        Title="Initializing AudioScript"
        Icon="pack://application:,,,/assets/AudioScript.ico"
        Width="784"
        MinWidth="688"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="{DynamicResource ControlFillColorDefaultBrush}"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style x:Key="AssetProgressBarStyle"
               TargetType="ProgressBar">
            <Setter Property="Height"
                    Value="6" />
            <Setter Property="Foreground"
                    Value="#D79DEB" />
            <Setter Property="Background"
                    Value="{DynamicResource ControlFillColorSecondaryBrush}" />
        </Style>
        <Style x:Key="StartupCardBorderStyle"
               TargetType="Border">
            <Setter Property="Background"
                    Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="BorderBrush"
                    Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="CornerRadius"
                    Value="8" />
            <Setter Property="Padding"
                    Value="14" />
        </Style>
        <Style x:Key="StartupStatusBadgeStyle"
               TargetType="Border">
            <Setter Property="Background"
                    Value="{DynamicResource ControlFillColorSecondaryBrush}" />
            <Setter Property="BorderBrush"
                    Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="CornerRadius"
                    Value="6" />
            <Setter Property="Padding"
                    Value="8,2" />
        </Style>
        <Style x:Key="StartupToolbarButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="MinWidth"
                    Value="96" />
            <Setter Property="Padding"
                    Value="12,6" />
            <Setter Property="Margin"
                    Value="0,0,0,0" />
        </Style>
        <Style x:Key="StartupPrimaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ToolbarPrimaryButtonStyle}">
            <Setter Property="MinWidth"
                    Value="96" />
            <Setter Property="Padding"
                    Value="12,6" />
            <Setter Property="Margin"
                    Value="0,0,0,0" />
        </Style>
        <Style x:Key="StartupDestructiveButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ToolbarDestructiveButtonStyle}">
            <Setter Property="MinWidth"
                    Value="96" />
            <Setter Property="Padding"
                    Value="12,6" />
            <Setter Property="Margin"
                    Value="0,0,0,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Margin="0,0,0,14">
            <TextBlock Text="{Binding HeaderText}"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6" />
            <TextBlock Text="Required startup assets are downloaded and installed before the app opens. This screen stays visible while that work runs."
                       FontSize="12.5"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,10" />
            <ProgressBar Height="4"
                         IsIndeterminate="{Binding IsBusy}"
                         Style="{StaticResource AssetProgressBarStyle}" />
        </StackPanel>

        <Border Grid.Row="1"
                Style="{StaticResource StartupCardBorderStyle}"
                Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="{Binding CurrentAssetText}"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4" />
                <TextBlock Text="{Binding CurrentActivityText}"
                           FontSize="13.5"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource StartupCardBorderStyle}">
            <StackPanel>
                <TextBlock Text="Progress"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12" />
                <ItemsControl ItemsSource="{Binding Assets}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:StartupProvisioningAssetViewModel}">
                            <StackPanel Margin="0,0,0,12">
                                <Grid Margin="0,0,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontSize="14.5"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right">
                                        <Border Style="{StaticResource StartupStatusBadgeStyle}"
                                                Margin="0,0,10,0">
                                            <TextBlock Text="{Binding StatusText}"
                                                       FontSize="11.5"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                        </Border>
                                        <TextBlock Text="{Binding PercentText}"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                                <ProgressBar Value="{Binding Percent, Mode=OneWay}"
                                             Maximum="100"
                                             Style="{StaticResource AssetProgressBarStyle}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button x:Name="CancelButton"
                    Content="Cancel and Exit"
                    Click="CancelButton_Click"
                    Style="{StaticResource StartupDestructiveButtonStyle}"
                    Visibility="{Binding ShowCancelButton, Converter={StaticResource BoolToVisibilityConverter}}" />
        </StackPanel>
    </Grid>
</Window>
