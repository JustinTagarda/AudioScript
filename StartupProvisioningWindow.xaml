<Window x:Class="AudioScript.StartupProvisioningWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:AudioScript.ViewModels"
        mc:Ignorable="d"
        Title="Initializing AudioScript"
        Width="1040"
        MinWidth="920"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#2A1B2E"
        Foreground="#F6F3F8"
        FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style x:Key="AssetProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="8" />
            <Setter Property="Foreground" Value="#D79DEB" />
            <Setter Property="Background" Value="#4B3950" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="150" />
            <Setter Property="Padding" Value="22,10" />
            <Setter Property="Margin" Value="0,0,0,0" />
            <Setter Property="Background" Value="#4B3950" />
            <Setter Property="Foreground" Value="#F6F3F8" />
            <Setter Property="BorderBrush" Value="#5C4761" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="{Binding HeaderText}"
                       FontSize="32"
                       FontWeight="SemiBold"
                       Margin="0,0,0,10" />
        </StackPanel>

        <Border Grid.Row="1"
                Background="#3B2A3F"
                CornerRadius="12"
                Padding="18"
                Margin="0,0,0,18">
            <StackPanel>
                <TextBlock Text="{Binding CurrentAssetText}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <TextBlock Text="{Binding CurrentActivityText}"
                           FontSize="17"
                           Foreground="#DDD3E1" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="#3B2A3F"
                CornerRadius="12"
                Padding="18">
            <StackPanel>
                <TextBlock Text="Progress"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,14" />
                <ItemsControl ItemsSource="{Binding Assets}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:StartupProvisioningAssetViewModel}">
                            <StackPanel Margin="0,0,0,18">
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontSize="17"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding StatusText}"
                                                   FontSize="16"
                                                   Foreground="#D9D0DB"
                                                   Margin="0,0,18,0" />
                                        <TextBlock Text="{Binding PercentText}"
                                                   FontSize="16"
                                                   Foreground="#D9D0DB" />
                                    </StackPanel>
                                </Grid>
                                <ProgressBar Value="{Binding Percent, Mode=OneWay}"
                                             Maximum="100"
                                             Style="{StaticResource AssetProgressBarStyle}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    Margin="0,18,0,0">
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Click="CancelButton_Click"
                    Visibility="{Binding ShowCancelButton, Converter={StaticResource BoolToVisibilityConverter}}" />
            <Button x:Name="CloseButton"
                    Content="Close"
                    Click="CloseButton_Click"
                    Margin="12,0,0,0"
                    Visibility="{Binding ShowCloseButton, Converter={StaticResource BoolToVisibilityConverter}}" />
        </StackPanel>
    </Grid>
</Window>
