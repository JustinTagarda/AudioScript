<Window x:Class="AudioScript.OpenAiSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="OpenAI API Key"
        Icon="pack://application:,,,/assets/AudioScript.ico"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="560"
        MinWidth="560"
        MaxWidth="560"
        ShowInTaskbar="False">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Enter your OpenAI API key"
                   Margin="0,0,0,10"
                   FontSize="14"
                   FontWeight="SemiBold"/>

        <TextBlock Grid.Row="1"
                   Margin="0,0,0,10"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Text="Stored securely in Windows Credential Manager and used for AI-assisted transcription features."
                   TextWrapping="Wrap"/>

        <TextBox Grid.Row="2"
                 x:Name="ApiKeyTextBox"
                 Margin="0,0,0,14"
                 HorizontalAlignment="Stretch"
                 Width="Auto"
                 Padding="8,6"
                 ToolTip="Stored securely in Windows Credential Manager."/>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="RemoveButton"
                    Content="Remove Key"
                    MinWidth="96"
                    Margin="0,0,8,0"
                    Click="RemoveButton_Click"/>
            <Button x:Name="SaveButton"
                    Content="Save Key"
                    MinWidth="96"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>



