<Window x:Class="AudioScript.OpenAiSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="OpenAI Settings"
        Icon="pack://application:,,,/Assets/AudioScript.ico"
        Width="560"
        Height="280"
        MinWidth="560"
        MinHeight="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="14">
            <StackPanel>
                <TextBlock Text="OpenAI API Key"
                           FontSize="22" />
                <TextBlock Text="Changes apply immediately when AI transcription is turned on."
                           Margin="0,2,0,2"
                           FontSize="12" />

                <TextBlock Text="API Key" />
                <TextBox x:Name="ApiKeyTextBox" />

                <TextBlock Text="This key is used when Auto Transcribe with AI is turned on."
                           Margin="0,10,0,0"
                           FontSize="12" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button x:Name="RemoveButton"
                    Content="Remove Key"
                    Margin="0,0,8,0"
                    MinWidth="110"
                    Click="RemoveButton_Click" />
            <Button x:Name="SaveButton"
                    Content="Save"
                    MinWidth="110"
                    Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Window>



