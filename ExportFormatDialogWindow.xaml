<Window x:Class="AudioScript.ExportFormatDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Export Format"
        Icon="pack://application:,,,/assets/AudioScript.ico"
        Width="520"
        MinWidth="460"
        MinHeight="220"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="10">
            <StackPanel>
                <TextBlock Text="Choose transcript export format"
                           FontSize="18"/>
                <TextBlock Margin="0,8,0,0"
                           TextWrapping="Wrap"
                           Text="Select the output layout for this document export."/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1"
                    Margin="0,8,0,0">
            <Button Content="Table - Timestamp, Speaker, Text"
                    Tag="&#xE8A5;"
                    Style="{StaticResource ToolbarButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Padding="12,8"
                    Click="OptionTabDelimited_Click"/>
            <Button Content="Interview Layout - No Timeline"
                    Tag="&#xE8A5;"
                    Style="{StaticResource ToolbarPrimaryButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Padding="12,8"
                    Margin="0,8,0,0"
                    Click="OptionInterviewLayout_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="Cancel"
                    MinWidth="120"
                    MinHeight="28"
                    Padding="12,6"
                    Tag="&#xE711;"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
