<UserControl x:Class="AudioScript.Views.Controls.AppStatusDisplay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="24">
    <Grid>
        <Border HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Background="Transparent">
            <Grid>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom">
                    <TextBlock Text="{Binding ModeText}"
                               Margin="0,0,10,0"
                               FontSize="12"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               ToolTip="{Binding ModeTooltip}">
                        <TextBlock.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding UpgradeCommand}"/>
                        </TextBlock.InputBindings>
                        <TextBlock.Style>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="Cursor"
                                        Value="Hand"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPremium}"
                                                 Value="True">
                                        <Setter Property="Cursor"
                                                Value="Arrow"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                     <TextBlock x:Name="VersionTextBlock"
                                Text="{Binding VersionText}"
                                FontSize="12"
                                FontWeight="Normal"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <Popup PlacementTarget="{Binding ElementName=VersionTextBlock}"
                       Placement="Top"
                       AllowsTransparency="True"
                       StaysOpen="True"
                       IsOpen="{Binding IsVersionToastVisible, Mode=OneWay}">
                    <Border Margin="0,0,0,4"
                            Padding="8,4"
                            CornerRadius="6"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <TextBlock Text="{Binding VersionToastText}"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    </Border>
                </Popup>
            </Grid>
        </Border>
    </Grid>
</UserControl>
