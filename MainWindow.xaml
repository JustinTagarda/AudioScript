<Window x:Class="AudioScript.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AudioScript"
        xmlns:abstractions="clr-namespace:AudioScript.Abstractions"
        mc:Ignorable="d"
        Title="AudioScript"
        Icon="pack://application:,,,/Assets/AudioScript.ico"
        Height="670"
        Width="1080"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"

        AllowDrop="True"
        PreviewDragEnter="Window_PreviewDragEnter"
        PreviewDragOver="Window_PreviewDragOver"
        PreviewDragLeave="Window_PreviewDragLeave"
        PreviewDrop="Window_PreviewDrop">
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static local:MainWindow.InsertRowAboveCommand}"
                        CanExecute="TranscriptContextCommand_CanExecute"
                        Executed="InsertRowAboveCommand_Executed" />
        <CommandBinding Command="{x:Static local:MainWindow.InsertRowBelowCommand}"
                        CanExecute="TranscriptContextCommand_CanExecute"
                        Executed="InsertRowBelowCommand_Executed" />
        <CommandBinding Command="{x:Static local:MainWindow.DuplicateRowCommand}"
                        CanExecute="TranscriptContextCommand_CanExecute"
                        Executed="DuplicateRowCommand_Executed" />
        <CommandBinding Command="{x:Static local:MainWindow.DeleteRowCommand}"
                        CanExecute="TranscriptContextCommand_CanExecute"
                        Executed="DeleteRowCommand_Executed" />
        <CommandBinding Command="{x:Static local:MainWindow.CopyTextCommand}"
                        CanExecute="TranscriptContextCommand_CanExecute"
                        Executed="CopyTextCommand_Executed" />
        <CommandBinding Command="{x:Static local:MainWindow.CopyTimelineAndTextCommand}"
                        CanExecute="TranscriptContextCommand_CanExecute"
                        Executed="CopyTimelineAndTextCommand_Executed" />
    </Window.CommandBindings>
    <Window.Resources>
        <Style x:Key="FluentComboBoxItemStyle"
               TargetType="{x:Type ComboBoxItem}"
               BasedOn="{StaticResource {x:Type ComboBoxItem}}" />
        <Style x:Key="FluentListBoxItemStyle"
               TargetType="{x:Type ListBoxItem}"
               BasedOn="{StaticResource {x:Type ListBoxItem}}" />
        <Style x:Key="FluentListViewItemStyle"
               TargetType="{x:Type ListViewItem}"
               BasedOn="{StaticResource {x:Type ListViewItem}}" />
        <Style x:Key="FluentDataGridCellStyle"
               TargetType="{x:Type DataGridCell}"
               BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="FluentDataGridColumnHeaderStyle"
               TargetType="{x:Type DataGridColumnHeader}"
               BasedOn="{StaticResource {x:Type DataGridColumnHeader}}" />
        <Style x:Key="FluentDataGridRowStyle"
               TargetType="{x:Type DataGridRow}"
               BasedOn="{StaticResource {x:Type DataGridRow}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="ContextMenu">
                <Setter.Value>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="Insert Row Above"
                                  Command="{x:Static local:MainWindow.InsertRowAboveCommand}"
                                  CommandParameter="{Binding}" />
                        <MenuItem Header="Insert Row Below"
                                  Command="{x:Static local:MainWindow.InsertRowBelowCommand}"
                                  CommandParameter="{Binding}" />
                        <MenuItem Header="Duplicate Row"
                                  Command="{x:Static local:MainWindow.DuplicateRowCommand}"
                                  CommandParameter="{Binding}" />
                        <Separator />
                        <MenuItem Header="Delete Row"
                                  Command="{x:Static local:MainWindow.DeleteRowCommand}"
                                  CommandParameter="{Binding}" />
                        <Separator />
                        <MenuItem Header="Copy Text"
                                  Command="{x:Static local:MainWindow.CopyTextCommand}"
                                  CommandParameter="{Binding}" />
                        <MenuItem Header="Copy Timeline + Text"
                                  Command="{x:Static local:MainWindow.CopyTimelineAndTextCommand}"
                                  CommandParameter="{Binding}" />
                    </ContextMenu>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="FluentDataGridRowHeaderStyle"
               TargetType="{x:Type DataGridRowHeader}"
               BasedOn="{StaticResource {x:Type DataGridRowHeader}}" />
        <Style x:Key="FluentDataGridStyle"
               TargetType="{x:Type DataGrid}"
               BasedOn="{StaticResource {x:Type DataGrid}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowBackground" Value="Transparent" />
            <Setter Property="AlternatingRowBackground" Value="Transparent" />
            <Setter Property="CellStyle" Value="{StaticResource FluentDataGridCellStyle}" />
            <Setter Property="ColumnHeaderStyle" Value="{StaticResource FluentDataGridColumnHeaderStyle}" />
            <Setter Property="RowStyle" Value="{StaticResource FluentDataGridRowStyle}" />
            <Setter Property="RowHeaderStyle" Value="{StaticResource FluentDataGridRowHeaderStyle}" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="RowBackground" Value="Transparent" />
                    <Setter Property="AlternatingRowBackground" Value="Transparent" />
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="WorkspaceGridEditorTextBoxStyle"
               TargetType="{x:Type TextBox}"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource ControlCornerRadius}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainRootGrid"
>
        <DockPanel x:Name="MainContentHost"
                   LastChildFill="True">
            <StatusBar DockPanel.Dock="Bottom"
                       Margin="0"
                       MinHeight="28"
                       Padding="6,2"


>
                <StatusBarItem DockPanel.Dock="Right"
                               Padding="0"
>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="© 2026 JustinTagarda  •  "
                                   FontSize="12"/>
                        <TextBlock Text="{Binding ApplicationVersionStatusText}"
                                   ToolTip="{Binding ApplicationVersionStatusText}"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </StatusBarItem>

                <StatusBarItem DockPanel.Dock="Right"
                               Padding="0"
>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="API Key"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                ToolTip="OpenAI API Key"
                                AutomationProperties.Name="OpenAI API Key"
                                IsEnabled="{Binding IsOpenAiSettingsEnabled}"
                                Click="OpenOpenAiSettings_Click"/>
                        <ComboBox Width="129"
                                  Margin="0,0,10,0"
                                  ItemsSource="{Binding ThemeOptions}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Preference"
                                  SelectedValue="{Binding SelectedThemePreference, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  ItemContainerStyle="{StaticResource FluentComboBoxItemStyle}" />
                        <ToggleButton x:Name="LogsToggleButton"
                                      Content="Logs"
                                      Margin="0,0,20,0"
                                      IsEnabled="{Binding HasProcessLogs}"/>
                    </StackPanel>
                </StatusBarItem>

                <StatusBarItem DockPanel.Dock="Left"
                               Padding="0"
>
                    <TextBlock Text="{Binding StatusMessage}"
                               ToolTip="{Binding StatusMessage}"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"
/>
                </StatusBarItem>
            </StatusBar>

            <Border DockPanel.Dock="Bottom"
                    Margin="8,0,8,6"
                    Padding="8"
                    CornerRadius="6"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,14,0"
                                Orientation="Horizontal">
                        <TextBlock Text="Player"
                                   FontSize="16"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding LoadedAudioFileName}"
                                   Margin="20,0,0,0"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="220"/>
                    </StackPanel>

                    <Grid Grid.Row="1"
                          Grid.ColumnSpan="2"
                          Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0"
                                  Content="Auto play"
                                  Margin="0,0,12,0"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding AutoPlayTimelineSelection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1"
                                Margin="0,0,8,0"
                                Width="74">
                            <Button.Style>
                                <Style TargetType="Button"
                                       BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Content" Value="Play"/>
                                    <Setter Property="Command" Value="{Binding PlayAudioCommand}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAudioPlaying}"
                                                     Value="True">
                                            <Setter Property="Content" Value="Pause"/>
                                            <Setter Property="Command" Value="{Binding PauseAudioCommand}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding AudioElapsedText}"
                                   VerticalAlignment="Center"
                                    Margin="0,0,8,0"
                                   FontSize="12"
/>
                        <Slider Grid.Column="3"
                                Minimum="0"
                                Maximum="{Binding AudioSeekMaximumSeconds}"
                                Value="{Binding AudioSeekPositionSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                VerticalAlignment="Center"
                                IsEnabled="{Binding IsAudioFileLoaded}"/>
                        <TextBlock Grid.Column="4"
                                   Text="{Binding AudioRemainingText}"
                                   VerticalAlignment="Center"
                                    Margin="8,0,0,0"
                                    FontSize="12"
/>
                    </Grid>
                </Grid>
            </Border>

            <Border DockPanel.Dock="Bottom"
                    Margin="8,0,8,6"



>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChecked, ElementName=LogsToggleButton}"
                                         Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0"
                               Margin="8,8,8,6"
                               LastChildFill="False">
                        <TextBlock Text="Process Logs"
                                   DockPanel.Dock="Left"
                                   FontSize="16"
/>
                        <TextBlock Text="Latest activity"
                                   DockPanel.Dock="Right"
                                   VerticalAlignment="Center"
                                   FontSize="11"
/>
                    </DockPanel>

                    <ListView x:Name="ProcessLogsListView"
                              Grid.Row="1"
                              Margin="8,0,8,8"
                              Height="132"
                              ItemsSource="{Binding ProcessLogs}"
                              ItemContainerStyle="{StaticResource FluentListViewItemStyle}"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="10,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="88"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Time}"
/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Message}"
                                               Margin="12,0,0,0"

                                               TextWrapping="Wrap"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Grid Margin="6,2,6,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="332"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="10">
                        <StackPanel>
                            <TextBlock Text="Current Task"
                                       FontSize="18"
                                       Margin="0,0,0,10"
/>

                            <Border x:Name="AudioDropZoneBorder"
                                    Margin="0,2,0,0"
                                    Padding="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Drop audio file"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
>
                                            
                                        </TextBlock>
                                        <TextBlock Text="{Binding LoadedAudioFileName}"
                                                   Margin="0,2,0,0"
                                                   FontSize="11.5"
                                                   FontWeight="SemiBold"

                                                   TextTrimming="CharacterEllipsis">
                                            
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Content="Select Audio"
                                                VerticalAlignment="Center"
                                                Command="{Binding OpenAudioFileCommand}"/>
                                        <Border Width="8"/>
                                        <Button Content="Clear"
                                                VerticalAlignment="Center"
                                                Command="{Binding ClearCommand}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <TextBlock Text="{Binding CurrentSessionAudioIssue}"
                                       Margin="0,8,0,0"
                                       FontSize="11"

                                       TextWrapping="Wrap">
                                
                            </TextBlock>

                            <TextBlock Text="Mode"
                                       Margin="0,16,0,6"/>
                            <ItemsControl ItemsSource="{Binding TranscriptModes}"
                                          IsEnabled="{Binding IsTranscriptModeSelectionEnabled}"
                                          Margin="0,2,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <RadioButton GroupName="TranscriptModeGroup"
                                                     Margin="0,0,0,12"
                                                     IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}"
                                                            FontSize="13"
                                                            FontWeight="SemiBold"
/>
                                                <TextBlock Text="{Binding Description}"
                                                           Margin="0,3,0,0"
                                                           FontSize="10.5"

                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </RadioButton>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Grid Margin="0,10,0,0"
                                  HorizontalAlignment="Right">
                                <Grid.Style>
                                    <Style TargetType="{x:Type Grid}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSegmentModeSelected}"
                                                         Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="GenerateTranscriptButton"
                                        Grid.Column="0"
                                        MinWidth="156"
                                        Content="{Binding GenerateTranscriptButtonText}"
                                        IsEnabled="{Binding IsTranscriptGenerationEnabled}"
                                        Click="GenerateTranscript_Click">
                                    <Button.Style>
                                        <Style TargetType="Button"
                                               BasedOn="{StaticResource {x:Type Button}}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSegmentBatchTranscribing, RelativeSource={RelativeSource AncestorType=Window}}"
                                                             Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Grid.Column="0"
                                        MinWidth="156"
                                        Content="Cancel Transcription"
                                        Click="CancelProcessing_Click">
                                    <Button.Style>
                                        <Style TargetType="Button"
                                               BasedOn="{StaticResource {x:Type Button}}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSegmentBatchTranscribing, RelativeSource={RelativeSource AncestorType=Window}}"
                                                             Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>

                            <Grid Margin="0,10,0,0"
                                  HorizontalAlignment="Right">
                                <Grid.Style>
                                    <Style TargetType="{x:Type Grid}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSpeakerDiarizationModeSelected}"
                                                         Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button MinWidth="156"
                                        Content="{Binding GenerateTranscriptButtonText}"
                                        IsEnabled="{Binding IsTranscriptGenerationEnabled}"
                                        Click="GenerateTranscript_Click">
                                    <Button.Style>
                                        <Style TargetType="Button"
                                               BasedOn="{StaticResource {x:Type Button}}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSegmentBatchTranscribing, RelativeSource={RelativeSource AncestorType=Window}}"
                                                             Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button MinWidth="156"
                                        Content="Cancel Transcription"
                                        Click="CancelProcessing_Click">
                                    <Button.Style>
                                        <Style TargetType="Button"
                                               BasedOn="{StaticResource {x:Type Button}}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSegmentBatchTranscribing, RelativeSource={RelativeSource AncestorType=Window}}"
                                                             Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>

                            <Border



                                    Padding="10,9"
                                    Margin="0,10,0,0"
                                    CornerRadius="6"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  VerticalAlignment="Top"
                                                  Margin="0,1,10,0"
                                                  IsEnabled="{Binding IsEngineSelectionEnabled}"
                                                  IsChecked="{Binding IsAiAssistChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Checked="AutoTranscribeWithAiCheckBox_Checked"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="AI Assist"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
/>
                                            <TextBlock Text="{Binding AutoTranscribeAssistModeDescriptionText}"
                                                       Margin="0,2,0,0"
                                                       FontSize="10.5"

                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding AutoTranscribeAssistStatusText}"
                                                       Margin="0,4,0,0"
                                                       FontSize="10.5"

                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Padding="10"
                            Margin="0,10,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Sessions"
                                       FontSize="18"/>

                            <Grid Grid.Row="1"
                                  Margin="0,10,0,0">
                                <ListBox ItemsSource="{Binding RecentSessions}"
                                         SelectedItem="{Binding SelectedRecentSession}"
                                         HorizontalContentAlignment="Stretch"
                                         ItemContainerStyle="{StaticResource FluentListBoxItemStyle}"
                                         MouseDoubleClick="RecentSessionsList_MouseDoubleClick"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel ToolTip="{Binding DisplayName}">
                                                <TextBlock Text="{Binding OriginalFileName}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"

                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding UpdatedUtc, StringFormat=Updated {0:MMM dd, yyyy h:mm tt}}"
                                                           Margin="0,3,0,0"
                                                           FontSize="10.5"

                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                        <Border



                                        Padding="10">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasRecentSessions}"
                                                             Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    
                                    <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="No saved sessions yet"
                                                   HorizontalAlignment="Center"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
/>
                                        <TextBlock Text="Import an audio file to create your first transcript session."
                                                   Margin="0,4,0,0"
                                                   HorizontalAlignment="Center"
                                                   FontSize="10.5"

                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <StackPanel Grid.Row="2"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,10,0,0">
                                <Button Content="Load"
                                        Command="{Binding OpenSelectedSessionCommand}"/>
                                <Border Width="8"/>
                                <Button Content="Clear"
                                        Command="{Binding ClearCommand}"/>
                                <Border Width="8"/>
                                <Button Content="Delete"
                                        Command="{Binding DeleteSelectedSessionCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <GridSplitter Grid.Column="1"
                              Width="6"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Stretch"
                              ResizeDirection="Columns"
                              ResizeBehavior="PreviousAndNext"
                              ShowsPreview="True"/>

                <Border Grid.Column="2"
                        Padding="6"
                        Margin="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Transcript"
                                           FontSize="18"
/>
                                <TextBlock Text="{Binding TranscriptPaneSubtitle}"
                                           Margin="0,3,0,0"
                                           FontSize="11"

                                           TextTrimming="CharacterEllipsis">
                                    
                                </TextBlock>
                            </StackPanel>
                            <Grid Grid.Column="1"
                                  VerticalAlignment="Center">
                                
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Content="Copy with time"
                                            Grid.Column="0"
                                            IsChecked="{Binding CopyFinalizedWithTimeline, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <CheckBox.Style>
                                        <Style TargetType="CheckBox"
                                               BasedOn="{StaticResource {x:Type CheckBox}}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCopyWithTimelineOptionVisible}"
                                                             Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </CheckBox.Style>
                                </CheckBox>
                                <TextBlock Grid.Column="2"
                                            Text="Speaker copy includes labels and time."
                                            VerticalAlignment="Center"
                                            FontSize="10.5"
>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSpeakerCopyFormatVisible}"
                                                             Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Button Content="Copy"
                                        Grid.Column="4"
                                        VerticalAlignment="Center"
                                        ToolTip="Copy to Clipboard"
                                        AutomationProperties.Name="Copy to Clipboard"
                                        IsEnabled="{Binding CanCopyTranscript}"
                                        Click="CopyFinalizedToClipboard_Click"/>
                            </Grid>
                        </Grid>

                        <Border Grid.Row="1"
                                Margin="0,8,0,0"




                                ClipToBounds="True">
                            <Grid>
                            <DataGrid x:Name="FinalizedTranscriptGrid"
                                      ItemsSource="{Binding CurrentTranscriptLines}"
                                      Style="{StaticResource FluentDataGridStyle}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserResizeRows="False"
                                      SelectionMode="Single"
                                      SelectionUnit="Cell"
                                      CurrentCellChanged="FinalizedTranscriptGrid_CurrentCellChanged"
                                      GotKeyboardFocus="FinalizedTranscriptGrid_GotKeyboardFocus"
                                      LostKeyboardFocus="FinalizedTranscriptGrid_LostKeyboardFocus"
                                      BeginningEdit="FinalizedTranscriptGrid_BeginningEdit"
                                      CellEditEnding="FinalizedTranscriptGrid_CellEditEnding"
                                      PreviewKeyDown="FinalizedTranscriptGrid_PreviewKeyDown"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                                <DataGrid.Resources>
                                    <Style TargetType="{x:Type TextBox}"
                                           BasedOn="{StaticResource WorkspaceGridEditorTextBoxStyle}" />
                                </DataGrid.Resources>
                                
                                <DataGrid.Columns>
                                        <DataGridTemplateColumn x:Name="TimelineTranscriptColumn"
                                                            Header="Timeline"
                                                            CanUserSort="False"
                                                            Width="78">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Timeline}"
                                                           TextAlignment="Left"
                                                           HorizontalAlignment="Left"
                                                           Margin="10,0,0,0"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Timeline, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                                         MaxLength="5"
                                                         TextAlignment="Left"
                                                         Loaded="TimelineEditingTextBox_Loaded"
                                                         GotKeyboardFocus="TimelineEditingTextBox_GotKeyboardFocus"
                                                         PreviewTextInput="TimelineEditingTextBox_PreviewTextInput"
                                                         PreviewKeyDown="TimelineEditingTextBox_PreviewKeyDown"
                                                         DataObject.Pasting="TimelineEditingTextBox_Pasting"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn x:Name="SpeakerTranscriptColumn"
                                                        Header="Speaker"
                                                        Binding="{Binding SpeakerLabel}"
                                                        Width="136"/>
                                    <DataGridTemplateColumn x:Name="TranscriptTextColumn"
                                                            Header="Text"
                                                            CanUserSort="False"
                                                            Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <TextBlock Text="{Binding Text}">
                                                        
                                                    </TextBlock>
                                                    <Border HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            Margin="20,0"
                                                            Padding="0">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPlaybackEditTranscribing}"
                                                                                 Value="True">
                                                                        <Setter Property="Visibility"
                                                                                Value="Visible"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsPlaybackEditProgressIndeterminate}"
                                                                                 Value="True">
                                                                        <Setter Property="Visibility"
                                                                                Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        
                                                        <ProgressBar Value="{Binding PlaybackEditProgressPercent}"
                                                                     IsIndeterminate="{Binding IsPlaybackEditProgressIndeterminate}"/>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         IsReadOnly="{Binding IsPlaybackEditTranscribing}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                                <Border x:Name="TranscriptEmptyStateBorder"



                                        Padding="12"
                                        Margin="0,56,0,0"
                                        VerticalAlignment="Top"
                                        MaxWidth="360">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTranscriptEmptyStateVisible}"
                                                             Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                MaxWidth="320">
                                        <TextBlock Text="{Binding TranscriptEmptyStateTitle}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"

                                                   TextAlignment="Center"/>
                                        <TextBlock Text="{Binding TranscriptEmptyStateMessage}"
                                                   Margin="0,8,0,0"
                                                   FontSize="11"

                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"/>
                                        <Button Content="Select Audio"
                                                Margin="0,12,0,0"
                                                HorizontalAlignment="Center"
                                                Command="{Binding OpenAudioFileCommand}">
                                            <Button.Style>
                                                <Style TargetType="Button"
                                                       BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShouldShowTranscriptChooseFileAction}"
                                                                     Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </DockPanel>

        <Border x:Name="SegmentBatchOverlay"
                Panel.ZIndex="100"
                Background="Transparent"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <Grid>
                <Border HorizontalAlignment="Center"
                        x:Name="SegmentBatchCard"
                        VerticalAlignment="Center"
                        Width="320"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16,14">
                    
                    <StackPanel>
                        <TextBlock Text="{Binding TranscriptProcessingTitle, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontSize="18"

                                   HorizontalAlignment="Center"/>
                        <ProgressBar Width="160"
                                     Height="8"
                                     Margin="0,14,0,0"
                                     IsIndeterminate="True"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Margin="0,12,0,0"
                                   FontSize="12"

                                   TextAlignment="Center"
                                   TextWrapping="Wrap"/>
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                      Content="Mute"
                                      IsChecked="{Binding IsPlaybackMuted, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      VerticalAlignment="Center">
                                
                            </CheckBox>
                            <Button x:Name="SegmentBatchCancelButton"
                                    Grid.Column="2"
                                    Content="Cancel"
                                    HorizontalAlignment="Right"
                                    IsEnabled="True"
                                    Click="CancelProcessing_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="CopyToastHost"
                Panel.ZIndex="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,48"
                Opacity="0"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <Border.RenderTransform>
                <TranslateTransform x:Name="CopyToastTransform"
                                    Y="-14"/>
            </Border.RenderTransform>
            <Border
                    x:Name="CopyToastCard"
                    HorizontalAlignment="Center"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14,12"
                    MaxWidth="320">
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="CopyToastIconHost"
                            Width="34"
                            Height="34"




                            VerticalAlignment="Top">
                        <Viewbox Width="15"
                                 Height="15"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center">
                            <Path x:Name="CopyToastIconPath"

                                  StrokeThickness="2.6"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Data="M2.5,8.5 L6.2,12.2 L13.5,4.5"/>
                        </Viewbox>
                    </Border>
                    <StackPanel Grid.Column="1"
                                Margin="12,0,0,0">
                        <TextBlock x:Name="CopyToastTitleText"
                                   Text="Copied to clipboard"
                                   FontSize="13"
                                   FontWeight="SemiBold"
/>
                        <TextBlock x:Name="CopyToastMessageText"
                                   Text="Finalized transcript is ready to paste."
                                   Margin="0,3,0,0"
                                   FontSize="11"

                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>




