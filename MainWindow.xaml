<Window x:Class="VoxTranscriber.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:abstractions="clr-namespace:VoxTranscriber.Abstractions"
        mc:Ignorable="d"
        Title="VoxTranscriber"
        Icon="pack://application:,,,/Assets/VoxTranscriber.ico"
        Height="670"
        Width="1140"
        MinHeight="600"
        MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Background="#FFF4F7F8">
    <Window.Resources>
        <SolidColorBrush x:Key="SurfaceBrush"
                Color="#CCFFFFFF"/>
        <SolidColorBrush x:Key="SurfaceBorderBrush"
                Color="#55B7CAD2"/>
        <SolidColorBrush x:Key="PrimaryTextBrush"
                Color="#FF15232D"/>
        <SolidColorBrush x:Key="SecondaryTextBrush"
                Color="#FF49616F"/>
        <SolidColorBrush x:Key="PlaybackSyncTextBrush"
                Color="#FF4682B4"/>
        <SolidColorBrush x:Key="AccentBrush"
                Color="#FF1B86AA"/>
        <SolidColorBrush x:Key="AccentSurfaceBrush"
                Color="#FFE7F4F9"/>
        <SolidColorBrush x:Key="AccentBorderBrush"
                Color="#FFC6DDE7"/>

        <Style x:Key="CardStyle"
                TargetType="Border">
            <Setter Property="Background"
                    Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush"
                    Value="{StaticResource SurfaceBorderBrush}"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="CornerRadius"
                    Value="10"/>
            <Setter Property="SnapsToDevicePixels"
                    Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="22"
                            ShadowDepth="0"
                            Opacity="0.18"
                            Color="#FF7F97A6"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- DataGrid style with rounded corners to match parent card -->
        <Style x:Key="RoundedDataGridStyle" TargetType="DataGrid">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGrid">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="DG_ScrollViewer"
                                          Focusable="false"
                                          Padding="{TemplateBinding Padding}">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- ListView style with rounded corners for process logs panel -->
        <Style x:Key="RoundedListViewStyle" TargetType="ListView">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListView">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="LV_ScrollViewer"
                                          Focusable="false"
                                          Padding="{TemplateBinding Padding}">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CaptionTextStyle"
                TargetType="TextBlock">
            <Setter Property="FontFamily"
                    Value="Segoe UI Variable Text"/>
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
            <Setter Property="Foreground"
                    Value="{StaticResource SecondaryTextBrush}"/>
            <Setter Property="Margin"
                    Value="0,10,0,5"/>
            <Setter Property="FontSize"
                    Value="11"/>
        </Style>

        <Style x:Key="TranscriptCellProgressBarStyle"
               TargetType="ProgressBar">
            <Setter Property="Height"
                    Value="4"/>
            <Setter Property="Minimum"
                    Value="0"/>
            <Setter Property="Maximum"
                    Value="100"/>
            <Setter Property="Background"
                    Value="#FFD9E8EE"/>
            <Setter Property="Foreground"
                    Value="#FF1B86AA"/>
            <Setter Property="BorderBrush"
                    Value="#FFBBD1DB"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="VerticalAlignment"
                    Value="Center"/>
            <Setter Property="Margin"
                    Value="0"/>
        </Style>

        <Style x:Key="ModernComboBoxItemStyle"
               TargetType="ComboBoxItem">
            <Setter Property="Padding"
                    Value="10,7"/>
            <Setter Property="FontFamily"
                    Value="Segoe UI Variable Text"/>
            <Setter Property="FontSize"
                    Value="13"/>
            <Setter Property="Foreground"
                    Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted"
                                     Value="True">
                                <Setter TargetName="ItemBorder"
                                        Property="Background"
                                        Value="#FFEAF4F8"/>
                            </Trigger>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter TargetName="ItemBorder"
                                        Property="Background"
                                        Value="#FFDCEFF6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernComboBoxStyle"
               TargetType="ComboBox">
            <Setter Property="FontFamily"
                    Value="Segoe UI Variable Text"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="Foreground"
                    Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background"
                    Value="#FFFDFEFF"/>
            <Setter Property="BorderBrush"
                    Value="#FF9DB6C0"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="Padding"
                    Value="10,8"/>
            <Setter Property="MinHeight"
                    Value="40"/>
            <Setter Property="SnapsToDevicePixels"
                    Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="OuterBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"/>

                            <ToggleButton x:Name="DropDownToggle"
                                          Focusable="False"
                                          FocusVisualStyle="{x:Null}"
                                          OverridesDefaultStyle="True"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          HorizontalContentAlignment="Stretch"
                                          VerticalContentAlignment="Stretch">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"
                                                BorderThickness="0">
                                            <ContentPresenter HorizontalAlignment="Stretch"
                                                              VerticalAlignment="Stretch"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <Grid Margin="{TemplateBinding Padding}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter Grid.Column="0"
                                                      Margin="0,0,8,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"/>

                                    <Path x:Name="DropArrow"
                                          Grid.Column="1"
                                          Width="11"
                                          Height="7"
                                          Stretch="Fill"
                                          Stroke="#FF4B6775"
                                          StrokeThickness="1.8"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Data="M1,1 L5.5,6 L10,1"/>
                                </Grid>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Margin="0,4,0,0"
                                        Background="#FFFDFEFF"
                                        BorderBrush="#FF9DB6C0"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="300"
                                                  VerticalScrollBarVisibility="Auto"
                                                  CanContentScroll="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="OuterBorder"
                                        Property="BorderBrush"
                                        Value="#FFA9C8D6"/>
                                <Setter TargetName="OuterBorder"
                                        Property="Background"
                                        Value="#FFDFF1F8"/>
                                <Setter Property="Foreground"
                                        Value="#FF153949"/>
                                <Setter TargetName="DropArrow"
                                        Property="Stroke"
                                        Value="#FF153949"/>
                                <Setter Property="Cursor"
                                        Value="Hand"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin"
                                     Value="True">
                                <Setter TargetName="OuterBorder"
                                        Property="BorderBrush"
                                        Value="#FF1B86AA"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter TargetName="OuterBorder"
                                        Property="Background"
                                        Value="#FFF1F6F8"/>
                                <Setter TargetName="OuterBorder"
                                        Property="BorderBrush"
                                        Value="#FFD9E3E8"/>
                                <Setter Property="Foreground"
                                        Value="#FFA0B0B9"/>
                                <Setter TargetName="DropArrow"
                                        Property="Stroke"
                                        Value="#FFA0B0B9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TranscriptModeRadioButtonStyle"
               TargetType="RadioButton">
            <Setter Property="FontFamily"
                    Value="Segoe UI Variable Text"/>
            <Setter Property="FontSize"
                    Value="13"/>
            <Setter Property="Foreground"
                    Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background"
                    Value="#FFFDFEFF"/>
            <Setter Property="BorderBrush"
                    Value="#FFD5E4EA"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="Padding"
                    Value="14,12"/>
            <Setter Property="Margin"
                    Value="0,0,0,8"/>
            <Setter Property="MinHeight"
                    Value="64"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="HorizontalContentAlignment"
                    Value="Stretch"/>
            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="OuterBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Width="16"
                                      Height="16"
                                      VerticalAlignment="Center">
                                    <Ellipse Stroke="#FF8EABB6"
                                             StrokeThickness="1.2"
                                             Fill="Transparent"/>
                                    <Ellipse x:Name="SelectionDot"
                                             Width="8"
                                             Height="8"
                                             Fill="{StaticResource AccentBrush}"
                                             Visibility="Collapsed"/>
                                </Grid>
                                <ContentPresenter Grid.Column="1"
                                                  Margin="10,0,0,0"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="OuterBorder"
                                        Property="Background"
                                        Value="#FFF7FBFD"/>
                                <Setter TargetName="OuterBorder"
                                        Property="BorderBrush"
                                        Value="#FF9DB6C0"/>
                            </Trigger>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter Property="FontWeight"
                                        Value="SemiBold"/>
                                <Setter TargetName="OuterBorder"
                                        Property="Background"
                                        Value="{StaticResource AccentSurfaceBrush}"/>
                                <Setter TargetName="OuterBorder"
                                        Property="BorderBrush"
                                        Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="SelectionDot"
                                        Property="Visibility"
                                        Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter TargetName="OuterBorder"
                                        Property="Opacity"
                                        Value="0.58"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Width"
                    Value="42"/>
            <Setter Property="MinWidth"
                    Value="42"/>
            <Setter Property="MinHeight"
                    Value="38"/>
            <Setter Property="Padding"
                    Value="0"/>
            <Setter Property="Margin"
                    Value="8,0,4,0"/>
        </Style>

        <Style x:Key="SettingsIconButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource IconActionButtonStyle}">
            <Setter Property="Width"
                    Value="28"/>
            <Setter Property="MinWidth"
                    Value="28"/>
            <Setter Property="Height"
                    Value="28"/>
            <Setter Property="MinHeight"
                    Value="28"/>
            <Setter Property="Margin"
                    Value="0"/>
            <Setter Property="Background"
                    Value="#FF1B86AA"/>
            <Setter Property="BorderBrush"
                    Value="#FF1B86AA"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SettingsIconBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="SettingsIconBorder"
                                        Property="Background"
                                        Value="#FF2597BE"/>
                                <Setter TargetName="SettingsIconBorder"
                                        Property="BorderBrush"
                                        Value="#FF2597BE"/>
                                <Setter Property="Cursor"
                                        Value="Hand"/>
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="SettingsIconBorder"
                                        Property="Background"
                                        Value="#FF176E8D"/>
                                <Setter TargetName="SettingsIconBorder"
                                        Property="BorderBrush"
                                        Value="#FF176E8D"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter TargetName="SettingsIconBorder"
                                        Property="Background"
                                        Value="#FFD9E3E8"/>
                                <Setter TargetName="SettingsIconBorder"
                                        Property="BorderBrush"
                                        Value="#FFD9E3E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlaybackActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Height"
                    Value="29"/>
            <Setter Property="MinHeight"
                    Value="29"/>
            <Setter Property="Padding"
                    Value="12,4"/>
        </Style>

        <Style x:Key="PlaybackSecondaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height"
                    Value="29"/>
            <Setter Property="MinHeight"
                    Value="29"/>
            <Setter Property="Padding"
                    Value="12,4"/>
        </Style>

        <Style x:Key="PlaybackIconButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource IconActionButtonStyle}">
            <Setter Property="Height"
                    Value="29"/>
            <Setter Property="MinHeight"
                    Value="29"/>
        </Style>

        <Style x:Key="StatusToggleButtonStyle"
               TargetType="ToggleButton">
            <Setter Property="FontFamily"
                    Value="Segoe UI Variable Text"/>
            <Setter Property="FontSize"
                    Value="12"/>
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
            <Setter Property="Foreground"
                    Value="{StaticResource SecondaryTextBrush}"/>
            <Setter Property="Background"
                    Value="#FFF8FBFC"/>
            <Setter Property="BorderBrush"
                    Value="#FFB8CBD5"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="Padding"
                    Value="12,5"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="ToggleBorder"
                                        Property="Background"
                                        Value="#FFEFF6F9"/>
                                <Setter TargetName="ToggleBorder"
                                        Property="BorderBrush"
                                        Value="#FF9FB7C3"/>
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="ToggleBorder"
                                        Property="Background"
                                        Value="#FFE6F0F5"/>
                                <Setter TargetName="ToggleBorder"
                                        Property="BorderBrush"
                                        Value="#FF8FAAB7"/>
                            </Trigger>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter Property="Foreground"
                                        Value="{StaticResource PrimaryTextBrush}"/>
                                <Setter TargetName="ToggleBorder"
                                        Property="Background"
                                        Value="{StaticResource AccentSurfaceBrush}"/>
                                <Setter TargetName="ToggleBorder"
                                        Property="BorderBrush"
                                        Value="{StaticResource AccentBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter TargetName="ToggleBorder"
                                        Property="Background"
                                        Value="#FFF1F6F8"/>
                                <Setter TargetName="ToggleBorder"
                                        Property="BorderBrush"
                                        Value="#FFD9E3E8"/>
                                <Setter Property="Foreground"
                                        Value="#FFA0B0B9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarCheckBoxStyle"
               TargetType="CheckBox">
            <Setter Property="FontFamily"
                    Value="Segoe UI Variable Text"/>
            <Setter Property="FontSize"
                    Value="13"/>
            <Setter Property="Foreground"
                    Value="{StaticResource SecondaryTextBrush}"/>
            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>
            <Setter Property="VerticalAlignment"
                    Value="Center"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Margin"
                    Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="BulletBorder"
                                    Grid.Column="0"
                                    Width="16"
                                    Height="16"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    CornerRadius="4"
                                    Background="#FFFDFEFF"
                                    BorderBrush="#FF9DB6C0"
                                    BorderThickness="1">
                                <Path x:Name="CheckMark"
                                      Data="M3.2,8.2 L6.4,11.3 L12.6,4.4"
                                      Stroke="{StaticResource AccentBrush}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Grid.Column="1"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="BulletBorder"
                                        Property="BorderBrush"
                                        Value="#FFA9C8D6"/>
                                <Setter Property="Foreground"
                                        Value="{StaticResource PrimaryTextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter TargetName="BulletBorder"
                                        Property="BorderBrush"
                                        Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="BulletBorder"
                                        Property="Background"
                                        Value="{StaticResource AccentSurfaceBrush}"/>
                                <Setter TargetName="CheckMark"
                                        Property="Visibility"
                                        Value="Visible"/>
                                <Setter Property="Foreground"
                                        Value="{StaticResource PrimaryTextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter TargetName="BulletBorder"
                                        Property="Background"
                                        Value="#FFF1F6F8"/>
                                <Setter TargetName="BulletBorder"
                                        Property="BorderBrush"
                                        Value="#FFD9E3E8"/>
                                <Setter Property="Foreground"
                                        Value="#FFA0B0B9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsCheckBoxStyle"
               TargetType="CheckBox"
               BasedOn="{StaticResource ToolbarCheckBoxStyle}">
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
            <Setter Property="Foreground"
                    Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Margin"
                    Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="BulletBorder"
                                    Grid.Column="0"
                                    Width="18"
                                    Height="18"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center"
                                    CornerRadius="5"
                                    Background="#FFFDFEFF"
                                    BorderBrush="#FF9DB6C0"
                                    BorderThickness="1">
                                <Path x:Name="CheckMark"
                                      Data="M3.6,9.1 L7.2,12.6 L14.2,5.6"
                                      Stroke="{StaticResource AccentBrush}"
                                      StrokeThickness="2.2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Grid.Column="1"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="BulletBorder"
                                        Property="BorderBrush"
                                        Value="#FFA9C8D6"/>
                            </Trigger>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter TargetName="BulletBorder"
                                        Property="BorderBrush"
                                        Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="BulletBorder"
                                        Property="Background"
                                        Value="{StaticResource AccentSurfaceBrush}"/>
                                <Setter TargetName="CheckMark"
                                        Property="Visibility"
                                        Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter TargetName="BulletBorder"
                                        Property="Background"
                                        Value="#FFF1F6F8"/>
                                <Setter TargetName="BulletBorder"
                                        Property="BorderBrush"
                                        Value="#FFD9E3E8"/>
                                <Setter Property="Foreground"
                                        Value="#FFA0B0B9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TranscriptOverlayActionButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource ButtonChromeStyle}">
            <Setter Property="Width"
                    Value="16"/>
            <Setter Property="Height"
                    Value="16"/>
            <Setter Property="MinWidth"
                    Value="16"/>
            <Setter Property="MinHeight"
                    Value="16"/>
            <Setter Property="Padding"
                    Value="0"/>
            <Setter Property="Margin"
                    Value="0"/>
            <Setter Property="Focusable"
                    Value="False"/>
            <Setter Property="IsTabStop"
                    Value="False"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="BorderBrush"
                    Value="Transparent"/>
            <Setter Property="Foreground"
                    Value="#FF234F61"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ActionBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="ActionBorder"
                                        Property="Background"
                                        Value="{StaticResource AccentSurfaceBrush}"/>
                                <Setter TargetName="ActionBorder"
                                        Property="BorderBrush"
                                        Value="{StaticResource AccentBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="ActionBorder"
                                        Property="Background"
                                        Value="#FFDCEFF6"/>
                                <Setter TargetName="ActionBorder"
                                        Property="BorderBrush"
                                        Value="#FFB7D4E1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainRootGrid"
          Background="#FFF4F7F8">
        <DockPanel x:Name="MainContentHost"
                   LastChildFill="True">
            <StatusBar DockPanel.Dock="Bottom"
                       Margin="0"
                       MinHeight="32"
                       Padding="10,2"
                       Background="#FFEFF3F6"
                       BorderBrush="#FFC8D6DD"
                       BorderThickness="1,1,1,0">
                <StatusBarItem DockPanel.Dock="Right"
                               Padding="0"
                               BorderThickness="0">
                    <TextBlock Text="{Binding ApplicationVersionStatusText}"
                               ToolTip="{Binding ApplicationVersionStatusText}"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                </StatusBarItem>

                <StatusBarItem DockPanel.Dock="Right"
                               Padding="0"
                               BorderThickness="0">
                    <ToggleButton x:Name="LogsToggleButton"
                                  Content="Logs"
                                  Margin="0,0,12,0"
                                  Style="{StaticResource StatusToggleButtonStyle}"
                                  IsEnabled="{Binding HasProcessLogs}"/>
                </StatusBarItem>

                <StatusBarItem DockPanel.Dock="Left"
                               Padding="0"
                               BorderThickness="0">
                    <TextBlock Text="{Binding StatusMessage}"
                               ToolTip="{Binding StatusMessage}"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                </StatusBarItem>
            </StatusBar>

            <Border DockPanel.Dock="Bottom"
                    Style="{StaticResource CardStyle}"
                    Margin="11,0,11,8"
                    Padding="14,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,18,0">
                        <TextBlock Text="Audio Player"
                                   FontFamily="Bahnschrift"
                                   FontSize="18"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="{Binding LoadedAudioFileName}"
                                   Margin="0,4,0,0"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="260"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0"
                                Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Content="Play"
                                Style="{StaticResource PlaybackActionButtonStyle}"
                                MinWidth="74"
                                Margin="0,0,8,0"
                                Command="{Binding PlayAudioCommand}"/>
                        <Button Content="Pause"
                                Style="{StaticResource PlaybackSecondaryButtonStyle}"
                                MinWidth="74"
                                Margin="0,0,8,0"
                                Command="{Binding PauseAudioCommand}"/>
                        <Button Content="Stop"
                                Style="{StaticResource PlaybackSecondaryButtonStyle}"
                                MinWidth="74"
                                Margin="0,0,8,0"
                                Command="{Binding StopAudioCommand}"/>
                        <Button ToolTip="Rewind 5 seconds"
                                AutomationProperties.Name="Rewind 5 seconds"
                                Style="{StaticResource PlaybackIconButtonStyle}"
                                Margin="0,0,8,0"
                                Command="{Binding RewindAudioCommand}">
                            <Viewbox Width="11.2"
                                     Height="11.2"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Stretch="Uniform"
                                      Data="M14,4 L8,10 L14,16 Z M8.5,4 L2.5,10 L8.5,16 Z"/>
                            </Viewbox>
                        </Button>
                        <Button ToolTip="Forward 5 seconds"
                                AutomationProperties.Name="Forward 5 seconds"
                                Style="{StaticResource PlaybackIconButtonStyle}"
                                Margin="0"
                                Command="{Binding ForwardAudioCommand}">
                            <Viewbox Width="11.2"
                                     Height="11.2"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Stretch="Uniform"
                                      Data="M2,4 L8,10 L2,16 Z M7.5,4 L13.5,10 L7.5,16 Z"/>
                            </Viewbox>
                        </Button>
                    </StackPanel>

                    <Grid Grid.Row="1"
                          Grid.ColumnSpan="2"
                          Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding AudioElapsedText}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                        <Slider Grid.Column="1"
                                Minimum="0"
                                Maximum="{Binding AudioSeekMaximumSeconds}"
                                Value="{Binding AudioSeekPositionSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                VerticalAlignment="Center"
                                IsEnabled="{Binding IsAudioFileLoaded}"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding AudioRemainingText}"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                    </Grid>
                </Grid>
            </Border>

            <Border DockPanel.Dock="Bottom"
                    Margin="11,0,11,8"
                    Background="#FFFDFEFF"
                    BorderBrush="#FFD2E2E7"
                    BorderThickness="1"
                    CornerRadius="10">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility"
                                Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsChecked, ElementName=LogsToggleButton}"
                                               Value="True"/>
                                    <Condition Binding="{Binding HasProcessLogs}"
                                               Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility"
                                        Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0"
                               Margin="14,12,14,10"
                               LastChildFill="False">
                        <TextBlock Text="Process Logs"
                                   DockPanel.Dock="Left"
                                   FontFamily="Bahnschrift"
                                   FontSize="18"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="Latest activity"
                                   DockPanel.Dock="Right"
                                   VerticalAlignment="Center"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="11"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                    </DockPanel>

                    <ListView x:Name="ProcessLogsListView"
                              Grid.Row="1"
                              Margin="12,0,12,12"
                              Height="168"
                              Style="{StaticResource RoundedListViewStyle}"
                              ItemsSource="{Binding ProcessLogs}"
                              BorderBrush="#FFD2E2E7"
                              BorderThickness="1"
                              Background="Transparent"
                              FontFamily="Segoe UI Variable Text"
                              FontSize="12"
                              Foreground="#808080"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="{x:Type ListViewItem}">
                                <Setter Property="Padding"
                                        Value="0"/>
                                <Setter Property="Margin"
                                        Value="0"/>
                                <Setter Property="HorizontalContentAlignment"
                                        Value="Stretch"/>
                                <Setter Property="VerticalContentAlignment"
                                        Value="Top"/>
                                <Setter Property="Background"
                                        Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected"
                                             Value="True">
                                        <Setter Property="Background"
                                                Value="#FFEAF4F8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="10,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="88"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Time}"
                                               FontFamily="Consolas"
                                               Foreground="#808080"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Message}"
                                               Margin="12,0,0,0"
                                               Foreground="#808080"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Grid Margin="11,3,11,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="372"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource CardStyle}"
                        Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="0"/>
                            <RowDefinition Height="0"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Current Task"
                                       FontFamily="Bahnschrift"
                                       FontSize="20"
                                       Foreground="{StaticResource PrimaryTextBrush}"/>

                            <TextBlock Text="AI Assist"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,12,0,7"/>
                            <Border Background="#FFFDFEFF"
                                    BorderBrush="#FFD2E2E7"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0"
                                          VerticalAlignment="Center">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility"
                                                        Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAutoTranscribeSettingVisible}"
                                                                 Value="False">
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  Style="{StaticResource SettingsCheckBoxStyle}"
                                                  VerticalAlignment="Top"
                                                  Margin="0,2,6,0"
                                                  IsEnabled="{Binding IsEngineSelectionEnabled}"
                                                  IsChecked="{Binding AutoTranscribeWithAi, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Checked="AutoTranscribeWithAiCheckBox_Checked"/>

                                        <Grid Grid.Column="1"
                                              VerticalAlignment="Center">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0"
                                                       Text="Auto Transcribe with AI"
                                                       FontFamily="Segoe UI Variable Text"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                                            <TextBlock Grid.Row="1"
                                                       Text="Turn this on to let AI help transcribe audio."
                                                       Margin="0,-1,0,0"
                                                       FontFamily="Segoe UI Variable Text"
                                                       FontSize="11"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       TextWrapping="Wrap"/>
                                        </Grid>
                                    </Grid>

                                    <StackPanel Grid.Column="0"
                                                VerticalAlignment="Center">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility"
                                                        Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSpeakerDiarizationNoticeVisible}"
                                                                 Value="True">
                                                        <Setter Property="Visibility"
                                                                Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="Speaker diarization"
                                                   FontFamily="Segoe UI Variable Text"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                                        <TextBlock Text="This mode always uses OpenAI gpt-4o-transcribe-diarize."
                                                   Margin="0,-1,0,0"
                                                   FontFamily="Segoe UI Variable Text"
                                                   FontSize="11"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Content="API Settings"
                                            Style="{StaticResource PlaybackSecondaryButtonStyle}"
                                            Height="32"
                                            MinHeight="32"
                                            Margin="10,0,0,0"
                                            Padding="12,4"
                                            ToolTip="OpenAI API Key"
                                            AutomationProperties.Name="OpenAI API Key"
                                            IsEnabled="{Binding IsOpenAiSettingsEnabled}"
                                            Click="OpenOpenAiSettings_Click"/>
                                </Grid>
                            </Border>

                            <TextBlock Text="Transcription"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,12,0,5"/>
                            <Border Background="#FFFDFEFF"
                                    BorderBrush="#FFD2E2E7"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Button Grid.Row="0"
                                            Content="Choose Audio File"
                                            Style="{StaticResource PlaybackSecondaryButtonStyle}"
                                            Height="33"
                                            MinHeight="33"
                                            Command="{Binding OpenAudioFileCommand}"/>
                                    <StackPanel Grid.Row="1"
                                                Margin="0,10,0,0">
                                        <TextBlock Text="Transcript mode"
                                                   FontFamily="Segoe UI Variable Text"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   Margin="0,0,0,5"/>
                                        <Border Background="#FFFDFEFF"
                                                BorderBrush="#FF9DB6C0"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="6">
                                            <ItemsControl ItemsSource="{Binding TranscriptModes}"
                                                          IsEnabled="{Binding IsTranscriptModeSelectionEnabled}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <RadioButton Content="{Binding DisplayName}"
                                                                     GroupName="TranscriptModeGroup"
                                                                     IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                     Style="{StaticResource TranscriptModeRadioButtonStyle}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Border>
                                    </StackPanel>
                                    <Grid Grid.Row="2"
                                          Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="GenerateTranscriptButton"
                                                Grid.Column="0"
                                                Content="{Binding GenerateTranscriptButtonText}"
                                                Height="33"
                                                MinHeight="33"
                                                IsEnabled="{Binding IsTranscriptGenerationEnabled}"
                                                Click="GenerateTranscript_Click">
                                            <Button.Style>
                                                <Style TargetType="{x:Type Button}"
                                                       BasedOn="{StaticResource PlaybackActionButtonStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSegmentBatchTranscribing, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                     Value="True">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Grid.Column="1"
                                                Content="Cancel Transcription"
                                                Height="33"
                                                MinHeight="33"
                                                Margin="8,0"
                                                Click="CancelProcessing_Click">
                                            <Button.Style>
                                                <Style TargetType="{x:Type Button}"
                                                       BasedOn="{StaticResource PlaybackActionButtonStyle}">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed"/>
                                                    <Setter Property="IsEnabled"
                                                            Value="False"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSegmentBatchTranscribing, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                     Value="True">
                                                            <Setter Property="Visibility"
                                                                    Value="Visible"/>
                                                            <Setter Property="IsEnabled"
                                                                    Value="True"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Grid.Column="2"
                                                Content="Clear"
                                                Style="{StaticResource PlaybackSecondaryButtonStyle}"
                                                Height="33"
                                                MinHeight="33"
                                                Command="{Binding ClearCommand}"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <TextBlock Text="Sessions"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,12,0,5"/>
                            <Border Background="#FFFDFEFF"
                                    BorderBrush="#FFD2E2E7"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="10">
                                <StackPanel>
                                    <ListBox ItemsSource="{Binding RecentSessions}"
                                             SelectedItem="{Binding SelectedRecentSession}"
                                             Height="112"
                                             HorizontalContentAlignment="Stretch"
                                             Grid.IsSharedSizeScope="True"
                                             MouseDoubleClick="RecentSessionsList_MouseDoubleClick"
                                             BorderThickness="1"
                                             BorderBrush="#FFD2E2E7"
                                             Background="#FFF8FBFC"
                                             FontFamily="Segoe UI Variable Text"
                                             Foreground="{StaticResource PrimaryTextBrush}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="4,3"
                                                      ToolTip="{Binding DisplayName}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"
                                                                          SharedSizeGroup="SessionFileColumn"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding OriginalFileName}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding UpdatedUtc, StringFormat=Updated {0:MMM dd, yyyy HH:mm}}"
                                                               Margin="14,0,0,0"
                                                               FontSize="11"
                                                               Foreground="{StaticResource SecondaryTextBrush}"
                                                               TextAlignment="Right"
                                                               HorizontalAlignment="Stretch"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                Margin="0,6,0,0">
                                        <Button Content="Open"
                                                Style="{StaticResource PlaybackSecondaryButtonStyle}"
                                                MinWidth="0"
                                                Width="72"
                                                Margin="0,0,6,0"
                                                Command="{Binding OpenSelectedSessionCommand}"/>
                                        <Button Content="Delete"
                                                Style="{StaticResource DangerButtonStyle}"
                                                MinWidth="0"
                                                Width="72"
                                                Height="29"
                                                MinHeight="29"
                                                Padding="12,4"
                                                Command="{Binding DeleteSelectedSessionCommand}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Audio File"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,12,0,5"
                                       Visibility="Collapsed"/>
                            <Border Background="#FFFDFEFF"
                                    BorderBrush="#FFD2E2E7"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="10"
                                    Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="{Binding LoadedAudioFileName}"
                                               FontFamily="Segoe UI Variable Text"
                                               FontSize="12"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding CurrentSessionAudioIssue}"
                                               Margin="0,6,0,0"
                                               FontFamily="Segoe UI Variable Text"
                                               FontSize="11"
                                               Foreground="#FF8A4B1D"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility"
                                                        Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentSessionAudioIssue}"
                                                                 Value="">
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Content="Play"
                                                Style="{StaticResource PlaybackActionButtonStyle}"
                                                Command="{Binding PlayAudioCommand}"/>
                                        <Button Grid.Column="1"
                                                Content="Pause"
                                                Style="{StaticResource PlaybackSecondaryButtonStyle}"
                                                Command="{Binding PauseAudioCommand}"/>
                                        <Button Grid.Column="2"
                                                Content="Stop"
                                                Style="{StaticResource PlaybackSecondaryButtonStyle}"
                                                Command="{Binding StopAudioCommand}"/>
                                        <Button Grid.Column="3"
                                                ToolTip="Rewind 5 seconds"
                                                AutomationProperties.Name="Rewind 5 seconds"
                                                Style="{StaticResource PlaybackIconButtonStyle}"
                                                Command="{Binding RewindAudioCommand}">
                                            <Viewbox Width="11.2"
                                                     Height="11.2"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center">
                                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                      Stretch="Uniform"
                                                      Data="M14,4 L8,10 L14,16 Z M8.5,4 L2.5,10 L8.5,16 Z"/>
                                            </Viewbox>
                                        </Button>
                                        <Button Grid.Column="4"
                                                ToolTip="Forward 5 seconds"
                                                AutomationProperties.Name="Forward 5 seconds"
                                                Style="{StaticResource PlaybackIconButtonStyle}"
                                                Command="{Binding ForwardAudioCommand}">
                                            <Viewbox Width="11.2"
                                                     Height="11.2"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center">
                                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                      Stretch="Uniform"
                                                      Data="M2,4 L8,10 L2,16 Z M7.5,4 L13.5,10 L7.5,16 Z"/>
                                            </Viewbox>
                                        </Button>
                                    </Grid>
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding AudioElapsedText}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"
                                                   FontFamily="Consolas"
                                                   FontSize="12"
                                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                                        <Slider Grid.Column="1"
                                                Minimum="0"
                                                Maximum="{Binding AudioSeekMaximumSeconds}"
                                                Value="{Binding AudioSeekPositionSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                VerticalAlignment="Center"
                                                IsEnabled="{Binding IsAudioFileLoaded}"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding AudioRemainingText}"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0"
                                                   FontFamily="Consolas"
                                                   FontSize="12"
                                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                        </StackPanel>

                        <TextBlock Grid.Row="1"
                                   Text="Process Logs"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,12,0,5"
                                   Visibility="Collapsed"/>

                        <Border Grid.Row="2"
                                Background="#FFFDFEFF"
                                BorderBrush="#FFD2E2E7"
                                BorderThickness="1"
                                CornerRadius="10"
                                ClipToBounds="True"
                                Visibility="Collapsed">
                            <ListView x:Name="LegacyProcessLogsListView"
                                      Style="{StaticResource RoundedListViewStyle}"
                                      ItemsSource="{Binding ProcessLogs}"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      FontFamily="Segoe UI Variable Text"
                                      FontSize="12"
                                      Foreground="#808080"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListView.Resources>
                                    <Style TargetType="{x:Type GridViewColumnHeader}">
                                        <Setter Property="FontFamily"
                                                Value="Segoe UI Variable Text"/>
                                        <Setter Property="FontSize"
                                                Value="12"/>
                                        <Setter Property="FontWeight"
                                                Value="SemiBold"/>
                                        <Setter Property="Foreground"
                                                Value="{StaticResource SecondaryTextBrush}"/>
                                        <Setter Property="Background"
                                                Value="#FFF6FAFC"/>
                                        <Setter Property="BorderBrush"
                                                Value="#FFD2E2E7"/>
                                        <Setter Property="BorderThickness"
                                                Value="0,0,0,1"/>
                                        <Setter Property="Padding"
                                                Value="6,5"/>
                                    </Style>
                                </ListView.Resources>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="{x:Type ListViewItem}">
                                        <Setter Property="Padding"
                                                Value="0"/>
                                        <Setter Property="Margin"
                                                Value="0"/>
                                        <Setter Property="HorizontalContentAlignment"
                                                Value="Stretch"/>
                                        <Setter Property="VerticalContentAlignment"
                                                Value="Top"/>
                                        <Setter Property="Background"
                                                Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected"
                                                     Value="True">
                                                <Setter Property="Background"
                                                        Value="#FFEAF4F8"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.View>
                                    <GridView AllowsColumnReorder="False">
                                        <GridViewColumn Header="Time"
                                                        Width="74">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Time}"
                                                               Foreground="#808080"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Log"
                                                        Width="246">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Message}"
                                                               Foreground="#808080"
                                                               TextWrapping="Wrap"
                                                               Margin="0,0,4,0"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Border>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1"
                              Width="6"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Stretch"
                              ResizeDirection="Columns"
                              ResizeBehavior="PreviousAndNext"
                              Background="Transparent"
                              ShowsPreview="True"/>

                <Border Grid.Column="2"
                        Style="{StaticResource CardStyle}"
                        Padding="10"
                        Margin="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Transcript"
                                           FontFamily="Bahnschrift"
                                           FontSize="20"
                                           Foreground="{StaticResource PrimaryTextBrush}"/>
                                <TextBlock Text="{Binding TranscriptPaneSubtitle}"
                                           Margin="0,4,0,0"
                                           FontFamily="Segoe UI Variable Text"
                                           FontSize="12"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Grid Grid.Column="1"
                                  VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Content="Include timeline in copy"
                                           Grid.Column="0"
                                           IsChecked="{Binding CopyFinalizedWithTimeline, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <CheckBox.Style>
                                        <Style TargetType="CheckBox"
                                               BasedOn="{StaticResource ToolbarCheckBoxStyle}">
                                            <Setter Property="Visibility"
                                                    Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCopyWithTimelineOptionVisible}"
                                                             Value="False">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </CheckBox.Style>
                                </CheckBox>
                                <TextBlock Grid.Column="1"
                                           Text="Speaker copy always includes labels and timestamps."
                                           Margin="0,0,10,0"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe UI Variable Text"
                                           FontSize="11"
                                           Foreground="{StaticResource SecondaryTextBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSpeakerCopyFormatVisible}"
                                                             Value="True">
                                                    <Setter Property="Visibility"
                                                            Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Button Content="Copy"
                                        Style="{StaticResource PlaybackSecondaryButtonStyle}"
                                        Grid.Column="2"
                                        MinWidth="72"
                                        VerticalAlignment="Center"
                                        ToolTip="Copy to Clipboard"
                                        AutomationProperties.Name="Copy to Clipboard"
                                        IsEnabled="{Binding CanCopyTranscript}"
                                        Click="CopyFinalizedToClipboard_Click"/>
                            </Grid>
                        </Grid>

                        <Border Grid.Row="1"
                                Margin="0,10,0,0"
                                Background="#FFFDFEFF"
                                BorderBrush="#FFD2E2E7"
                                BorderThickness="1"
                                CornerRadius="10"
                                ClipToBounds="True">
                            <Grid>
                            <DataGrid x:Name="FinalizedTranscriptGrid"
                                      Style="{StaticResource RoundedDataGridStyle}"
                                      ItemsSource="{Binding CurrentTranscriptLines}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserResizeRows="False"
                                      HeadersVisibility="Column"
                                      RowHeaderWidth="0"
                                      GridLinesVisibility="None"
                                      SelectionMode="Single"
                                      SelectionUnit="Cell"
                                      CurrentCellChanged="FinalizedTranscriptGrid_CurrentCellChanged"
                                      GotKeyboardFocus="FinalizedTranscriptGrid_GotKeyboardFocus"
                                      LostKeyboardFocus="FinalizedTranscriptGrid_LostKeyboardFocus"
                                      BeginningEdit="FinalizedTranscriptGrid_BeginningEdit"
                                      CellEditEnding="FinalizedTranscriptGrid_CellEditEnding"
                                      PreviewKeyDown="FinalizedTranscriptGrid_PreviewKeyDown"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      RowBackground="#00FFFFFF"
                                      AlternatingRowBackground="#05EAF4F8"
                                      FontFamily="Segoe UI Variable Text"
                                      FontSize="14"
                                      Foreground="{StaticResource PrimaryTextBrush}"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                                <DataGrid.Resources>
                                    <Style TargetType="{x:Type DataGridColumnHeader}">
                                        <Setter Property="FontFamily"
                                                Value="Segoe UI Variable Text"/>
                                        <Setter Property="FontSize"
                                                Value="12"/>
                                        <Setter Property="FontWeight"
                                                Value="SemiBold"/>
                                        <Setter Property="Foreground"
                                                Value="{StaticResource SecondaryTextBrush}"/>
                                        <Setter Property="Background"
                                                Value="#FFF6FAFC"/>
                                        <Setter Property="BorderBrush"
                                                Value="#FFD2E2E7"/>
                                        <Setter Property="BorderThickness"
                                                Value="0,0,0,1"/>
                                        <Setter Property="Padding"
                                                Value="8,6"/>
                                    </Style>
                                    <Style TargetType="{x:Type DataGridCell}">
                                        <Setter Property="Padding"
                                                Value="8,6"/>
                                        <Setter Property="VerticalContentAlignment"
                                                Value="Top"/>
                                        <Setter Property="BorderThickness"
                                                Value="1"/>
                                        <Setter Property="BorderBrush"
                                                Value="Transparent"/>
                                        <Setter Property="Background"
                                                Value="Transparent"/>
                                        <Setter Property="Foreground"
                                                Value="{StaticResource PrimaryTextBrush}"/>
                                        <Setter Property="FocusVisualStyle"
                                                Value="{x:Null}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected"
                                                     Value="True">
                                                <Setter Property="Background"
                                                        Value="#14D7E7EF"/>
                                                <Setter Property="Foreground"
                                                        Value="{StaticResource PrimaryTextBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsEditing"
                                                     Value="True">
                                                <Setter Property="BorderBrush"
                                                        Value="#6495ED"/>
                                                <Setter Property="BorderThickness"
                                                        Value="1"/>
                                            </Trigger>
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsKeyboardFocusWithin"
                                                               Value="True"/>
                                                    <Condition Property="IsEditing"
                                                               Value="False"/>
                                                </MultiTrigger.Conditions>
                                                <Setter Property="BorderBrush"
                                                        Value="#C0C0C0"/>
                                                <Setter Property="BorderThickness"
                                                        Value="1"/>
                                            </MultiTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsPlaybackTimelineMatch}"
                                                               Value="True"/>
                                                    <Condition Binding="{Binding Column.DisplayIndex, RelativeSource={RelativeSource Self}}"
                                                               Value="0"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="FontWeight"
                                                        Value="Bold"/>
                                                <Setter Property="Foreground"
                                                        Value="{StaticResource PlaybackSyncTextBrush}"/>
                                            </MultiDataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Column.DisplayIndex, RelativeSource={RelativeSource Self}}"
                                                               Value="0"/>
                                                    <Condition Binding="{Binding IsEditing, RelativeSource={RelativeSource Self}}"
                                                               Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="FontWeight"
                                                        Value="Normal"/>
                                                <Setter Property="Foreground"
                                                        Value="{StaticResource PrimaryTextBrush}"/>
                                            </MultiDataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsManuallyReviewed}"
                                                               Value="True"/>
                                                    <Condition Binding="{Binding Column.Header, RelativeSource={RelativeSource Self}}"
                                                               Value="Text"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Background"
                                                        Value="#E0FFFF"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style TargetType="{x:Type DataGridRow}">
                                        <Setter Property="Foreground"
                                                Value="{StaticResource PrimaryTextBrush}"/>
                                        <Setter Property="VerticalAlignment"
                                                Value="Top"/>
                                        <Setter Property="VerticalContentAlignment"
                                                Value="Top"/>
                                        <Setter Property="BorderThickness"
                                                Value="0"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected"
                                                     Value="True">
                                                <Setter Property="Foreground"
                                                        Value="{StaticResource PrimaryTextBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style TargetType="{x:Type TextBox}">
                                        <Setter Property="Foreground"
                                                Value="{StaticResource PrimaryTextBrush}"/>
                                        <Setter Property="BorderThickness"
                                                Value="0"/>
                                        <Setter Property="Background"
                                                Value="Transparent"/>
                                        <Setter Property="FocusVisualStyle"
                                                Value="{x:Null}"/>
                                        <Setter Property="VerticalContentAlignment"
                                                Value="Top"/>
                                    </Style>
                                    <Style x:Key="TranscriptCellTextStyle"
                                           TargetType="{x:Type TextBlock}">
                                        <Setter Property="TextWrapping"
                                                Value="Wrap"/>
                                        <Setter Property="TextAlignment"
                                                Value="Left"/>
                                        <Setter Property="VerticalAlignment"
                                                Value="Top"/>
                                    </Style>
                                    <Style x:Key="TranscriptEditingTextStyle"
                                           TargetType="{x:Type TextBox}"
                                           BasedOn="{StaticResource {x:Type TextBox}}">
                                        <Setter Property="TextWrapping"
                                                Value="Wrap"/>
                                        <Setter Property="TextAlignment"
                                                Value="Left"/>
                                        <Setter Property="VerticalContentAlignment"
                                                Value="Top"/>
                                        <Setter Property="VerticalAlignment"
                                                Value="Top"/>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn x:Name="TimelineTranscriptColumn"
                                                            Header="Timeline"
                                                            CanUserSort="False"
                                                            Width="84">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Timeline}"
                                                           TextAlignment="Left"
                                                           HorizontalAlignment="Left"
                                                           Margin="10,0,0,0"
                                                           FontFamily="Consolas"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Timeline, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                                         MaxLength="5"
                                                         TextAlignment="Left"
                                                         FontWeight="Normal"
                                                         Padding="10,0,0,0"
                                                         FontFamily="Consolas"
                                                         Loaded="TimelineEditingTextBox_Loaded"
                                                         GotKeyboardFocus="TimelineEditingTextBox_GotKeyboardFocus"
                                                         PreviewTextInput="TimelineEditingTextBox_PreviewTextInput"
                                                         PreviewKeyDown="TimelineEditingTextBox_PreviewKeyDown"
                                                         DataObject.Pasting="TimelineEditingTextBox_Pasting"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn x:Name="SpeakerTranscriptColumn"
                                                        Header="Speaker"
                                                        Binding="{Binding SpeakerLabel}"
                                                        Width="150"
                                                        IsReadOnly="True"/>
                                    <DataGridTemplateColumn x:Name="TranscriptTextColumn"
                                                            Header="Text"
                                                            CanUserSort="False"
                                                            Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <TextBlock Text="{Binding Text}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="{x:Type TextBlock}"
                                                                   BasedOn="{StaticResource TranscriptCellTextStyle}">
                                                                <Setter Property="Visibility"
                                                                        Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPlaybackEditTranscribing}"
                                                                                 Value="True">
                                                                        <Setter Property="Visibility"
                                                                                Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <Border HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            Margin="20,0"
                                                            Padding="0">
                                                        <Border.Style>
                                                            <Style TargetType="{x:Type Border}">
                                                                <Setter Property="Visibility"
                                                                        Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPlaybackEditTranscribing}"
                                                                                 Value="True">
                                                                        <Setter Property="Visibility"
                                                                                Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <ProgressBar Style="{StaticResource TranscriptCellProgressBarStyle}"
                                                                     Value="{Binding PlaybackEditProgressPercent}"
                                                                     IsIndeterminate="{Binding IsPlaybackEditProgressIndeterminate}"/>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource TranscriptEditingTextStyle}"
                                                         IsReadOnly="{Binding IsPlaybackEditTranscribing}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn x:Name="TranscriptRowActionsColumn"
                                                            Header=""
                                                            CanUserSort="False"
                                                            IsReadOnly="True"
                                                            Width="36">
                                        <DataGridTemplateColumn.CellStyle>
                                            <Style TargetType="{x:Type DataGridCell}"
                                                   BasedOn="{StaticResource {x:Type DataGridCell}}">
                                                <Setter Property="Padding"
                                                        Value="0"/>
                                            </Style>
                                        </DataGridTemplateColumn.CellStyle>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Top"
                                                            Margin="0">
                                                    <StackPanel.Style>
                                                        <Style TargetType="{x:Type StackPanel}">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding AreRowActionsVisible}"
                                                                             Value="True">
                                                                    <Setter Property="Visibility"
                                                                            Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <Button Style="{StaticResource TranscriptOverlayActionButtonStyle}"
                                                            Click="InsertTranscriptRowBelow_Click"
                                                            ToolTip="Insert new row below">
                                                        <Viewbox Width="14"
                                                                 Height="14">
                                                            <Grid Width="16"
                                                                  Height="16">
                                                                <Path Fill="#FF234F61"
                                                                      Data="M2,3 H14 V4.5 H2 Z M2,7 H14 V8.5 H2 Z M2,11 H9.5 V12.5 H2 Z"/>
                                                                <Path Fill="#FF234F61"
                                                                      Data="M11.2,9.2 H12.8 V11.2 H14.8 V12.8 H12.8 V14.8 H11.2 V12.8 H9.2 V11.2 H11.2 Z"/>
                                                            </Grid>
                                                        </Viewbox>
                                                    </Button>
                                                    <Button Style="{StaticResource TranscriptOverlayActionButtonStyle}"
                                                            Click="DeleteTranscriptRow_Click"
                                                            Margin="0"
                                                            ToolTip="Delete this row">
                                                        <Viewbox Width="14"
                                                                 Height="14">
                                                            <Path Fill="#FF234F61"
                                                                  Data="M6,1.8 H10 L10.7,2.9 H14 V4.4 H2 V2.9 H5.3 Z M4.1,5.1 H11.9 L11.2,14.2 H4.8 Z M6,6.6 V12.4 H7.4 V6.6 Z M8.6,6.6 V12.4 H10 V6.6 Z"/>
                                                        </Viewbox>
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                                <Border Background="#FFF8FBFC"
                                        BorderBrush="#FFD2E2E7"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="24"
                                        Margin="0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility"
                                                    Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasCurrentTranscriptLines}"
                                                             Value="True">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                MaxWidth="420">
                                        <TextBlock Text="{Binding TranscriptEmptyStateTitle}"
                                                   FontFamily="Segoe UI Variable Text"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   TextAlignment="Center"/>
                                        <TextBlock Text="{Binding TranscriptEmptyStateMessage}"
                                                   Margin="0,8,0,0"
                                                   FontFamily="Segoe UI Variable Text"
                                                   FontSize="12"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </DockPanel>

        <Border x:Name="SegmentBatchOverlay"
                Panel.ZIndex="100"
                Background="Transparent"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <Grid>
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="320"
                        Background="#FFFDFEFF"
                        BorderBrush="#FFD2E2E7"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="16,14">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="28"
                                          ShadowDepth="0"
                                          Opacity="0.18"
                                          Color="#FF7F97A6"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="{Binding TranscriptProcessingTitle, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontFamily="Bahnschrift"
                                   FontSize="18"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   HorizontalAlignment="Center"/>
                        <ProgressBar Width="160"
                                     Height="8"
                                     Margin="0,14,0,0"
                                     IsIndeterminate="True"
                                     Style="{StaticResource TranscriptCellProgressBarStyle}"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Margin="0,12,0,0"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"/>
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                      Content="Mute"
                                      IsChecked="{Binding IsPlaybackMuted, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      VerticalAlignment="Center">
                                <CheckBox.Style>
                                    <Style TargetType="CheckBox"
                                           BasedOn="{StaticResource ToolbarCheckBoxStyle}">
                                        <Setter Property="Visibility"
                                                Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTranscriptProcessingMuteAvailable, RelativeSource={RelativeSource AncestorType=Window}}"
                                                         Value="False">
                                                <Setter Property="Visibility"
                                                        Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </CheckBox.Style>
                            </CheckBox>
                            <Button x:Name="SegmentBatchCancelButton"
                                    Grid.Column="1"
                                    Content="Cancel"
                                    Width="110"
                                    HorizontalAlignment="Right"
                                    Style="{StaticResource PlaybackActionButtonStyle}"
                                    IsEnabled="True"
                                    Click="CancelProcessing_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="CopyToastHost"
                Panel.ZIndex="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,48"
                Opacity="0"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <Border.RenderTransform>
                <TranslateTransform x:Name="CopyToastTransform"
                                    Y="-14"/>
            </Border.RenderTransform>
            <Border Background="#FFFDFEFF"
                    BorderBrush="#FFD2E2E7"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14,12"
                    MaxWidth="320">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="26"
                                      ShadowDepth="0"
                                      Opacity="0.2"
                                      Color="#FF7F97A6"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="CopyToastIconHost"
                            Width="34"
                            Height="34"
                            CornerRadius="17"
                            Background="{StaticResource AccentSurfaceBrush}"
                            BorderBrush="{StaticResource AccentBorderBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Top">
                        <Viewbox Width="15"
                                 Height="15"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center">
                            <Path x:Name="CopyToastIconPath"
                                  Stroke="{StaticResource AccentBrush}"
                                  StrokeThickness="2.6"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Data="M2.5,8.5 L6.2,12.2 L13.5,4.5"/>
                        </Viewbox>
                    </Border>
                    <StackPanel Grid.Column="1"
                                Margin="12,0,0,0">
                        <TextBlock x:Name="CopyToastTitleText"
                                   Text="Copied to clipboard"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock x:Name="CopyToastMessageText"
                                   Text="Finalized transcript is ready to paste."
                                   Margin="0,3,0,0"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="11"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>


