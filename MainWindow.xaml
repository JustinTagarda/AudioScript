<Window x:Class="VoxTranscriber.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:abstractions="clr-namespace:VoxTranscriber.Abstractions"
        mc:Ignorable="d"
        Title="VoxTranscriber"
        Icon="pack://application:,,,/Assets/VoxTranscriber.ico"
        Height="670"
        Width="1080"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"

        AllowDrop="True"
        PreviewDragEnter="Window_PreviewDragEnter"
        PreviewDragOver="Window_PreviewDragOver"
        PreviewDragLeave="Window_PreviewDragLeave"
        PreviewDrop="Window_PreviewDrop">
    


    <Grid x:Name="MainRootGrid"
>
        <DockPanel x:Name="MainContentHost"
                   LastChildFill="True">
            <StatusBar DockPanel.Dock="Bottom"
                       Margin="0"
                       MinHeight="28"
                       Padding="6,2"


>
                <StatusBarItem DockPanel.Dock="Right"
                               Padding="0"
>
                    <TextBlock Text="{Binding ApplicationVersionStatusText}"
                               ToolTip="{Binding ApplicationVersionStatusText}"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"
/>
                </StatusBarItem>

                <StatusBarItem DockPanel.Dock="Right"
                               Padding="0"
>
                    <ToggleButton x:Name="LogsToggleButton"
                                  Content="Logs"
                                  Margin="0,0,10,0"
                                  IsEnabled="{Binding HasProcessLogs}"/>
                </StatusBarItem>

                <StatusBarItem DockPanel.Dock="Left"
                               Padding="0"
>
                    <TextBlock Text="{Binding StatusMessage}"
                               ToolTip="{Binding StatusMessage}"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"
/>
                </StatusBarItem>
            </StatusBar>

            <Border DockPanel.Dock="Bottom"
                    Margin="8,0,8,6"
                    Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,14,0">
                        <TextBlock Text="Player"
                                   FontFamily="Bahnschrift"
                                   FontSize="16"
/>
                        <TextBlock Text="{Binding LoadedAudioFileName}"
                                   Margin="0,2,0,0"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="11"

                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="220"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0"
                                Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Content="Play"
                                MinWidth="56"
                                Margin="0,0,4,0"
                                Command="{Binding PlayAudioCommand}"/>
                        <Button Content="Pause"
                                MinWidth="56"
                                Margin="0,0,4,0"
                                Command="{Binding PauseAudioCommand}"/>
                        <Button Content="Stop"
                                MinWidth="56"
                                Margin="0,0,4,0"
                                Command="{Binding StopAudioCommand}"/>
                        <Button ToolTip="Rewind 5 seconds"
                                AutomationProperties.Name="Rewind 5 seconds"
                                Margin="0,0,6,0"
                                Command="{Binding RewindAudioCommand}">
                            <Viewbox Width="11.2"
                                     Height="11.2"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Stretch="Uniform"
                                      Data="M14,4 L8,10 L14,16 Z M8.5,4 L2.5,10 L8.5,16 Z"/>
                            </Viewbox>
                        </Button>
                        <Button ToolTip="Forward 5 seconds"
                                AutomationProperties.Name="Forward 5 seconds"
                                Margin="0"
                                Command="{Binding ForwardAudioCommand}">
                            <Viewbox Width="11.2"
                                     Height="11.2"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Stretch="Uniform"
                                      Data="M2,4 L8,10 L2,16 Z M7.5,4 L13.5,10 L7.5,16 Z"/>
                            </Viewbox>
                        </Button>
                    </StackPanel>

                    <Grid Grid.Row="1"
                          Grid.ColumnSpan="2"
                          Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding AudioElapsedText}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   FontFamily="Consolas"
                                   FontSize="12"
/>
                        <Slider Grid.Column="1"
                                Minimum="0"
                                Maximum="{Binding AudioSeekMaximumSeconds}"
                                Value="{Binding AudioSeekPositionSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                VerticalAlignment="Center"
                                IsEnabled="{Binding IsAudioFileLoaded}"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding AudioRemainingText}"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"
                                   FontFamily="Consolas"
                                   FontSize="12"
/>
                    </Grid>
                </Grid>
            </Border>

            <Border DockPanel.Dock="Bottom"
                    Margin="8,0,8,6"



>
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0"
                               Margin="8,8,8,6"
                               LastChildFill="False">
                        <TextBlock Text="Process Logs"
                                   DockPanel.Dock="Left"
                                   FontFamily="Bahnschrift"
                                   FontSize="16"
/>
                        <TextBlock Text="Latest activity"
                                   DockPanel.Dock="Right"
                                   VerticalAlignment="Center"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="11"
/>
                    </DockPanel>

                    <ListView x:Name="ProcessLogsListView"
                              Grid.Row="1"
                              Margin="8,0,8,8"
                              Height="132"
                              ItemsSource="{Binding ProcessLogs}"


                              Background="Transparent"
                              FontFamily="Segoe UI Variable Text"
                              FontSize="12"

                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="10,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="88"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Time}"
                                               FontFamily="Consolas"
/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Message}"
                                               Margin="12,0,0,0"

                                               TextWrapping="Wrap"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Grid Margin="6,2,6,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="332"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="10">
                        <StackPanel>
                            <TextBlock Text="Current Task"
                                       FontFamily="Bahnschrift"
                                       FontSize="18"
/>

                            <TextBlock Text="Choose file and mode."
                                       Margin="0,4,0,0"
                                       FontFamily="Segoe UI Variable Text"
                                       FontSize="11"

                                       TextWrapping="Wrap"/>

                            <TextBlock Text="File"
                                       Margin="0,12,0,5"/>
                            <Border x:Name="AudioDropZoneBorder"




                                    Padding="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Drop audio here"
                                                   FontFamily="Segoe UI Variable Text"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
>
                                            
                                        </TextBlock>
                                        <TextBlock Text="or choose a file"
                                                   Margin="0,2,0,0"
                                                   FontFamily="Segoe UI Variable Text"
                                                   FontSize="10.5"
>
                                            
                                        </TextBlock>
                                        <TextBlock Text="{Binding LoadedAudioFileName}"
                                                   FontFamily="Segoe UI Variable Text"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"

                                                   TextTrimming="CharacterEllipsis">
                                            
                                        </TextBlock>
                                        <TextBlock Text="Drop another file to replace it."
                                                   Margin="0,2,0,0"
                                                   FontFamily="Segoe UI Variable Text"
                                                   FontSize="10.5"
>
                                            
                                        </TextBlock>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Content="Choose"
                                            Height="28"
                                            MinHeight="28"
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            Command="{Binding OpenAudioFileCommand}"/>
                                </Grid>
                            </Border>
                            <TextBlock Text="{Binding CurrentSessionAudioIssue}"
                                       Margin="0,6,0,0"
                                       FontFamily="Segoe UI Variable Text"
                                       FontSize="11"

                                       TextWrapping="Wrap">
                                
                            </TextBlock>

                            <TextBlock Text="Mode"
                                       Margin="0,12,0,5"/>
                            <ItemsControl ItemsSource="{Binding TranscriptModes}"
                                          IsEnabled="{Binding IsTranscriptModeSelectionEnabled}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <RadioButton GroupName="TranscriptModeGroup"
                                                     IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontFamily="Segoe UI Variable Text"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
/>
                                                <TextBlock Text="{Binding Description}"
                                                           Margin="0,3,0,0"
                                                           FontFamily="Segoe UI Variable Text"
                                                           FontSize="10.5"

                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding DataContext.AutoTranscribeAssistStatusText, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           Margin="0,4,0,0"
                                                           FontFamily="Segoe UI Variable Text"
                                                           FontSize="10.5"

                                                           TextWrapping="Wrap">
                                                    
                                                </TextBlock>
                                                <TextBlock Text="{Binding DataContext.SpeakerDiarizationStatusText, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           Margin="0,4,0,0"
                                                           FontFamily="Segoe UI Variable Text"
                                                           FontSize="10.5"

                                                           TextWrapping="Wrap">
                                                    
                                                </TextBlock>
                                            </StackPanel>
                                        </RadioButton>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border



                                    Padding="8"
                                    Margin="0,2,0,0">
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  VerticalAlignment="Top"
                                                  Margin="0,2,8,0"
                                                  IsEnabled="{Binding IsEngineSelectionEnabled}"
                                                  IsChecked="{Binding AutoTranscribeWithAi, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Checked="AutoTranscribeWithAiCheckBox_Checked"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="AI Assist"
                                                       FontFamily="Segoe UI Variable Text"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
/>
                                            <TextBlock Text="Fill segment text automatically."
                                                       Margin="0,2,0,0"
                                                       FontFamily="Segoe UI Variable Text"
                                                       FontSize="10.5"

                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding AutoTranscribeAssistStatusText}"
                                                       Margin="0,4,0,0"
                                                       FontFamily="Segoe UI Variable Text"
                                                       FontSize="10.5"

                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                    <Button Grid.Column="1"
                                            Content="API Key"
                                            Height="28"
                                            MinHeight="28"
                                            Margin="6,0,0,0"
                                            ToolTip="OpenAI API Key"
                                            AutomationProperties.Name="OpenAI API Key"
                                            IsEnabled="{Binding IsOpenAiSettingsEnabled}"
                                            Click="OpenOpenAiSettings_Click"/>
                                </Grid>
                            </Border>

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="GenerateTranscriptButton"
                                        Grid.Column="0"
                                        Content="{Binding GenerateTranscriptButtonText}"
                                        Height="28"
                                        MinHeight="28"
                                        IsEnabled="{Binding IsTranscriptGenerationEnabled}"
                                        Click="GenerateTranscript_Click">
                                    
                                </Button>
                                <Button Grid.Column="0"
                                        Content="Cancel Transcription"
                                        Height="28"
                                        MinHeight="28"
                                        Click="CancelProcessing_Click">
                                    
                                </Button>
                                <Button Grid.Column="1"
                                        Content="Clear"
                                        Height="28"
                                        MinHeight="28"
                                        Margin="6,0,0,0"
                                        Command="{Binding ClearCommand}">
                                    
                                </Button>
                            </Grid>

                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Padding="10"
                            Margin="0,10,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Sessions"
                                           FontFamily="Bahnschrift"
                                           FontSize="18"
/>
                                <TextBlock Text="Recent work."
                                           Margin="0,4,0,0"
                                           FontFamily="Segoe UI Variable Text"
                                           FontSize="11"

                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <Grid Grid.Row="1"
                                  Margin="0,10,0,0">
                                <ListBox ItemsSource="{Binding RecentSessions}"
                                         SelectedItem="{Binding SelectedRecentSession}"
                                         HorizontalContentAlignment="Stretch"
                                         MouseDoubleClick="RecentSessionsList_MouseDoubleClick"

                                         Background="Transparent"
                                         FontFamily="Segoe UI Variable Text"

                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel ToolTip="{Binding DisplayName}">
                                                <TextBlock Text="{Binding OriginalFileName}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"

                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding UpdatedUtc, StringFormat=Updated {0:MMM dd, yyyy h:mm tt}}"
                                                           Margin="0,3,0,0"
                                                           FontSize="10.5"

                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Border



                                        Padding="10">
                                    
                                    <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="No saved sessions yet"
                                                   HorizontalAlignment="Center"
                                                   FontFamily="Segoe UI Variable Text"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
/>
                                        <TextBlock Text="Import an audio file to create your first transcript session."
                                                   Margin="0,4,0,0"
                                                   HorizontalAlignment="Center"
                                                   FontFamily="Segoe UI Variable Text"
                                                   FontSize="10.5"

                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <StackPanel Grid.Row="2"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,10,0,0">
                                <Button Content="Open"
                                        MinWidth="60"
                                        Margin="0,0,4,0"
                                        Command="{Binding OpenSelectedSessionCommand}"/>
                                <Button Content="Delete"
                                        MinWidth="60"
                                        Height="28"
                                        MinHeight="28"
                                        Command="{Binding DeleteSelectedSessionCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <GridSplitter Grid.Column="1"
                              Width="6"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Stretch"
                              ResizeDirection="Columns"
                              ResizeBehavior="PreviousAndNext"
                              Background="Transparent"
                              ShowsPreview="True"/>

                <Border Grid.Column="2"
                        Padding="6"
                        Margin="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Transcript"
                                           FontFamily="Bahnschrift"
                                           FontSize="18"
/>
                                <TextBlock Text="{Binding TranscriptPaneSubtitle}"
                                           Margin="0,3,0,0"
                                           FontFamily="Segoe UI Variable Text"
                                           FontSize="11"

                                           TextTrimming="CharacterEllipsis">
                                    
                                </TextBlock>
                            </StackPanel>
                            <Grid Grid.Column="1"
                                  VerticalAlignment="Center">
                                
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Content="Copy with time"
                                           Grid.Column="0"
                                           IsChecked="{Binding CopyFinalizedWithTimeline, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    
                                </CheckBox>
                                <TextBlock Grid.Column="1"
                                           Text="Speaker copy includes labels and time."
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe UI Variable Text"
                                           FontSize="10.5"
>
                                    
                                </TextBlock>
                                <Button Content="Copy"
                                        Grid.Column="2"
                                        MinWidth="52"
                                        VerticalAlignment="Center"
                                        ToolTip="Copy to Clipboard"
                                        AutomationProperties.Name="Copy to Clipboard"
                                        IsEnabled="{Binding CanCopyTranscript}"
                                        Click="CopyFinalizedToClipboard_Click"/>
                            </Grid>
                        </Grid>

                        <Border Grid.Row="1"
                                Margin="0,8,0,0"




                                ClipToBounds="True">
                            <Grid>
                            <DataGrid x:Name="FinalizedTranscriptGrid"
                                      ItemsSource="{Binding CurrentTranscriptLines}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserResizeRows="False"
                                      HeadersVisibility="Column"
                                      RowHeaderWidth="0"
                                      GridLinesVisibility="None"
                                      SelectionMode="Single"
                                      SelectionUnit="Cell"
                                      CurrentCellChanged="FinalizedTranscriptGrid_CurrentCellChanged"
                                      GotKeyboardFocus="FinalizedTranscriptGrid_GotKeyboardFocus"
                                      LostKeyboardFocus="FinalizedTranscriptGrid_LostKeyboardFocus"
                                      BeginningEdit="FinalizedTranscriptGrid_BeginningEdit"
                                      CellEditEnding="FinalizedTranscriptGrid_CellEditEnding"
                                      PreviewKeyDown="FinalizedTranscriptGrid_PreviewKeyDown"

                                      Background="Transparent"


                                       FontFamily="Segoe UI Variable Text"
                                       FontSize="13"

                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                                
                                <DataGrid.Columns>
                                        <DataGridTemplateColumn x:Name="TimelineTranscriptColumn"
                                                            Header="Timeline"
                                                            CanUserSort="False"
                                                            Width="78">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Timeline}"
                                                           TextAlignment="Left"
                                                           HorizontalAlignment="Left"
                                                           Margin="10,0,0,0"
                                                           FontFamily="Consolas"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Timeline, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                                         MaxLength="5"
                                                         TextAlignment="Left"
                                                         FontWeight="Normal"
                                                         Padding="10,0,0,0"
                                                         FontFamily="Consolas"
                                                         Loaded="TimelineEditingTextBox_Loaded"
                                                         GotKeyboardFocus="TimelineEditingTextBox_GotKeyboardFocus"
                                                         PreviewTextInput="TimelineEditingTextBox_PreviewTextInput"
                                                         PreviewKeyDown="TimelineEditingTextBox_PreviewKeyDown"
                                                         DataObject.Pasting="TimelineEditingTextBox_Pasting"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn x:Name="SpeakerTranscriptColumn"
                                                        Header="Speaker"
                                                        Binding="{Binding SpeakerLabel}"
                                                        Width="136"
                                                        IsReadOnly="True"/>
                                    <DataGridTemplateColumn x:Name="TranscriptTextColumn"
                                                            Header="Text"
                                                            CanUserSort="False"
                                                            Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <TextBlock Text="{Binding Text}">
                                                        
                                                    </TextBlock>
                                                    <Border HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            Margin="20,0"
                                                            Padding="0">
                                                        
                                                        <ProgressBar Value="{Binding PlaybackEditProgressPercent}"
                                                                     IsIndeterminate="{Binding IsPlaybackEditProgressIndeterminate}"/>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         IsReadOnly="{Binding IsPlaybackEditTranscribing}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn x:Name="TranscriptRowActionsColumn"
                                                            Header=""
                                                            CanUserSort="False"
                                                            IsReadOnly="True"
                                                            Width="36">
                                        
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Top"
                                                            Margin="0">
                                                    
                                                    <Button Click="InsertTranscriptRowBelow_Click"
                                                            ToolTip="Insert new row below">
                                                        <Viewbox Width="14"
                                                                 Height="14">
                                                            <Grid Width="16"
                                                                  Height="16">
                                                                <Path
                                                                      Data="M2,3 H14 V4.5 H2 Z M2,7 H14 V8.5 H2 Z M2,11 H9.5 V12.5 H2 Z"/>
                                                                <Path
                                                                      Data="M11.2,9.2 H12.8 V11.2 H14.8 V12.8 H12.8 V14.8 H11.2 V12.8 H9.2 V11.2 H11.2 Z"/>
                                                            </Grid>
                                                        </Viewbox>
                                                    </Button>
                                                    <Button Click="DeleteTranscriptRow_Click"
                                                            Margin="0"
                                                            ToolTip="Delete this row">
                                                        <Viewbox Width="14"
                                                                 Height="14">
                                                            <Path
                                                                  Data="M6,1.8 H10 L10.7,2.9 H14 V4.4 H2 V2.9 H5.3 Z M4.1,5.1 H11.9 L11.2,14.2 H4.8 Z M6,6.6 V12.4 H7.4 V6.6 Z M8.6,6.6 V12.4 H10 V6.6 Z"/>
                                                        </Viewbox>
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                                <Border x:Name="TranscriptEmptyStateBorder"




                                        Padding="12"
                                        Margin="0,56,0,0"
                                        VerticalAlignment="Top"
                                        MaxWidth="360">
                                    
                                    <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                MaxWidth="320">
                                        <TextBlock Text="{Binding TranscriptEmptyStateTitle}"
                                                   FontFamily="Segoe UI Variable Text"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"

                                                   TextAlignment="Center"/>
                                        <TextBlock Text="{Binding TranscriptEmptyStateMessage}"
                                                   Margin="0,6,0,0"
                                                   FontFamily="Segoe UI Variable Text"
                                                   FontSize="11"

                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"/>
                                        <Button Content="Choose File"
                                                Margin="0,12,0,0"
                                                HorizontalAlignment="Center"
                                                Command="{Binding OpenAudioFileCommand}"/>
                                        <TextBlock Text="You can also drag audio into this window."
                                                   Margin="0,8,0,0"
                                                   FontFamily="Segoe UI Variable Text"
                                                   FontSize="10.5"

                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </DockPanel>

        <Border x:Name="SegmentBatchOverlay"
                Panel.ZIndex="100"
                Background="Transparent"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <Grid>
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="320"




                        Padding="16,14">
                    
                    <StackPanel>
                        <TextBlock Text="{Binding TranscriptProcessingTitle, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontFamily="Bahnschrift"
                                   FontSize="18"

                                   HorizontalAlignment="Center"/>
                        <ProgressBar Width="160"
                                     Height="8"
                                     Margin="0,14,0,0"
                                     IsIndeterminate="True"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Margin="0,12,0,0"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="12"

                                   TextAlignment="Center"
                                   TextWrapping="Wrap"/>
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                      Content="Mute"
                                      IsChecked="{Binding IsPlaybackMuted, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      VerticalAlignment="Center">
                                
                            </CheckBox>
                            <Button x:Name="SegmentBatchCancelButton"
                                    Grid.Column="1"
                                    Content="Cancel"
                                    Width="110"
                                    HorizontalAlignment="Right"
                                    IsEnabled="True"
                                    Click="CancelProcessing_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="CopyToastHost"
                Panel.ZIndex="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,48"
                Opacity="0"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <Border.RenderTransform>
                <TranslateTransform x:Name="CopyToastTransform"
                                    Y="-14"/>
            </Border.RenderTransform>
            <Border



                    Padding="14,12"
                    MaxWidth="320">
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="CopyToastIconHost"
                            Width="34"
                            Height="34"




                            VerticalAlignment="Top">
                        <Viewbox Width="15"
                                 Height="15"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center">
                            <Path x:Name="CopyToastIconPath"

                                  StrokeThickness="2.6"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Data="M2.5,8.5 L6.2,12.2 L13.5,4.5"/>
                        </Viewbox>
                    </Border>
                    <StackPanel Grid.Column="1"
                                Margin="12,0,0,0">
                        <TextBlock x:Name="CopyToastTitleText"
                                   Text="Copied to clipboard"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="13"
                                   FontWeight="SemiBold"
/>
                        <TextBlock x:Name="CopyToastMessageText"
                                   Text="Finalized transcript is ready to paste."
                                   Margin="0,3,0,0"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="11"

                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>



