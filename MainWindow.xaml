                x:Name="CopyToastCard"
                HorizontalAlignment="Center"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14,12"
                MaxWidth="320">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="CopyToastIconHost"
                            Width="34"
                            Height="34"
                            VerticalAlignment="Top">
                        <Viewbox Width="15"
                                 Height="15"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center">
                            <Path x:Name="CopyToastIconPath"
                                  StrokeThickness="2.6"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Data="M2.5,8.5 L6.2,12.2 L13.5,4.5"/>
                        </Viewbox>
                    </Border>
                    <StackPanel Grid.Column="1"
                                Margin="12,0,0,0">
                        <TextBlock x:Name="CopyToastTitleText"
                                   Text="Copied to clipboard"
                                   FontSize="13"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="CopyToastMessageText"
                                   Text="Finalized transcript is ready to paste."
                                   Margin="0,3,0,0"
                                   FontSize="11"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>





