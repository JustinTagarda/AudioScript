<Window x:Class="AudioScript.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AudioScript"
        xmlns:abstractions="clr-namespace:AudioScript.Abstractions"
        mc:Ignorable="d"
        Title="AudioScript"
        Icon="pack://application:,,,/assets/AudioScript.ico"
        Height="600"
        Width="900"
        MinHeight="400"
        MinWidth="500"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        PreviewDragEnter="Window_PreviewDragEnter"
        PreviewDragOver="Window_PreviewDragOver"
        PreviewDragLeave="Window_PreviewDragLeave"
        PreviewDrop="Window_PreviewDrop">
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static local:MainWindow.TranscribeRowCommand}"
                        CanExecute="TranscriptContextCommand_CanExecute"
                        Executed="TranscribeRowCommand_Executed"/>
        <CommandBinding Command="{x:Static local:MainWindow.CombineToPreviousRowCommand}"
                        CanExecute="TranscriptContextCommand_CanExecute"
                        Executed="CombineToPreviousRowCommand_Executed"/>
        <CommandBinding Command="{x:Static local:MainWindow.RenameSpeakerCommand}"
                        CanExecute="TranscriptContextCommand_CanExecute"
                        Executed="RenameSpeakerCommand_Executed"/>
        <CommandBinding Command="{x:Static local:MainWindow.MergeAdjacentRowsForSelectedSpeakerCommand}"
                        CanExecute="TranscriptContextCommand_CanExecute"
                        Executed="MergeAdjacentRowsForSelectedSpeakerCommand_Executed"/>
        <CommandBinding Command="{x:Static local:MainWindow.MergeAllAdjacentRowsBySpeakerCommand}"
                        CanExecute="TranscriptContextCommand_CanExecute"
                        Executed="MergeAllAdjacentRowsBySpeakerCommand_Executed"/>
        <CommandBinding Command="{x:Static local:MainWindow.CopyRowTextCommand}"
                        CanExecute="TranscriptContextCommand_CanExecute"
                        Executed="CopyRowTextCommand_Executed"/>
        <CommandBinding Command="{x:Static local:MainWindow.SeparateRowCommand}"
                        CanExecute="TranscriptContextCommand_CanExecute"
                        Executed="SeparateRowCommand_Executed"/>
    </Window.CommandBindings>
    <Window.Resources>
        <Style x:Key="SectionHeaderTextBlockStyle"
               TargetType="{x:Type TextBlock}"
               BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize"
                    Value="16"/>
            <Setter Property="Margin"
                    Value="0,0,0,4"/>
        </Style>
        <Style x:Key="FluentComboBoxItemStyle"
               TargetType="{x:Type ComboBoxItem}"
               BasedOn="{StaticResource {x:Type ComboBoxItem}}"/>
        <Style x:Key="FluentListBoxItemStyle"
               TargetType="{x:Type ListBoxItem}"
               BasedOn="{StaticResource {x:Type ListBoxItem}}"/>
        <Style x:Key="SessionsRowOpenButtonStyle"
               TargetType="{x:Type Button}">
            <Setter Property="Width"
                    Value="20"/>
            <Setter Property="Height"
                    Value="24"/>
            <Setter Property="Margin"
                    Value="6,0,0,0"/>
            <Setter Property="Padding"
                    Value="0"/>
            <Setter Property="Background"
                    Value="{x:Null}"/>
            <Setter Property="BorderBrush"
                    Value="{x:Null}"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Foreground"
                    Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="HorizontalAlignment"
                    Value="Center"/>
            <Setter Property="VerticalAlignment"
                    Value="Center"/>
            <Setter Property="HorizontalContentAlignment"
                    Value="Center"/>
            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="ToolTipService.ShowOnDisabled"
                    Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <TextBlock x:Name="IconText"
                                       Style="{StaticResource ToolbarButtonIconTextStyle}"
                                       Foreground="{TemplateBinding Foreground}"
                                       Text="{TemplateBinding Tag}"
                                       Margin="0"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Opacity="0.3"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}"
                                         Value="True">
                                <Setter TargetName="IconText"
                                        Property="Opacity"
                                        Value="1"/>
                            </DataTrigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter Property="Opacity"
                                        Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SessionsCardBorderStyle"
               TargetType="{x:Type Border}">
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="BorderBrush"
                    Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
            <Setter Property="Background"
                    Value="{x:Null}"/>
            <Setter Property="CornerRadius"
                    Value="6"/>
            <Setter Property="Padding"
                    Value="12,10,4,10"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLoaded}"
                             Value="True">
                    <Setter Property="BorderBrush"
                            Value="{DynamicResource ControlStrokeColorSecondaryBrush}"/>
                    <Setter Property="Background"
                            Value="{DynamicResource SessionsCardLoadedBackgroundBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SessionsCardTextBlockStyle"
               TargetType="{x:Type TextBlock}"
               BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground"
                    Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLoaded}"
                             Value="True">
                    <Setter Property="Foreground"
                            Value="{DynamicResource SessionsCardLoadedForegroundBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SessionsCardOpenButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource SessionsRowOpenButtonStyle}">
            <Setter Property="Foreground"
                    Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLoaded}"
                             Value="True">
                    <Setter Property="Foreground"
                            Value="{DynamicResource SessionsCardLoadedForegroundBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SessionsListBoxItemStyle"
               TargetType="{x:Type ListBoxItem}"
               BasedOn="{StaticResource FluentListBoxItemStyle}">
            <Setter Property="Margin"
                    Value="0,0,0,6"/>
            <Setter Property="Padding"
                    Value="0"/>
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="BorderBrush"
                    Value="{x:Null}"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="HorizontalContentAlignment"
                    Value="Stretch"/>
            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>
            <Setter Property="FocusVisualStyle"
                    Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FluentListViewItemStyle"
               TargetType="{x:Type ListViewItem}"
               BasedOn="{StaticResource {x:Type ListViewItem}}"/>
        <Style x:Key="TranscribeAudioButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource ToolbarPrimaryButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Margin="{TemplateBinding Padding}">
                                <TextBlock x:Name="IconText"
                                           Style="{StaticResource ToolbarButtonIconTextStyle}"
                                           Text="{TemplateBinding Tag}"
                                           FontSize="16"
                                           Margin="0,0,6,0"/>
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag"
                                     Value="{x:Null}">
                                <Setter TargetName="IconText"
                                        Property="Visibility"
                                        Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Chrome"
                                        Property="Background"
                                        Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                <Setter TargetName="Chrome"
                                        Property="BorderBrush"
                                        Value="{DynamicResource ControlStrokeColorSecondaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Chrome"
                                        Property="Background"
                                        Value="{DynamicResource ControlFillColorTertiaryBrush}"/>
                                <Setter TargetName="Chrome"
                                        Property="BorderBrush"
                                        Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter Property="Opacity"
                                        Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FluentDataGridCellStyle"
               TargetType="{x:Type DataGridCell}"
               BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Setter Property="Background"
                    Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled"
                         Value="False">
                    <Setter Property="Background"
                            Value="Transparent"/>
                    <Setter Property="Opacity"
                            Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="FluentDataGridColumnHeaderStyle"
               TargetType="{x:Type DataGridColumnHeader}"
               BasedOn="{StaticResource {x:Type DataGridColumnHeader}}"/>
        <Style x:Key="FluentDataGridRowStyle"
               TargetType="{x:Type DataGridRow}"
               BasedOn="{StaticResource {x:Type DataGridRow}}">
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="ContextMenu">
                <Setter.Value>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="Rename Speaker…"
                                  Command="{x:Static local:MainWindow.RenameSpeakerCommand}"
                                  CommandParameter="{Binding}"/>
                        <MenuItem Header="Merge Adjacent Rows for This Speaker"
                                  Command="{x:Static local:MainWindow.MergeAdjacentRowsForSelectedSpeakerCommand}"
                                  CommandParameter="{Binding}"/>
                        <MenuItem Header="Merge All Adjacent Rows by Speaker"
                                  Command="{x:Static local:MainWindow.MergeAllAdjacentRowsBySpeakerCommand}"
                                  CommandParameter="{Binding}"/>
                        <Separator Tag="SpeakerDivider"/>
                        <MenuItem Header="Transcribe This Row"
                                  Command="{x:Static local:MainWindow.TranscribeRowCommand}"
                                  CommandParameter="{Binding}"/>
                        <MenuItem Header="Split into Two Rows"
                                  Command="{x:Static local:MainWindow.SeparateRowCommand}"
                                  CommandParameter="{Binding}"/>
                        <MenuItem Header="Combine with Previous Row"
                                  Command="{x:Static local:MainWindow.CombineToPreviousRowCommand}"
                                  CommandParameter="{Binding}"/>
                        <Separator Tag="CopyDivider"/>
                        <MenuItem Header="Copy Row Text"
                                  Command="{x:Static local:MainWindow.CopyRowTextCommand}"
                                  CommandParameter="{Binding}"/>
                    </ContextMenu>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled"
                         Value="False">
                    <Setter Property="Background"
                            Value="Transparent"/>
                    <Setter Property="Opacity"
                            Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="FluentDataGridRowHeaderStyle"
               TargetType="{x:Type DataGridRowHeader}"
               BasedOn="{StaticResource {x:Type DataGridRowHeader}}"/>
        <Style x:Key="FluentDataGridStyle"
               TargetType="{x:Type DataGrid}"
               BasedOn="{StaticResource {x:Type DataGrid}}">
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="HeadersVisibility"
                    Value="Column"/>
            <Setter Property="RowBackground"
                    Value="Transparent"/>
            <Setter Property="AlternatingRowBackground"
                    Value="Transparent"/>
            <Setter Property="CellStyle"
                    Value="{StaticResource FluentDataGridCellStyle}"/>
            <Setter Property="ColumnHeaderStyle"
                    Value="{StaticResource FluentDataGridColumnHeaderStyle}"/>
            <Setter Property="RowStyle"
                    Value="{StaticResource FluentDataGridRowStyle}"/>
            <Setter Property="RowHeaderStyle"
                    Value="{StaticResource FluentDataGridRowHeaderStyle}"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled"
                         Value="False">
                    <Setter Property="Background"
                            Value="Transparent"/>
                    <Setter Property="RowBackground"
                            Value="Transparent"/>
                    <Setter Property="AlternatingRowBackground"
                            Value="Transparent"/>
                    <Setter Property="Opacity"
                            Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="WorkspaceGridEditorTextBoxStyle"
               TargetType="{x:Type TextBox}"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Padding"
                    Value="0"/>
            <Setter Property="Margin"
                    Value="0"/>
            <Setter Property="Background"
                    Value="White"/>
            <Setter Property="Foreground"
                    Value="Black"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource ControlCornerRadius}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TranscriptSpeakerEditorTextBoxStyle"
               TargetType="{x:Type TextBox}"
               BasedOn="{StaticResource WorkspaceGridEditorTextBoxStyle}">
            <Setter Property="Padding"
                    Value="4,0"/>
            <Setter Property="TextAlignment"
                    Value="Left"/>
            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>
            <Setter Property="CaretBrush"
                    Value="Black"/>
            <Setter Property="SelectionBrush"
                    Value="#FF0078D4"/>
            <Setter Property="SelectionTextBrush"
                    Value="White"/>
            <Setter Property="UndoLimit"
                    Value="100"/>
            <Setter Property="KeyboardNavigation.DirectionalNavigation"
                    Value="Contained"/>
        </Style>
        <Style x:Key="TranscriptTextEditorTextBoxStyle"
               TargetType="{x:Type TextBox}"
               BasedOn="{StaticResource WorkspaceGridEditorTextBoxStyle}">
            <Setter Property="Padding"
                    Value="4,0"/>
            <Setter Property="TextAlignment"
                    Value="Left"/>
            <Setter Property="VerticalContentAlignment"
                    Value="Top"/>
            <Setter Property="TextWrapping"
                    Value="Wrap"/>
            <Setter Property="AcceptsReturn"
                    Value="True"/>
            <Setter Property="AcceptsTab"
                    Value="False"/>
            <Setter Property="VerticalScrollBarVisibility"
                    Value="Disabled"/>
            <Setter Property="HorizontalScrollBarVisibility"
                    Value="Disabled"/>
            <Setter Property="CaretBrush"
                    Value="Black"/>
            <Setter Property="SelectionBrush"
                    Value="#FF0078D4"/>
            <Setter Property="SelectionTextBrush"
                    Value="White"/>
            <Setter Property="UndoLimit"
                    Value="100"/>
            <Setter Property="KeyboardNavigation.DirectionalNavigation"
                    Value="Contained"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainRootGrid">
        <DockPanel x:Name="MainContentHost"
                   LastChildFill="True">
            <StatusBar DockPanel.Dock="Bottom"
                       Margin="0"
                       MinHeight="28"
                       Padding="6,2"
                       VerticalContentAlignment="Center">
                <StatusBarItem Padding="0"
                               HorizontalContentAlignment="Stretch"
                               VerticalContentAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="© 2026 JustinTagarda"
                                       Margin="0,0,8,0"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility"
                                                Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsApplicationFooterDefaultVisible}"
                                                         Value="False">
                                                <Setter Property="Visibility"
                                                        Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <local:AppStatusDisplay Grid.Column="1"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"/>
                    </Grid>
                </StatusBarItem>
            </StatusBar>

            <Grid Margin="6,2,6,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Margin="0,0,0,6"
                        Padding="0"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Left">
                        <Button
                                Content="{x:Null}"
                                Width="32"
                                Height="32"
                                Padding="0"
                                ToolTip="Settings"
                                AutomationProperties.Name="Settings"
                                Tag="&#xE713;"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Click="Settings_Click"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="0"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Margin="0,0,6,0"
                            Padding="0"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            Background="{x:Null}"
                            CornerRadius="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                    <Border Grid.Row="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0"
                                  Margin="2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Content="Open Audio"
                                            Margin="0"
                                            VerticalAlignment="Center"
                                            Padding="8,0"
                                            Tag="&#xE838;"
                                            Style="{StaticResource ToolbarButtonStyle}"
                                            Command="{Binding OpenAudioFileCommand}"/>
                                    <Button Grid.Column="1"
                                            x:Name="LiveTranscriptionPrimaryActionButton"
                                            Content="Live Transcription"
                                            Margin="2,0,0,0"
                                            Padding="8,0"
                                            Tag="&#xE720;"
                                            IsEnabled="{Binding CanRunLivePrimaryAction}"
                                            Style="{StaticResource ToolbarPrimaryButtonStyle}"
                                            Click="LiveTranscriptionPrimaryAction_Click"/>
                                    <Button Grid.Column="2"
                                            Content="{x:Null}"
                                            Margin="2,0,0,0"
                                            Height="32"
                                            HorizontalAlignment="Stretch"
                                            Padding="0"
                                            ToolTip="Settings"
                                            AutomationProperties.Name="Settings"
                                            Tag="&#xE713;"
                                            Style="{StaticResource ToolbarButtonStyle}"
                                            Click="Settings_Click"/>
                                </Grid>
                            </Grid>

                            <Grid Grid.Row="1">
                                <ListBox ItemsSource="{Binding RecentSessions}"
                                         SelectedItem="{Binding SelectedRecentSession, Mode=TwoWay}"
                                         Margin="2,0"
                                         HorizontalContentAlignment="Stretch"
                                         Background="{x:Null}"
                                         ItemContainerStyle="{StaticResource SessionsListBoxItemStyle}"
                                         PreviewMouseLeftButtonDown="RecentSessionsList_PreviewMouseLeftButtonDown"
                                         MouseDoubleClick="RecentSessionsList_MouseDoubleClick"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">

                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource SessionsCardBorderStyle}"
                                                    ToolTip="{Binding DisplayName}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Style="{StaticResource SessionsCardTextBlockStyle}"
                                                                   Text="{Binding OriginalFileName}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Style="{StaticResource SessionsCardTextBlockStyle}"
                                                                   Text="{Binding UpdatedUtc, StringFormat=Updated {0:MMM dd, yyyy h:mm tt}}"
                                                                   Margin="0,3,0,0"
                                                                   FontSize="10.5"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>

                                                    <Button Grid.Column="1"
                                                            Tag="&#xE8A7;"
                                                            ToolTip="Open session"
                                                            Click="RecentSessionOpenButton_Click">
                                                        <Button.Style>
                                                            <Style TargetType="Button"
                                                                   BasedOn="{StaticResource SessionsCardOpenButtonStyle}">
                                                                <Setter Property="Visibility"
                                                                        Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsLoaded}"
                                                                                 Value="True">
                                                                        <Setter Property="Visibility"
                                                                                Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Border
                                    Padding="10">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasRecentSessions}"
                                                             Value="False">
                                                    <Setter Property="Visibility"
                                                            Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="No saved sessions yet"
                                                   HorizontalAlignment="Center"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="Import an audio file to create your first transcript session."
                                                   Margin="0,4,0,0"
                                                   HorizontalAlignment="Center"
                                                   FontSize="10.5"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    </Grid>
                </Border>

                    <Border Grid.Column="2"
                            Margin="0"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            Background="{x:Null}"
                            CornerRadius="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="0"
                                MinHeight="0"
                                VerticalAlignment="Stretch">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0"
                                      Margin="2">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Left">
                                        <Button x:Name="TranscribeAudioPrimaryActionButton"
                                                Content="Transcribe Audio"
                                                Margin="0"
                                                Padding="8,0"
                                                Tag="&#xE7F0;"
                                                IsEnabled="{Binding CanRunTranscribeAudioPrimaryAction}"
                                                Style="{StaticResource TranscribeAudioButtonStyle}"
                                                Click="TranscribeAudioPrimaryAction_Click"/>
                                        <Button x:Name="DetectSpeakerPrimaryActionButton"
                                                Content="Detect Speaker"
                                                Margin="2,0,0,0"
                                                Padding="8,0"
                                                Tag="&#xE716;"
                                                IsEnabled="{Binding CanRunDetectSpeakerPrimaryAction}"
                                                Style="{StaticResource ToolbarButtonStyle}"
                                                Click="DetectSpeakerPrimaryAction_Click"/>
                                        <Button Content="Copy"
                                                Margin="2,0,0,0"
                                                VerticalAlignment="Center"
                                                Padding="8,0"
                                                ToolTip="Copy to Clipboard"
                                                AutomationProperties.Name="Copy to Clipboard"
                                                Tag="&#xE8C8;"
                                                Style="{StaticResource ToolbarButtonStyle}"
                                                IsEnabled="{Binding CanCopyTranscript}"
                                                Click="CopyFinalizedToClipboard_Click"/>
                                        <Button Content="Export"
                                                Margin="2,0,0,0"
                                                VerticalAlignment="Center"
                                                Padding="8,0"
                                                ToolTip="Export transcript to Word document"
                                                AutomationProperties.Name="Export transcript"
                                                Tag="&#xE8A5;"
                                                Style="{StaticResource ToolbarButtonStyle}"
                                                IsEnabled="{Binding CanCopyTranscript}"
                                                Click="ExportTranscriptToDocument_Click"/>
                                        <Button Content="Close"
                                                Margin="2,0,0,0"
                                                VerticalAlignment="Center"
                                                Padding="8,0"
                                                Tag="&#xE711;"
                                                Style="{StaticResource ToolbarButtonStyle}"
                                                Command="{Binding CloseCommand}"/>
                                        <Button Content="Delete"
                                                Margin="2,0,0,0"
                                                Tag="&#xE74D;"
                                                Style="{StaticResource ToolbarButtonStyle}"
                                                Command="{Binding DeleteSelectedSessionCommand}"/>
                                    </StackPanel>
                                </Grid>

                                <Border Grid.Row="1"
                                        ClipToBounds="True"
                                        VerticalAlignment="Stretch">
                                    <Grid>
                                        <DataGrid x:Name="FinalizedTranscriptGrid"
                                                  ItemsSource="{Binding CurrentTranscriptLines}"
                                                  Style="{StaticResource FluentDataGridStyle}"
                                                  BorderThickness="0,0,0,1"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  CanUserResizeRows="False"
                                                  SelectionMode="Single"
                                                  SelectionUnit="Cell"
                                                  CurrentCellChanged="FinalizedTranscriptGrid_CurrentCellChanged"
                                                  GotKeyboardFocus="FinalizedTranscriptGrid_GotKeyboardFocus"
                                                  LostKeyboardFocus="FinalizedTranscriptGrid_LostKeyboardFocus"
                                                  BeginningEdit="FinalizedTranscriptGrid_BeginningEdit"
                                                  CellEditEnding="FinalizedTranscriptGrid_CellEditEnding"
                                                  PreviewMouseRightButtonDown="FinalizedTranscriptGrid_PreviewMouseRightButtonDown"
                                                  ContextMenuOpening="FinalizedTranscriptGrid_ContextMenuOpening"
                                                  PreviewKeyDown="FinalizedTranscriptGrid_PreviewKeyDown"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalAlignment="Stretch"
                                                  HorizontalAlignment="Stretch">
                                            <DataGrid.Resources>
                                                <Style TargetType="{x:Type TextBox}"
                                                       BasedOn="{StaticResource WorkspaceGridEditorTextBoxStyle}"/>
                                            </DataGrid.Resources>

                                            <DataGrid.Columns>
                                                <DataGridTemplateColumn x:Name="TimelineTranscriptColumn"
                                                                        Header="Timeline"
                                                                        CanUserSort="False"
                                                                        IsReadOnly="True"
                                                                        Width="Auto">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Border Margin="6,0,0,0"
                                                                    Padding="4,1"
                                                                    CornerRadius="4">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background"
                                                                                Value="Transparent"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsPlaybackTimelineMatch}"
                                                                                         Value="True">
                                                                                <Setter Property="Background"
                                                                                        Value="#FFBFDF"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding Timeline}"
                                                                           TextAlignment="Left"
                                                                           HorizontalAlignment="Left">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground"
                                                                                    Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsPlaybackTimelineMatch}"
                                                                                             Value="True">
                                                                                    <Setter Property="Foreground"
                                                                                            Value="Black"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn x:Name="SpeakerColumn"
                                                                    Header="Speaker"
                                                                    Binding="{Binding SpeakerLabel}"
                                                                    EditingElementStyle="{StaticResource TranscriptSpeakerEditorTextBoxStyle}"
                                                                    Width="Auto"
                                                                    Visibility="Collapsed"/>
                                                <DataGridTemplateColumn x:Name="TranscriptTextColumn"
                                                                        Header="Text"
                                                                        CanUserSort="False"
                                                                        Width="*">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Grid>
                                                                <TextBlock Text="{Binding Text}"
                                                                           Margin="4,0"
                                                                           TextWrapping="Wrap">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsTranscriptionPartial}"
                                                                                             Value="True">
                                                                                    <Setter Property="FontStyle"
                                                                                            Value="Italic"/>
                                                                                    <Setter Property="Opacity"
                                                                                            Value="0.82"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <Border Height="3"
                                                                        VerticalAlignment="Bottom"
                                                                        Margin="4,0">
                                                                    <Border.Style>
                                                                        <Style TargetType="{x:Type Border}">
                                                                            <Setter Property="Visibility"
                                                                                    Value="Collapsed"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsPlaybackEditTranscribing}"
                                                                                             Value="True">
                                                                                    <Setter Property="Visibility"
                                                                                            Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <ProgressBar Minimum="0"
                                                                                 Maximum="100"
                                                                                 Value="{Binding PlaybackEditProgressPercent}"
                                                                                 IsIndeterminate="{Binding IsPlaybackEditProgressIndeterminate}"/>
                                                                </Border>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                    <DataGridTemplateColumn.CellEditingTemplate>
                                                        <DataTemplate>
                                                            <TextBox Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                     Style="{StaticResource TranscriptTextEditorTextBoxStyle}"
                                                                     IsReadOnly="{Binding IsPlaybackEditTranscribing}"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellEditingTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <Border x:Name="TranscriptEmptyStateBorder"
                                                Padding="12"
                                                Margin="0"
                                                VerticalAlignment="Stretch"
                                                MaxWidth="360">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsTranscriptEmptyStateVisible}"
                                                                     Value="True">
                                                            <Setter Property="Visibility"
                                                                    Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        MaxWidth="320">
                                                <TextBlock Text="{Binding TranscriptEmptyStateTitle}"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           TextAlignment="Center"/>
                                                <TextBlock Text="{Binding TranscriptEmptyStateMessage}"
                                                           Margin="0,8,0,0"
                                                           FontSize="11"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap"/>
                                                <Button Content="Open Audio"
                                                        Margin="0,12,0,0"
                                                        HorizontalAlignment="Center"
                                                        Tag="&#xE838;"
                                                        Command="{Binding OpenAudioFileCommand}">
                                                    <Button.Style>
                                                        <Style TargetType="Button"
                                                               BasedOn="{StaticResource ToolbarButtonStyle}">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ShouldShowTranscriptChooseFileAction}"
                                                                             Value="True">
                                                                    <Setter Property="Visibility"
                                                                            Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                <Button Content="Transcribe Audio"
                                                        Margin="0,12,0,0"
                                                        HorizontalAlignment="Center"
                                                        Padding="10,0"
                                                        Tag="&#xE7F0;"
                                                        IsEnabled="{Binding CanRunTranscribeAudioPrimaryAction}"
                                                        Click="TranscribeAudioPrimaryAction_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button"
                                                               BasedOn="{StaticResource TranscribeAudioButtonStyle}">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ShouldShowTranscriptTranscribeAudioAction}"
                                                                             Value="True">
                                                                    <Setter Property="Visibility"
                                                                            Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Margin="0"
                                Padding="8"
                                CornerRadius="6"
                                BorderThickness="0"
                                BorderBrush="{x:Null}"
                                Background="{x:Null}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Text="Player"
                                           FontSize="16"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="1"
                                           Margin="12,0,0,0"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Text="{Binding LoadedAudioFileName}"
                                           TextWrapping="Wrap"/>

                                <Grid Grid.Row="1"
                                      Grid.ColumnSpan="2"
                                      Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0"
                                              Content="Auto play"
                                              Margin="0,0,12,0"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding AutoPlayTimelineSelection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Button Grid.Column="1"
                                            Margin="0,0,8,0"
                                            Width="74">
                                        <Button.Style>
                                            <Style TargetType="Button"
                                                   BasedOn="{StaticResource ToolbarButtonStyle}">
                                                <Setter Property="Content"
                                                        Value="Play"/>
                                                <Setter Property="Tag"
                                                        Value="&#xE768;"/>
                                                <Setter Property="Command"
                                                        Value="{Binding PlayAudioCommand}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAudioPlaying}"
                                                                 Value="True">
                                                        <Setter Property="Content"
                                                                Value="Pause"/>
                                                        <Setter Property="Tag"
                                                                Value="&#xE769;"/>
                                                        <Setter Property="Command"
                                                                Value="{Binding PauseAudioCommand}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding AudioElapsedText}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"
                                               FontSize="12"/>
                                    <Slider Grid.Column="3"
                                            Minimum="0"
                                            Maximum="{Binding AudioSeekMaximumSeconds}"
                                            Value="{Binding AudioSeekPositionSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            VerticalAlignment="Center"
                                            IsEnabled="{Binding IsAudioFileLoaded}"/>
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding AudioRemainingText}"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"
                                               FontSize="12"/>
                                </Grid>
                            </Grid>
                        </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </DockPanel>

        <Border x:Name="TranscribeAudioBatchOverlay"
                Panel.ZIndex="100"
                Background="Transparent"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <Grid>
                <Border HorizontalAlignment="Center"
                        x:Name="TranscribeAudioBatchCard"
                        VerticalAlignment="Center"
                        Width="520"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="22,18">

                    <StackPanel>
                        <TextBlock Text="{Binding TranscriptProcessingTitle, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                        <TextBlock Text="{Binding TranscriptProcessingDetail, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Margin="0,6,0,0"
                                   FontSize="12"
                                   Opacity="0.82"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                        <Border Margin="0,14,0,0"
                                Padding="14,12"
                                CornerRadius="8"
                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Source file"
                                               FontSize="10.5"
                                               Opacity="0.72"/>
                                    <TextBlock Text="{Binding TranscriptProcessingSourceFileText, RelativeSource={RelativeSource AncestorType=Window}}"
                                               Margin="0,4,0,0"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1"
                                            Margin="16,0,0,0"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom">
                                    <TextBlock Text="File size"
                                               FontSize="10.5"
                                               Opacity="0.72"
                                               TextAlignment="Right"/>
                                    <TextBlock Text="{Binding TranscriptProcessingSourceFileSizeText, RelativeSource={RelativeSource AncestorType=Window}}"
                                               Margin="0,4,0,0"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               TextAlignment="Right"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Margin="0,8,0,0"
                                Padding="14,10"
                                CornerRadius="8"
                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Engine"
                                           FontSize="10.5"
                                           Opacity="0.72"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding TranscriptProcessingEngineText, RelativeSource={RelativeSource AncestorType=Window}}"
                                           Margin="14,0,0,0"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextAlignment="Right"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Border>
                        <StackPanel Margin="0,14,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility"
                                            Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTranscribeAudioBatchPendingStart, RelativeSource={RelativeSource AncestorType=Window}}"
                                                     Value="True">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <ProgressBar Height="8"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="{Binding TranscriptProcessingPercent, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"
                                         IsIndeterminate="{Binding IsTranscriptProcessingIndeterminate, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            <Grid Margin="0,14,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding TranscriptProcessingChunkText, RelativeSource={RelativeSource AncestorType=Window}}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Opacity="0.82"
                                           TextAlignment="Center"/>
                                <TextBlock Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding TranscriptProcessingAudioText, RelativeSource={RelativeSource AncestorType=Window}}"
                                           Margin="0,4,0,0"
                                           FontSize="12"
                                           Opacity="0.82"
                                           TextAlignment="Center"/>
                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Text="{Binding TranscriptProcessingElapsedText, RelativeSource={RelativeSource AncestorType=Window}}"
                                           Margin="0,4,8,0"
                                           FontSize="11"
                                           Opacity="0.82"
                                           TextAlignment="Right"/>
                                <TextBlock Grid.Row="2"
                                           Grid.Column="1"
                                           Text="{Binding TranscriptProcessingEtaText, RelativeSource={RelativeSource AncestorType=Window}}"
                                           Margin="8,4,0,0"
                                           FontSize="11"
                                           Opacity="0.82"
                                           TextAlignment="Left"/>
                            </Grid>
                        </StackPanel>
                        <DockPanel Margin="0,16,0,0"
                                   LastChildFill="False">
                            <CheckBox DockPanel.Dock="Left"
                                      Content="Mute"
                                      IsChecked="{Binding IsPlaybackMuted, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0">
                                <CheckBox.Style>
                                    <Style TargetType="CheckBox"
                                           BasedOn="{StaticResource {x:Type CheckBox}}">
                                        <Setter Property="Visibility"
                                                Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTranscriptProcessingMuteAvailable, RelativeSource={RelativeSource AncestorType=Window}}"
                                                         Value="False">
                                                <Setter Property="Visibility"
                                                        Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </CheckBox.Style>
                            </CheckBox>
                            <Button x:Name="TranscribeAudioBatchStartButton"
                                    DockPanel.Dock="Right"
                                    Content="{Binding TranscriptProcessingStartButtonText, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Tag="&#xE768;"
                                    Margin="0,0,8,0"
                                    IsEnabled="{Binding IsTranscribeAudioBatchStartEnabled, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Click="StartProcessing_Click">
                                <Button.Style>
                                    <Style TargetType="Button"
                                           BasedOn="{StaticResource ToolbarPrimaryButtonStyle}">
                                        <Setter Property="Visibility"
                                                Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTranscribeAudioBatchPendingStart, RelativeSource={RelativeSource AncestorType=Window}}"
                                                         Value="False">
                                                <Setter Property="Visibility"
                                                        Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button x:Name="TranscribeAudioBatchCancelButton"
                                    DockPanel.Dock="Right"
                                    Content="{Binding TranscriptProcessingDismissButtonText, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Tag="&#xE711;"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    IsEnabled="{Binding IsTranscriptProcessingCancelEnabled, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Click="CancelProcessing_Click"/>
                        </DockPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="CopyToastHost"
                Panel.ZIndex="20"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,48,48,0"
                Opacity="0"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <Border.RenderTransform>
                <TranslateTransform x:Name="CopyToastTransform"
                                    Y="-14"/>
            </Border.RenderTransform>
            <Border
                x:Name="CopyToastCard"
                HorizontalAlignment="Center"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14,12"
                MaxWidth="320">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="CopyToastIconHost"
                            Width="34"
                            Height="34"
                            VerticalAlignment="Top">
                        <Viewbox Width="15"
                                 Height="15"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center">
                            <Path x:Name="CopyToastIconPath"
                                  StrokeThickness="2.6"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Data="M2.5,8.5 L6.2,12.2 L13.5,4.5"/>
                        </Viewbox>
                    </Border>
                    <StackPanel Grid.Column="1"
                                Margin="12,0,0,0">
                        <TextBlock x:Name="CopyToastTitleText"
                                   Text="Copied to clipboard"
                                   FontSize="13"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="CopyToastMessageText"
                                   Text="Finalized transcript is ready to paste."
                                   Margin="0,3,0,0"
                                   FontSize="11"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>





