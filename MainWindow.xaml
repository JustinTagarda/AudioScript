<Window x:Class="AudioTranscript.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Audio Transcription"
        Height="820"
        Width="1280"
        MinHeight="720"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#FFF4F7F8">
    <Window.Resources>
        <SolidColorBrush x:Key="SurfaceBrush"
                Color="#CCFFFFFF"/>
        <SolidColorBrush x:Key="SurfaceBorderBrush"
                Color="#55B7CAD2"/>
        <SolidColorBrush x:Key="PrimaryTextBrush"
                Color="#FF15232D"/>
        <SolidColorBrush x:Key="SecondaryTextBrush"
                Color="#FF49616F"/>
        <SolidColorBrush x:Key="InterimSurfaceBrush"
                Color="#FFF3FAFD"/>
        <SolidColorBrush x:Key="InterimBorderBrush"
                Color="#FFC0D9E4"/>
        <SolidColorBrush x:Key="InterimTextBrush"
                Color="#FF234A5D"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="CardStyle"
                TargetType="Border">
            <Setter Property="Background"
                    Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush"
                    Value="{StaticResource SurfaceBorderBrush}"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="CornerRadius"
                    Value="10"/>
            <Setter Property="SnapsToDevicePixels"
                    Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="22"
                            ShadowDepth="0"
                            Opacity="0.18"
                            Color="#FF7F97A6"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CaptionTextStyle"
                TargetType="TextBlock">
            <Setter Property="FontFamily"
                    Value="Segoe UI Variable Text"/>
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
            <Setter Property="Foreground"
                    Value="{StaticResource SecondaryTextBrush}"/>
            <Setter Property="Margin"
                    Value="0,12,0,6"/>
            <Setter Property="FontSize"
                    Value="11"/>
        </Style>

        <Style x:Key="LiveDotStyle"
                TargetType="Ellipse">
            <Setter Property="Fill"
                    Value="#FF95A8B3"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLiveRunning}"
                        Value="True">
                    <Setter Property="Fill"
                            Value="#FF18C180"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FooterProgressBarStyle"
               TargetType="ProgressBar">
            <Setter Property="Width"
                    Value="160"/>
            <Setter Property="Height"
                    Value="10"/>
            <Setter Property="Margin"
                    Value="0,0,10,0"/>
            <Setter Property="Minimum"
                    Value="0"/>
            <Setter Property="Maximum"
                    Value="100"/>
            <Setter Property="IsIndeterminate"
                    Value="True"/>
            <Setter Property="Background"
                    Value="#FFD9E8EE"/>
            <Setter Property="Foreground"
                    Value="#FF1B86AA"/>
            <Setter Property="BorderBrush"
                    Value="#FFBBD1DB"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="Visibility"
                    Value="Collapsed"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid ClipToBounds="True">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5"/>
                            <Border x:Name="Indicator"
                                    Width="52"
                                    HorizontalAlignment="Left"
                                    CornerRadius="5"
                                    Background="{TemplateBinding Foreground}"
                                    Margin="0,1"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <TranslateTransform X="-60"/>
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsIndeterminate"
                                     Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="Indicator"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             From="-60"
                                                             To="220"
                                                             Duration="0:0:1.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFileTranscribing}"
                             Value="True">
                    <Setter Property="Visibility"
                            Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernComboBoxItemStyle"
               TargetType="ComboBoxItem">
            <Setter Property="Padding"
                    Value="10,7"/>
            <Setter Property="FontFamily"
                    Value="Segoe UI Variable Text"/>
            <Setter Property="FontSize"
                    Value="13"/>
            <Setter Property="Foreground"
                    Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted"
                                     Value="True">
                                <Setter TargetName="ItemBorder"
                                        Property="Background"
                                        Value="#FFEAF4F8"/>
                            </Trigger>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter TargetName="ItemBorder"
                                        Property="Background"
                                        Value="#FFDCEFF6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernComboBoxStyle"
               TargetType="ComboBox">
            <Setter Property="FontFamily"
                    Value="Segoe UI Variable Text"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="Foreground"
                    Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background"
                    Value="#FFFDFEFF"/>
            <Setter Property="BorderBrush"
                    Value="#FF9DB6C0"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="Padding"
                    Value="10,8"/>
            <Setter Property="MinHeight"
                    Value="40"/>
            <Setter Property="SnapsToDevicePixels"
                    Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="OuterBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"/>

                            <ToggleButton x:Name="DropDownToggle"
                                          Focusable="False"
                                          FocusVisualStyle="{x:Null}"
                                          OverridesDefaultStyle="True"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          HorizontalContentAlignment="Stretch"
                                          VerticalContentAlignment="Stretch">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"
                                                BorderThickness="0">
                                            <ContentPresenter HorizontalAlignment="Stretch"
                                                              VerticalAlignment="Stretch"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <Grid Margin="{TemplateBinding Padding}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter Grid.Column="0"
                                                      Margin="0,0,8,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"/>

                                    <Path x:Name="DropArrow"
                                          Grid.Column="1"
                                          Width="11"
                                          Height="7"
                                          Stretch="Fill"
                                          Stroke="#FF4B6775"
                                          StrokeThickness="1.8"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Data="M1,1 L5.5,6 L10,1"/>
                                </Grid>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Margin="0,4,0,0"
                                        Background="#FFFDFEFF"
                                        BorderBrush="#FF9DB6C0"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="300"
                                                  VerticalScrollBarVisibility="Auto"
                                                  CanContentScroll="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="OuterBorder"
                                        Property="BorderBrush"
                                        Value="#FFA9C8D6"/>
                                <Setter TargetName="OuterBorder"
                                        Property="Background"
                                        Value="#FFDFF1F8"/>
                                <Setter Property="Foreground"
                                        Value="#FF153949"/>
                                <Setter TargetName="DropArrow"
                                        Property="Stroke"
                                        Value="#FF153949"/>
                                <Setter Property="Cursor"
                                        Value="Hand"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin"
                                     Value="True">
                                <Setter TargetName="OuterBorder"
                                        Property="BorderBrush"
                                        Value="#FF1B86AA"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter TargetName="OuterBorder"
                                        Property="Background"
                                        Value="#FFF1F6F8"/>
                                <Setter TargetName="OuterBorder"
                                        Property="BorderBrush"
                                        Value="#FFD9E3E8"/>
                                <Setter Property="Foreground"
                                        Value="#FFA0B0B9"/>
                                <Setter TargetName="DropArrow"
                                        Property="Stroke"
                                        Value="#FFA0B0B9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Width"
                    Value="42"/>
            <Setter Property="MinWidth"
                    Value="42"/>
            <Setter Property="MinHeight"
                    Value="38"/>
            <Setter Property="Padding"
                    Value="0"/>
            <Setter Property="Margin"
                    Value="8,0,4,0"/>
        </Style>

        <Style x:Key="PlaybackActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Height"
                    Value="29"/>
            <Setter Property="MinHeight"
                    Value="29"/>
            <Setter Property="Padding"
                    Value="12,4"/>
        </Style>

        <Style x:Key="PlaybackSecondaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height"
                    Value="29"/>
            <Setter Property="MinHeight"
                    Value="29"/>
            <Setter Property="Padding"
                    Value="12,4"/>
        </Style>

        <Style x:Key="PlaybackIconButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource IconActionButtonStyle}">
            <Setter Property="Height"
                    Value="29"/>
            <Setter Property="MinHeight"
                    Value="29"/>
        </Style>
    </Window.Resources>

    <Grid Background="#FFF4F7F8">
        <DockPanel LastChildFill="True">
            <StatusBar DockPanel.Dock="Bottom"
                       Margin="0"
                       MinHeight="32"
                       Padding="10,2"
                       Background="#FFEFF3F6"
                       BorderBrush="#FFC8D6DD"
                       BorderThickness="1,1,1,0">
                <StatusBarItem DockPanel.Dock="Right"
                               Padding="0"
                               BorderThickness="0">
                    <StackPanel Orientation="Horizontal">
                        <ProgressBar Style="{StaticResource FooterProgressBarStyle}"/>
                        <Ellipse Width="10"
                                 Height="10"
                                 Margin="0,0,8,0"
                                 Style="{StaticResource LiveDotStyle}"/>
                        <TextBlock Text="{Binding SelectedEngine.DisplayName, TargetNullValue=No engine selected}"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>
                </StatusBarItem>

                <StatusBarItem DockPanel.Dock="Left"
                               Padding="0"
                               BorderThickness="0">
                    <TextBlock Text="© 2026 justintagarda@gmail.com. All rights reserved."
                               Margin="0,0,14,0"
                               FontFamily="Bahnschrift"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                </StatusBarItem>
            </StatusBar>

            <Grid Margin="14,3.5,14,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="400"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource CardStyle}"
                        Padding="11">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Settings"
                                       FontFamily="Bahnschrift"
                                       FontSize="20"
                                       Foreground="{StaticResource PrimaryTextBrush}"/>

                            <TextBlock Text="Transcription Engine"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,14,0,8"/>
                            <ComboBox ItemsSource="{Binding Engines}"
                                      SelectedItem="{Binding SelectedEngine}"
                                      SelectionChanged="EngineComboBox_SelectionChanged"
                                      DisplayMemberPath="DisplayName"
                                      IsEnabled="{Binding IsEngineSelectionEnabled}"
                                      Style="{StaticResource ModernComboBoxStyle}"
                                      ItemContainerStyle="{StaticResource ModernComboBoxItemStyle}"/>

                            <Separator Margin="0,12,0,10"/>

                            <UniformGrid Columns="3"
                                         Rows="2"
                                         Margin="0,6,0,0">
                                <Button Content="Transcribe File"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding TranscribeFileCommand}"/>
                                <Button Content="Live Transcription"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding StartLiveCommand}"/>
                                <Button Content="Clear Output"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding ClearCommand}"/>
                                <Button Content="Cancel"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding CancelCommand}"/>
                                <Button Content="Stop Live"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding StopLiveCommand}"/>
                                <Button Content="OpenAI settings"
                                        Style="{StaticResource ActionButtonStyle}"
                                        IsEnabled="{Binding IsOpenAiSettingsEnabled}"
                                        Click="OpenOpenAiSettings_Click"/>
                            </UniformGrid>

                            <TextBlock Text="Audio Preview"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,12,0,6"/>
                            <Border Background="#FFFDFEFF"
                                    BorderBrush="#FFD2E2E7"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="10">
                                <StackPanel>
                                    <TextBlock Text="{Binding LoadedAudioFileName}"
                                               FontFamily="Segoe UI Variable Text"
                                               FontSize="12"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               TextWrapping="Wrap"/>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Content="Play"
                                                Style="{StaticResource PlaybackActionButtonStyle}"
                                                Command="{Binding PlayAudioCommand}"/>
                                        <Button Grid.Column="1"
                                                Content="Pause"
                                                Style="{StaticResource PlaybackSecondaryButtonStyle}"
                                                Command="{Binding PauseAudioCommand}"/>
                                        <Button Grid.Column="2"
                                                Content="Stop"
                                                Style="{StaticResource PlaybackSecondaryButtonStyle}"
                                                Command="{Binding StopAudioCommand}"/>
                                        <Button Grid.Column="3"
                                                ToolTip="Rewind 5 seconds"
                                                AutomationProperties.Name="Rewind 5 seconds"
                                                Style="{StaticResource PlaybackIconButtonStyle}"
                                                Command="{Binding RewindAudioCommand}">
                                            <Viewbox Width="11.2"
                                                     Height="11.2"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center">
                                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                      Stretch="Uniform"
                                                      Data="M14,4 L8,10 L14,16 Z M8.5,4 L2.5,10 L8.5,16 Z"/>
                                            </Viewbox>
                                        </Button>
                                        <Button Grid.Column="4"
                                                ToolTip="Forward 5 seconds"
                                                AutomationProperties.Name="Forward 5 seconds"
                                                Style="{StaticResource PlaybackIconButtonStyle}"
                                                Command="{Binding ForwardAudioCommand}">
                                            <Viewbox Width="11.2"
                                                     Height="11.2"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center">
                                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                      Stretch="Uniform"
                                                      Data="M2,4 L8,10 L2,16 Z M7.5,4 L13.5,10 L7.5,16 Z"/>
                                            </Viewbox>
                                        </Button>
                                    </Grid>
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding AudioElapsedText}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"
                                                   FontFamily="Consolas"
                                                   FontSize="12"
                                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                                        <Slider Grid.Column="1"
                                                Minimum="0"
                                                Maximum="{Binding AudioSeekMaximumSeconds}"
                                                Value="{Binding AudioSeekPositionSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                VerticalAlignment="Center"
                                                IsEnabled="{Binding IsAudioFileLoaded}"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding AudioRemainingText}"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0"
                                                   FontFamily="Consolas"
                                                   FontSize="12"
                                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Separator Margin="0,12,0,8"/>
                        </StackPanel>

                        <TextBlock Grid.Row="1"
                                   Text="Process Logs"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,2,0,6"/>

                        <Border Grid.Row="2"
                                Background="#FFFDFEFF"
                                BorderBrush="#FFD2E2E7"
                                BorderThickness="1"
                                CornerRadius="10">
                            <ListView x:Name="ProcessLogsListView"
                                      ItemsSource="{Binding ProcessLogs}"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      FontFamily="Segoe UI Variable Text"
                                      FontSize="12"
                                      Foreground="{StaticResource PrimaryTextBrush}"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListView.Resources>
                                    <Style TargetType="{x:Type GridViewColumnHeader}">
                                        <Setter Property="FontFamily"
                                                Value="Segoe UI Variable Text"/>
                                        <Setter Property="FontSize"
                                                Value="12"/>
                                        <Setter Property="FontWeight"
                                                Value="SemiBold"/>
                                        <Setter Property="Foreground"
                                                Value="{StaticResource SecondaryTextBrush}"/>
                                        <Setter Property="Background"
                                                Value="#FFF6FAFC"/>
                                        <Setter Property="BorderBrush"
                                                Value="#FFD2E2E7"/>
                                        <Setter Property="BorderThickness"
                                                Value="0,0,0,1"/>
                                        <Setter Property="Padding"
                                                Value="6,5"/>
                                    </Style>
                                </ListView.Resources>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="{x:Type ListViewItem}">
                                        <Setter Property="Padding"
                                                Value="0"/>
                                        <Setter Property="Margin"
                                                Value="0"/>
                                        <Setter Property="HorizontalContentAlignment"
                                                Value="Stretch"/>
                                        <Setter Property="VerticalContentAlignment"
                                                Value="Center"/>
                                        <Setter Property="Background"
                                                Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected"
                                                     Value="True">
                                                <Setter Property="Background"
                                                        Value="#FFEAF4F8"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.View>
                                    <GridView AllowsColumnReorder="False">
                                        <GridViewColumn Header="Time"
                                                        Width="74"
                                                        DisplayMemberBinding="{Binding Time}"/>
                                        <GridViewColumn Header="Log"
                                                        Width="284">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Message}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,0,4,0"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Border>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1"
                              Width="6"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Stretch"
                              ResizeDirection="Columns"
                              ResizeBehavior="PreviousAndNext"
                              Background="Transparent"
                              ShowsPreview="True"/>

                <Border Grid.Column="2"
                        Style="{StaticResource CardStyle}"
                        Padding="12"
                        Margin="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    Margin="0,0,0,16"
                                    Visibility="{Binding IsLiveRunning, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Interim Output"
                                       FontFamily="Bahnschrift"
                                       FontSize="20"
                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                            <Border Background="{StaticResource InterimSurfaceBrush}"
                                    BorderBrush="{StaticResource InterimBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="10"
                                    Margin="0,10,0,0">
                                <TextBlock Text="{Binding InterimText}"
                                           FontFamily="Segoe UI Variable Text"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource InterimTextBrush}"
                                           MinHeight="30"/>
                            </Border>
                        </StackPanel>

                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0"
                                       LastChildFill="False">
                                <TextBlock Text="Finalized Transcript"
                                           DockPanel.Dock="Left"
                                           FontFamily="Bahnschrift"
                                           FontSize="20"
                                           Foreground="{StaticResource PrimaryTextBrush}"/>
                                <Button DockPanel.Dock="Right"
                                        Style="{StaticResource IconActionButtonStyle}"
                                        ToolTip="Copy to Clipboard"
                                        AutomationProperties.Name="Copy to Clipboard"
                                        IsEnabled="{Binding IsEngineSelectionEnabled}"
                                        Click="CopyFinalizedToClipboard_Click">
                                    <Viewbox Width="16"
                                             Height="16">
                                        <Path Fill="White"
                                              Data="M16,1H4A2,2 0 0,0 2,3V17H4V3H16M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5Z"/>
                                    </Viewbox>
                                </Button>
                            </DockPanel>

                            <Border Grid.Row="1"
                                    Background="#FFFDFEFF"
                                    BorderBrush="#FFD2E2E7"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Margin="0,10,0,0">
                                <TextBox x:Name="FinalizedTranscriptTextBox"
                                         Text="{Binding FinalizedText, Mode=OneWay}"
                                         IsReadOnly="True"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Padding="7"
                                         FontFamily="Consolas"
                                         FontSize="15"
                                         Foreground="{StaticResource PrimaryTextBrush}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Disabled"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </DockPanel>
    </Grid>
</Window>
