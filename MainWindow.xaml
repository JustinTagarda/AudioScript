<Window x:Class="AudioTranscript.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AudioTranscript Studio"
        Height="820"
        Width="1280"
        MinHeight="720"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#FFF4F7F8">
    <Window.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#CCFFFFFF" />
        <SolidColorBrush x:Key="SurfaceBorderBrush" Color="#55B7CAD2" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FF15232D" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#FF49616F" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF168AAD" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#22168AAD" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="22" ShadowDepth="0" Opacity="0.18" Color="#FF7F97A6" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="Margin" Value="0,12,0,6" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#FF167AA0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#FF167AA0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF0E90B4" />
                    <Setter Property="BorderBrush" Value="#FF0E90B4" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FF9DB8C3" />
                    <Setter Property="BorderBrush" Value="#FF9DB8C3" />
                    <Setter Property="Foreground" Value="#FFE2EAEE" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#FFD94E3A" />
            <Setter Property="BorderBrush" Value="#FFD94E3A" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFE6644E" />
                    <Setter Property="BorderBrush" Value="#FFE6644E" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FFC9A9A3" />
                    <Setter Property="BorderBrush" Value="#FFC9A9A3" />
                    <Setter Property="Foreground" Value="#FFF5EBEA" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ChipStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="#33168AAD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="0,0,8,8" />
        </Style>

        <Style x:Key="LiveDotStyle" TargetType="Ellipse">
            <Setter Property="Fill" Value="#FF95A8B3" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLiveRunning}" Value="True">
                    <Setter Property="Fill" Value="#FF18C180" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#FFF4F7F8">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,18">
                <TextBlock Text="AudioTranscript Studio"
                           FontFamily="Bahnschrift SemiBold"
                           FontSize="40"
                           Foreground="{StaticResource PrimaryTextBrush}" />
                <TextBlock Text="Transcribe audio files and live conversations with pluggable local and online engines"
                           Margin="0,2,0,0"
                           FontFamily="Segoe UI Variable Text"
                           FontSize="15"
                           Foreground="{StaticResource SecondaryTextBrush}" />
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="390" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="20">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock Text="Control Center"
                                       FontFamily="Bahnschrift SemiBold"
                                       FontSize="26"
                                       Foreground="{StaticResource PrimaryTextBrush}" />

                            <TextBlock Text="Engine" Style="{StaticResource CaptionTextStyle}" />
                            <ComboBox ItemsSource="{Binding Engines}"
                                      SelectedItem="{Binding SelectedEngine}"
                                      DisplayMemberPath="DisplayName"
                                      FontFamily="Segoe UI Variable Text"
                                      FontSize="14"
                                      Padding="10"
                                      BorderBrush="#FF9DB6C0"
                                      BorderThickness="1"
                                      Background="#FFFDFEFF" />

                            <TextBlock Text="Capabilities" Style="{StaticResource CaptionTextStyle}" />
                            <ItemsControl ItemsSource="{Binding CapabilityLabels}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource ChipStyle}">
                                            <TextBlock Text="{Binding}"
                                                       FontFamily="Segoe UI Variable Text"
                                                       FontSize="12"
                                                       Foreground="{StaticResource AccentBrush}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Language Hint" Style="{StaticResource CaptionTextStyle}" />
                            <TextBox Text="{Binding LanguageHint, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Segoe UI Variable Text"
                                     FontSize="14"
                                     Padding="10"
                                     BorderBrush="#FF9DB6C0"
                                     BorderThickness="1"
                                     Background="#FFFDFEFF" />

                            <CheckBox Content="Include timestamps where supported"
                                      IsChecked="{Binding IncludeTimestamps}"
                                      Margin="0,12,0,0"
                                      FontFamily="Segoe UI Variable Text"
                                      FontSize="13"
                                      Foreground="{StaticResource PrimaryTextBrush}" />

                            <Separator Margin="0,16,0,8" />

                            <TextBlock Text="OpenAI Settings"
                                       FontFamily="Bahnschrift"
                                       FontSize="18"
                                       Foreground="{StaticResource PrimaryTextBrush}" />
                            <TextBlock Text="API Key" Style="{StaticResource CaptionTextStyle}" />
                            <TextBox Text="{Binding OpenAiApiKey, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     Padding="10"
                                     BorderBrush="#FF9DB6C0"
                                     BorderThickness="1"
                                     Background="#FFFDFEFF" />
                            <TextBlock Text="Model" Style="{StaticResource CaptionTextStyle}" />
                            <TextBox Text="{Binding OpenAiModel, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     Padding="10"
                                     BorderBrush="#FF9DB6C0"
                                     BorderThickness="1"
                                     Background="#FFFDFEFF" />

                            <UniformGrid Columns="2" Margin="0,20,0,0">
                                <Button Content="Transcribe File"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding TranscribeFileCommand}" />
                                <Button Content="Start Live"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding StartLiveCommand}" />
                                <Button Content="Stop Live"
                                        Style="{StaticResource DangerButtonStyle}"
                                        Command="{Binding StopLiveCommand}" />
                                <Button Content="Clear Output"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding ClearCommand}" />
                            </UniformGrid>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Interim Output"
                                       FontFamily="Bahnschrift"
                                       FontSize="21"
                                       Foreground="{StaticResource PrimaryTextBrush}" />
                            <TextBlock Text="Live hypothesis. This line updates as the engine revises recognition."
                                       Margin="0,2,0,10"
                                       FontFamily="Segoe UI Variable Text"
                                       FontSize="13"
                                       Foreground="{StaticResource SecondaryTextBrush}" />
                            <Border Background="#FFFFFAEC"
                                    BorderBrush="#FFF2D89F"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="14">
                                <TextBlock Text="{Binding InterimText}"
                                           FontFamily="Segoe UI Variable Text"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Foreground="#FF7A5200"
                                           MinHeight="60" />
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="2">
                            <TextBlock Text="Finalized Transcript"
                                       FontFamily="Bahnschrift"
                                       FontSize="21"
                                       Foreground="{StaticResource PrimaryTextBrush}" />
                            <TextBlock Text="Committed lines once text becomes stable."
                                       Margin="0,2,0,10"
                                       FontFamily="Segoe UI Variable Text"
                                       FontSize="13"
                                       Foreground="{StaticResource SecondaryTextBrush}" />
                            <Border Background="#FFFDFEFF"
                                    BorderBrush="#FFD2E2E7"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <TextBox Text="{Binding FinalizedText}"
                                         IsReadOnly="True"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Padding="14"
                                         FontFamily="Consolas"
                                         FontSize="15"
                                         Foreground="{StaticResource PrimaryTextBrush}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="14" Margin="0,18,0,0">
                <DockPanel LastChildFill="True">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <Ellipse Width="10" Height="10" Margin="0,0,8,0" Style="{StaticResource LiveDotStyle}" />
                        <TextBlock Text="{Binding SelectedEngine.DisplayName, TargetNullValue=No engine selected}"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                    </StackPanel>

                    <TextBlock Text="{Binding StatusMessage}"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="13"
                               Foreground="{StaticResource PrimaryTextBrush}" />
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
