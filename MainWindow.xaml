<Window x:Class="AudioTranscript.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Audio Transcription"
        Height="820"
        Width="1280"
        MinHeight="720"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#FFF4F7F8">
    <Window.Resources>
        <SolidColorBrush x:Key="SurfaceBrush"
                Color="#CCFFFFFF"/>
        <SolidColorBrush x:Key="SurfaceBorderBrush"
                Color="#55B7CAD2"/>
        <SolidColorBrush x:Key="PrimaryTextBrush"
                Color="#FF15232D"/>
        <SolidColorBrush x:Key="SecondaryTextBrush"
                Color="#FF49616F"/>
        <SolidColorBrush x:Key="PlaybackSyncTextBrush"
                Color="#FF4682B4"/>
        <SolidColorBrush x:Key="AccentBrush"
                Color="#FF1B86AA"/>
        <SolidColorBrush x:Key="AccentSurfaceBrush"
                Color="#FFE7F4F9"/>
        <SolidColorBrush x:Key="AccentBorderBrush"
                Color="#FFC6DDE7"/>

        <Style x:Key="CardStyle"
                TargetType="Border">
            <Setter Property="Background"
                    Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush"
                    Value="{StaticResource SurfaceBorderBrush}"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="CornerRadius"
                    Value="10"/>
            <Setter Property="SnapsToDevicePixels"
                    Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="22"
                            ShadowDepth="0"
                            Opacity="0.18"
                            Color="#FF7F97A6"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- DataGrid style with rounded corners to match parent card -->
        <Style x:Key="RoundedDataGridStyle" TargetType="DataGrid">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGrid">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="DG_ScrollViewer"
                                          Focusable="false"
                                          Padding="{TemplateBinding Padding}">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- ListView style with rounded corners for process logs panel -->
        <Style x:Key="RoundedListViewStyle" TargetType="ListView">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListView">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="LV_ScrollViewer"
                                          Focusable="false"
                                          Padding="{TemplateBinding Padding}">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CaptionTextStyle"
                TargetType="TextBlock">
            <Setter Property="FontFamily"
                    Value="Segoe UI Variable Text"/>
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
            <Setter Property="Foreground"
                    Value="{StaticResource SecondaryTextBrush}"/>
            <Setter Property="Margin"
                    Value="0,12,0,6"/>
            <Setter Property="FontSize"
                    Value="11"/>
        </Style>

        <Style x:Key="FooterProgressBarStyle"
               TargetType="ProgressBar">
            <Setter Property="Width"
                    Value="160"/>
            <Setter Property="Height"
                    Value="10"/>
            <Setter Property="Margin"
                    Value="0,0,10,0"/>
            <Setter Property="Minimum"
                    Value="0"/>
            <Setter Property="Maximum"
                    Value="100"/>
            <Setter Property="IsIndeterminate"
                    Value="True"/>
            <Setter Property="Background"
                    Value="#FFD9E8EE"/>
            <Setter Property="Foreground"
                    Value="#FF1B86AA"/>
            <Setter Property="BorderBrush"
                    Value="#FFBBD1DB"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="Visibility"
                    Value="Collapsed"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid ClipToBounds="True">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5"/>
                            <Border x:Name="Indicator"
                                    Width="52"
                                    HorizontalAlignment="Left"
                                    CornerRadius="5"
                                    Background="{TemplateBinding Foreground}"
                                    Margin="0,1"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <TranslateTransform X="-60"/>
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsIndeterminate"
                                     Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="Indicator"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             From="-60"
                                                             To="220"
                                                             Duration="0:0:1.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFileTranscribing}"
                             Value="True">
                    <Setter Property="Visibility"
                            Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernComboBoxItemStyle"
               TargetType="ComboBoxItem">
            <Setter Property="Padding"
                    Value="10,7"/>
            <Setter Property="FontFamily"
                    Value="Segoe UI Variable Text"/>
            <Setter Property="FontSize"
                    Value="13"/>
            <Setter Property="Foreground"
                    Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted"
                                     Value="True">
                                <Setter TargetName="ItemBorder"
                                        Property="Background"
                                        Value="#FFEAF4F8"/>
                            </Trigger>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter TargetName="ItemBorder"
                                        Property="Background"
                                        Value="#FFDCEFF6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernComboBoxStyle"
               TargetType="ComboBox">
            <Setter Property="FontFamily"
                    Value="Segoe UI Variable Text"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="Foreground"
                    Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background"
                    Value="#FFFDFEFF"/>
            <Setter Property="BorderBrush"
                    Value="#FF9DB6C0"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="Padding"
                    Value="10,8"/>
            <Setter Property="MinHeight"
                    Value="40"/>
            <Setter Property="SnapsToDevicePixels"
                    Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="OuterBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"/>

                            <ToggleButton x:Name="DropDownToggle"
                                          Focusable="False"
                                          FocusVisualStyle="{x:Null}"
                                          OverridesDefaultStyle="True"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          HorizontalContentAlignment="Stretch"
                                          VerticalContentAlignment="Stretch">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"
                                                BorderThickness="0">
                                            <ContentPresenter HorizontalAlignment="Stretch"
                                                              VerticalAlignment="Stretch"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <Grid Margin="{TemplateBinding Padding}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter Grid.Column="0"
                                                      Margin="0,0,8,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"/>

                                    <Path x:Name="DropArrow"
                                          Grid.Column="1"
                                          Width="11"
                                          Height="7"
                                          Stretch="Fill"
                                          Stroke="#FF4B6775"
                                          StrokeThickness="1.8"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Data="M1,1 L5.5,6 L10,1"/>
                                </Grid>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Margin="0,4,0,0"
                                        Background="#FFFDFEFF"
                                        BorderBrush="#FF9DB6C0"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="300"
                                                  VerticalScrollBarVisibility="Auto"
                                                  CanContentScroll="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="OuterBorder"
                                        Property="BorderBrush"
                                        Value="#FFA9C8D6"/>
                                <Setter TargetName="OuterBorder"
                                        Property="Background"
                                        Value="#FFDFF1F8"/>
                                <Setter Property="Foreground"
                                        Value="#FF153949"/>
                                <Setter TargetName="DropArrow"
                                        Property="Stroke"
                                        Value="#FF153949"/>
                                <Setter Property="Cursor"
                                        Value="Hand"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin"
                                     Value="True">
                                <Setter TargetName="OuterBorder"
                                        Property="BorderBrush"
                                        Value="#FF1B86AA"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter TargetName="OuterBorder"
                                        Property="Background"
                                        Value="#FFF1F6F8"/>
                                <Setter TargetName="OuterBorder"
                                        Property="BorderBrush"
                                        Value="#FFD9E3E8"/>
                                <Setter Property="Foreground"
                                        Value="#FFA0B0B9"/>
                                <Setter TargetName="DropArrow"
                                        Property="Stroke"
                                        Value="#FFA0B0B9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Width"
                    Value="42"/>
            <Setter Property="MinWidth"
                    Value="42"/>
            <Setter Property="MinHeight"
                    Value="38"/>
            <Setter Property="Padding"
                    Value="0"/>
            <Setter Property="Margin"
                    Value="8,0,4,0"/>
        </Style>

        <Style x:Key="PlaybackActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Height"
                    Value="29"/>
            <Setter Property="MinHeight"
                    Value="29"/>
            <Setter Property="Padding"
                    Value="12,4"/>
        </Style>

        <Style x:Key="PlaybackSecondaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height"
                    Value="29"/>
            <Setter Property="MinHeight"
                    Value="29"/>
            <Setter Property="Padding"
                    Value="12,4"/>
        </Style>

        <Style x:Key="PlaybackIconButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource IconActionButtonStyle}">
            <Setter Property="Height"
                    Value="29"/>
            <Setter Property="MinHeight"
                    Value="29"/>
        </Style>

        <Style x:Key="ToolbarCheckBoxStyle"
               TargetType="CheckBox">
            <Setter Property="FontFamily"
                    Value="Segoe UI Variable Text"/>
            <Setter Property="FontSize"
                    Value="13"/>
            <Setter Property="Foreground"
                    Value="{StaticResource SecondaryTextBrush}"/>
            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>
            <Setter Property="VerticalAlignment"
                    Value="Center"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Margin"
                    Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="BulletBorder"
                                    Grid.Column="0"
                                    Width="16"
                                    Height="16"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    CornerRadius="4"
                                    Background="#FFFDFEFF"
                                    BorderBrush="#FF9DB6C0"
                                    BorderThickness="1">
                                <Path x:Name="CheckMark"
                                      Data="M3.2,8.2 L6.4,11.3 L12.6,4.4"
                                      Stroke="{StaticResource AccentBrush}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Grid.Column="1"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="BulletBorder"
                                        Property="BorderBrush"
                                        Value="#FFA9C8D6"/>
                                <Setter Property="Foreground"
                                        Value="{StaticResource PrimaryTextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter TargetName="BulletBorder"
                                        Property="BorderBrush"
                                        Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="BulletBorder"
                                        Property="Background"
                                        Value="{StaticResource AccentSurfaceBrush}"/>
                                <Setter TargetName="CheckMark"
                                        Property="Visibility"
                                        Value="Visible"/>
                                <Setter Property="Foreground"
                                        Value="{StaticResource PrimaryTextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter TargetName="BulletBorder"
                                        Property="Background"
                                        Value="#FFF1F6F8"/>
                                <Setter TargetName="BulletBorder"
                                        Property="BorderBrush"
                                        Value="#FFD9E3E8"/>
                                <Setter Property="Foreground"
                                        Value="#FFA0B0B9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TranscriptOverlayActionButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource ButtonChromeStyle}">
            <Setter Property="Width"
                    Value="16"/>
            <Setter Property="Height"
                    Value="16"/>
            <Setter Property="MinWidth"
                    Value="16"/>
            <Setter Property="MinHeight"
                    Value="16"/>
            <Setter Property="Padding"
                    Value="0"/>
            <Setter Property="Margin"
                    Value="0"/>
            <Setter Property="Focusable"
                    Value="False"/>
            <Setter Property="IsTabStop"
                    Value="False"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="BorderBrush"
                    Value="Transparent"/>
            <Setter Property="Foreground"
                    Value="#FF234F61"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ActionBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="ActionBorder"
                                        Property="Background"
                                        Value="{StaticResource AccentSurfaceBrush}"/>
                                <Setter TargetName="ActionBorder"
                                        Property="BorderBrush"
                                        Value="{StaticResource AccentBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="ActionBorder"
                                        Property="Background"
                                        Value="#FFDCEFF6"/>
                                <Setter TargetName="ActionBorder"
                                        Property="BorderBrush"
                                        Value="#FFB7D4E1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainRootGrid"
          Background="#FFF4F7F8">
        <DockPanel LastChildFill="True">
            <StatusBar DockPanel.Dock="Bottom"
                       Margin="0"
                       MinHeight="32"
                       Padding="10,2"
                       Background="#FFEFF3F6"
                       BorderBrush="#FFC8D6DD"
                       BorderThickness="1,1,1,0">
                <StatusBarItem DockPanel.Dock="Right"
                               Padding="0"
                               BorderThickness="0">
                    <StackPanel Orientation="Horizontal">
                        <ProgressBar Style="{StaticResource FooterProgressBarStyle}"/>
                        <TextBlock Text="{Binding SelectedEngine.DisplayName, TargetNullValue=No engine selected}"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>
                </StatusBarItem>

                <StatusBarItem DockPanel.Dock="Left"
                               Padding="0"
                               BorderThickness="0">
                    <TextBlock Text="© 2026 Justin Tagarda · justintagarda@gmail.com"
                               Margin="0,0,14,0"
                               FontFamily="Bahnschrift"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                </StatusBarItem>
            </StatusBar>

            <Grid Margin="14,3.5,14,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="400"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource CardStyle}"
                        Padding="11">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Settings"
                                       FontFamily="Bahnschrift"
                                       FontSize="20"
                                       Foreground="{StaticResource PrimaryTextBrush}"/>

                            <TextBlock Text="Transcription Engine"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,14,0,8"/>
                            <ComboBox ItemsSource="{Binding Engines}"
                                      SelectedItem="{Binding SelectedEngine}"
                                      SelectionChanged="EngineComboBox_SelectionChanged"
                                      DisplayMemberPath="DisplayName"
                                      IsEnabled="{Binding IsEngineSelectionEnabled}"
                                      Style="{StaticResource ModernComboBoxStyle}"
                                      ItemContainerStyle="{StaticResource ModernComboBoxItemStyle}"/>

                            <TextBlock Text="Sessions"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,14,0,6"/>
                            <Border Background="#FFFDFEFF"
                                    BorderBrush="#FFD2E2E7"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="10">
                                <StackPanel>
                                    <ListBox ItemsSource="{Binding RecentSessions}"
                                             SelectedItem="{Binding SelectedRecentSession}"
                                             Height="128"
                                             HorizontalContentAlignment="Stretch"
                                             Grid.IsSharedSizeScope="True"
                                             MouseDoubleClick="RecentSessionsList_MouseDoubleClick"
                                             BorderThickness="1"
                                             BorderBrush="#FFD2E2E7"
                                             Background="#FFF8FBFC"
                                             FontFamily="Segoe UI Variable Text"
                                             Foreground="{StaticResource PrimaryTextBrush}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="4,3"
                                                      ToolTip="{Binding DisplayName}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"
                                                                          SharedSizeGroup="SessionFileColumn"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding OriginalFileName}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding UpdatedUtc, StringFormat=Updated {0:MMM dd, yyyy HH:mm}}"
                                                               Margin="14,0,0,0"
                                                               FontSize="11"
                                                               Foreground="{StaticResource SecondaryTextBrush}"
                                                               TextAlignment="Right"
                                                               HorizontalAlignment="Stretch"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                Margin="0,6,0,0">
                                        <Button Content="Open"
                                                Style="{StaticResource PlaybackSecondaryButtonStyle}"
                                                MinWidth="0"
                                                Width="80"
                                                Margin="0,0,6,0"
                                                Command="{Binding OpenSelectedSessionCommand}"/>
                                        <Button Content="Delete"
                                                Style="{StaticResource DangerButtonStyle}"
                                                MinWidth="0"
                                                Width="80"
                                                Height="32"
                                                Command="{Binding DeleteSelectedSessionCommand}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Transcription"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,14,0,6"/>
                            <Border Background="#FFFDFEFF"
                                    BorderBrush="#FFD2E2E7"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="10">
                                <UniformGrid Columns="3"
                                             Rows="2">
                                    <Button Content="Open File..."
                                            Style="{StaticResource PlaybackSecondaryButtonStyle}"
                                            Command="{Binding OpenAudioFileCommand}"/>
                                    <Button Content="Transcribe"
                                            Style="{StaticResource PlaybackActionButtonStyle}"
                                            Command="{Binding TranscribeFileCommand}"/>
                                    <Button Content="Clear"
                                            Style="{StaticResource PlaybackActionButtonStyle}"
                                            Command="{Binding ClearCommand}"/>
                                    <Button Content="Cancel"
                                            Style="{StaticResource PlaybackActionButtonStyle}"
                                            Command="{Binding CancelCommand}"/>
                                    <Button Content="API Key"
                                            Style="{StaticResource PlaybackActionButtonStyle}"
                                            IsEnabled="{Binding IsOpenAiSettingsEnabled}"
                                            Click="OpenOpenAiSettings_Click"/>
                                    <Button Content="Restore Audio"
                                            Style="{StaticResource PlaybackSecondaryButtonStyle}"
                                            Command="{Binding RestoreSessionAudioCommand}"/>
                                </UniformGrid>
                            </Border>

                            <TextBlock Text="Audio File"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,14,0,6"/>
                            <Border Background="#FFFDFEFF"
                                    BorderBrush="#FFD2E2E7"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="10">
                                <StackPanel>
                                    <TextBlock Text="{Binding LoadedAudioFileName}"
                                               FontFamily="Segoe UI Variable Text"
                                               FontSize="12"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding CurrentSessionAudioIssue}"
                                               Margin="0,6,0,0"
                                               FontFamily="Segoe UI Variable Text"
                                               FontSize="11"
                                               Foreground="#FF8A4B1D"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility"
                                                        Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentSessionAudioIssue}"
                                                                 Value="">
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Content="Play"
                                                Style="{StaticResource PlaybackActionButtonStyle}"
                                                Command="{Binding PlayAudioCommand}"/>
                                        <Button Grid.Column="1"
                                                Content="Pause"
                                                Style="{StaticResource PlaybackSecondaryButtonStyle}"
                                                Command="{Binding PauseAudioCommand}"/>
                                        <Button Grid.Column="2"
                                                Content="Stop"
                                                Style="{StaticResource PlaybackSecondaryButtonStyle}"
                                                Command="{Binding StopAudioCommand}"/>
                                        <Button Grid.Column="3"
                                                ToolTip="Rewind 5 seconds"
                                                AutomationProperties.Name="Rewind 5 seconds"
                                                Style="{StaticResource PlaybackIconButtonStyle}"
                                                Command="{Binding RewindAudioCommand}">
                                            <Viewbox Width="11.2"
                                                     Height="11.2"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center">
                                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                      Stretch="Uniform"
                                                      Data="M14,4 L8,10 L14,16 Z M8.5,4 L2.5,10 L8.5,16 Z"/>
                                            </Viewbox>
                                        </Button>
                                        <Button Grid.Column="4"
                                                ToolTip="Forward 5 seconds"
                                                AutomationProperties.Name="Forward 5 seconds"
                                                Style="{StaticResource PlaybackIconButtonStyle}"
                                                Command="{Binding ForwardAudioCommand}">
                                            <Viewbox Width="11.2"
                                                     Height="11.2"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center">
                                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                      Stretch="Uniform"
                                                      Data="M2,4 L8,10 L2,16 Z M7.5,4 L13.5,10 L7.5,16 Z"/>
                                            </Viewbox>
                                        </Button>
                                    </Grid>
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding AudioElapsedText}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"
                                                   FontFamily="Consolas"
                                                   FontSize="12"
                                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                                        <Slider Grid.Column="1"
                                                Minimum="0"
                                                Maximum="{Binding AudioSeekMaximumSeconds}"
                                                Value="{Binding AudioSeekPositionSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                VerticalAlignment="Center"
                                                IsEnabled="{Binding IsAudioFileLoaded}"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding AudioRemainingText}"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0"
                                                   FontFamily="Consolas"
                                                   FontSize="12"
                                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                        </StackPanel>

                        <TextBlock Grid.Row="1"
                                   Text="Process Logs"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,15,0,6"/>

                        <Border Grid.Row="2"
                                Background="#FFFDFEFF"
                                BorderBrush="#FFD2E2E7"
                                BorderThickness="1"
                                CornerRadius="10"
                                ClipToBounds="True">
                            <ListView x:Name="ProcessLogsListView"
                                      Style="{StaticResource RoundedListViewStyle}"
                                      ItemsSource="{Binding ProcessLogs}"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      FontFamily="Segoe UI Variable Text"
                                      FontSize="12"
                                      Foreground="{StaticResource PrimaryTextBrush}"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListView.Resources>
                                    <Style TargetType="{x:Type GridViewColumnHeader}">
                                        <Setter Property="FontFamily"
                                                Value="Segoe UI Variable Text"/>
                                        <Setter Property="FontSize"
                                                Value="12"/>
                                        <Setter Property="FontWeight"
                                                Value="SemiBold"/>
                                        <Setter Property="Foreground"
                                                Value="{StaticResource SecondaryTextBrush}"/>
                                        <Setter Property="Background"
                                                Value="#FFF6FAFC"/>
                                        <Setter Property="BorderBrush"
                                                Value="#FFD2E2E7"/>
                                        <Setter Property="BorderThickness"
                                                Value="0,0,0,1"/>
                                        <Setter Property="Padding"
                                                Value="6,5"/>
                                    </Style>
                                </ListView.Resources>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="{x:Type ListViewItem}">
                                        <Setter Property="Padding"
                                                Value="0"/>
                                        <Setter Property="Margin"
                                                Value="0"/>
                                        <Setter Property="HorizontalContentAlignment"
                                                Value="Stretch"/>
                                        <Setter Property="VerticalContentAlignment"
                                                Value="Top"/>
                                        <Setter Property="Background"
                                                Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected"
                                                     Value="True">
                                                <Setter Property="Background"
                                                        Value="#FFEAF4F8"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.View>
                                    <GridView AllowsColumnReorder="False">
                                        <GridViewColumn Header="Time"
                                                        Width="74"
                                                        DisplayMemberBinding="{Binding Time}"/>
                                        <GridViewColumn Header="Log"
                                                        Width="284">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Message}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,0,4,0"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Border>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1"
                              Width="6"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Stretch"
                              ResizeDirection="Columns"
                              ResizeBehavior="PreviousAndNext"
                              Background="Transparent"
                              ShowsPreview="True"/>

                <Border Grid.Column="2"
                        Style="{StaticResource CardStyle}"
                        Padding="12"
                        Margin="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0"
                                   LastChildFill="False">
                            <TextBlock Text="Finalized Transcript"
                                       DockPanel.Dock="Left"
                                       FontFamily="Bahnschrift"
                                       FontSize="20"
                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                            <Grid DockPanel.Dock="Right"
                                  VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Content="Copy with timeline"
                                          Grid.Column="0"
                                          Style="{StaticResource ToolbarCheckBoxStyle}"
                                          IsChecked="{Binding CopyFinalizedWithTimeline, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Style="{StaticResource IconActionButtonStyle}"
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        ToolTip="Copy to Clipboard"
                                        AutomationProperties.Name="Copy to Clipboard"
                                        IsEnabled="{Binding IsEngineSelectionEnabled}"
                                        Click="CopyFinalizedToClipboard_Click">
                                    <Viewbox Width="16"
                                             Height="16">
                                        <Path Fill="White"
                                              Data="M16,1H4A2,2 0 0,0 2,3V17H4V3H16M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5Z"/>
                                    </Viewbox>
                                </Button>
                            </Grid>
                        </DockPanel>

                        <Border Grid.Row="1"
                                Background="#FFFDFEFF"
                                BorderBrush="#FFD2E2E7"
                                BorderThickness="1"
                                CornerRadius="10"
                                Margin="0,10,0,0"
                                ClipToBounds="True">
                            <DataGrid x:Name="FinalizedTranscriptGrid"
                                      Style="{StaticResource RoundedDataGridStyle}"
                                      ItemsSource="{Binding FinalizedTranscriptLines}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserResizeRows="False"
                                      HeadersVisibility="Column"
                                      RowHeaderWidth="0"
                                      GridLinesVisibility="None"
                                      SelectionMode="Single"
                                      SelectionUnit="Cell"
                                      CurrentCellChanged="FinalizedTranscriptGrid_CurrentCellChanged"
                                      GotKeyboardFocus="FinalizedTranscriptGrid_GotKeyboardFocus"
                                      LostKeyboardFocus="FinalizedTranscriptGrid_LostKeyboardFocus"
                                      BeginningEdit="FinalizedTranscriptGrid_BeginningEdit"
                                      CellEditEnding="FinalizedTranscriptGrid_CellEditEnding"
                                      PreviewKeyDown="FinalizedTranscriptGrid_PreviewKeyDown"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      RowBackground="#00FFFFFF"
                                      AlternatingRowBackground="#05EAF4F8"
                                      FontFamily="Consolas"
                                      FontSize="15"
                                      Foreground="{StaticResource PrimaryTextBrush}"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                                <DataGrid.Resources>
                                    <Style TargetType="{x:Type DataGridColumnHeader}">
                                        <Setter Property="FontFamily"
                                                Value="Segoe UI Variable Text"/>
                                        <Setter Property="FontSize"
                                                Value="12"/>
                                        <Setter Property="FontWeight"
                                                Value="SemiBold"/>
                                        <Setter Property="Foreground"
                                                Value="{StaticResource SecondaryTextBrush}"/>
                                        <Setter Property="Background"
                                                Value="#FFF6FAFC"/>
                                        <Setter Property="BorderBrush"
                                                Value="#FFD2E2E7"/>
                                        <Setter Property="BorderThickness"
                                                Value="0,0,0,1"/>
                                        <Setter Property="Padding"
                                                Value="6,5"/>
                                    </Style>
                                    <Style TargetType="{x:Type DataGridCell}">
                                        <Setter Property="Padding"
                                                Value="6,3"/>
                                        <Setter Property="VerticalContentAlignment"
                                                Value="Top"/>
                                        <Setter Property="BorderThickness"
                                                Value="1"/>
                                        <Setter Property="BorderBrush"
                                                Value="Transparent"/>
                                        <Setter Property="Background"
                                                Value="Transparent"/>
                                        <Setter Property="Foreground"
                                                Value="{StaticResource PrimaryTextBrush}"/>
                                        <Setter Property="FocusVisualStyle"
                                                Value="{x:Null}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected"
                                                     Value="True">
                                                <Setter Property="Background"
                                                        Value="#14D7E7EF"/>
                                                <Setter Property="Foreground"
                                                        Value="{StaticResource PrimaryTextBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsEditing"
                                                     Value="True">
                                                <Setter Property="BorderBrush"
                                                        Value="#6495ED"/>
                                                <Setter Property="BorderThickness"
                                                        Value="1"/>
                                            </Trigger>
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsKeyboardFocusWithin"
                                                               Value="True"/>
                                                    <Condition Property="IsEditing"
                                                               Value="False"/>
                                                </MultiTrigger.Conditions>
                                                <Setter Property="BorderBrush"
                                                        Value="#C0C0C0"/>
                                                <Setter Property="BorderThickness"
                                                        Value="1"/>
                                            </MultiTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsPlaybackTimelineMatch}"
                                                               Value="True"/>
                                                    <Condition Binding="{Binding Column.DisplayIndex, RelativeSource={RelativeSource Self}}"
                                                               Value="0"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="FontWeight"
                                                        Value="Bold"/>
                                                <Setter Property="Foreground"
                                                        Value="{StaticResource PlaybackSyncTextBrush}"/>
                                            </MultiDataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Column.DisplayIndex, RelativeSource={RelativeSource Self}}"
                                                               Value="0"/>
                                                    <Condition Binding="{Binding IsEditing, RelativeSource={RelativeSource Self}}"
                                                               Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="FontWeight"
                                                        Value="Normal"/>
                                                <Setter Property="Foreground"
                                                        Value="{StaticResource PrimaryTextBrush}"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style TargetType="{x:Type DataGridRow}">
                                        <Setter Property="Foreground"
                                                Value="{StaticResource PrimaryTextBrush}"/>
                                        <Setter Property="VerticalAlignment"
                                                Value="Top"/>
                                        <Setter Property="VerticalContentAlignment"
                                                Value="Top"/>
                                        <Setter Property="BorderThickness"
                                                Value="0"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected"
                                                     Value="True">
                                                <Setter Property="Foreground"
                                                        Value="{StaticResource PrimaryTextBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style TargetType="{x:Type TextBox}">
                                        <Setter Property="Foreground"
                                                Value="{StaticResource PrimaryTextBrush}"/>
                                        <Setter Property="BorderThickness"
                                                Value="0"/>
                                        <Setter Property="Background"
                                                Value="Transparent"/>
                                        <Setter Property="FocusVisualStyle"
                                                Value="{x:Null}"/>
                                        <Setter Property="VerticalContentAlignment"
                                                Value="Top"/>
                                    </Style>
                                    <Style x:Key="TranscriptCellTextStyle"
                                           TargetType="{x:Type TextBlock}">
                                        <Setter Property="TextWrapping"
                                                Value="Wrap"/>
                                        <Setter Property="TextAlignment"
                                                Value="Left"/>
                                        <Setter Property="VerticalAlignment"
                                                Value="Top"/>
                                    </Style>
                                    <Style x:Key="TranscriptEditingTextStyle"
                                           TargetType="{x:Type TextBox}"
                                           BasedOn="{StaticResource {x:Type TextBox}}">
                                        <Setter Property="TextWrapping"
                                                Value="Wrap"/>
                                        <Setter Property="TextAlignment"
                                                Value="Left"/>
                                        <Setter Property="VerticalContentAlignment"
                                                Value="Top"/>
                                        <Setter Property="VerticalAlignment"
                                                Value="Top"/>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Timeline"
                                                            CanUserSort="False"
                                                            Width="69">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Timeline}"
                                                           TextAlignment="Left"
                                                           HorizontalAlignment="Left"
                                                           Margin="10,0,0,0"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Timeline, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                                         MaxLength="5"
                                                         TextAlignment="Left"
                                                         FontWeight="Normal"
                                                         Padding="10,0,0,0"
                                                         Loaded="TimelineEditingTextBox_Loaded"
                                                         GotKeyboardFocus="TimelineEditingTextBox_GotKeyboardFocus"
                                                         PreviewTextInput="TimelineEditingTextBox_PreviewTextInput"
                                                         PreviewKeyDown="TimelineEditingTextBox_PreviewKeyDown"
                                                         DataObject.Pasting="TimelineEditingTextBox_Pasting"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Transcription"
                                                            CanUserSort="False"
                                                            Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Text}"
                                                           Style="{StaticResource TranscriptCellTextStyle}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource TranscriptEditingTextStyle}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header=""
                                                            CanUserSort="False"
                                                            IsReadOnly="True"
                                                            Width="36">
                                        <DataGridTemplateColumn.CellStyle>
                                            <Style TargetType="{x:Type DataGridCell}"
                                                   BasedOn="{StaticResource {x:Type DataGridCell}}">
                                                <Setter Property="Padding"
                                                        Value="0"/>
                                            </Style>
                                        </DataGridTemplateColumn.CellStyle>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Top"
                                                            Margin="0">
                                                    <StackPanel.Style>
                                                        <Style TargetType="{x:Type StackPanel}">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding AreRowActionsVisible}"
                                                                             Value="True">
                                                                    <Setter Property="Visibility"
                                                                            Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <Button Style="{StaticResource TranscriptOverlayActionButtonStyle}"
                                                            Click="InsertTranscriptRowBelow_Click"
                                                            ToolTip="Insert new row below">
                                                        <Viewbox Width="14"
                                                                 Height="14">
                                                            <Grid Width="16"
                                                                  Height="16">
                                                                <Path Fill="#FF234F61"
                                                                      Data="M2,3 H14 V4.5 H2 Z M2,7 H14 V8.5 H2 Z M2,11 H9.5 V12.5 H2 Z"/>
                                                                <Path Fill="#FF234F61"
                                                                      Data="M11.2,9.2 H12.8 V11.2 H14.8 V12.8 H12.8 V14.8 H11.2 V12.8 H9.2 V11.2 H11.2 Z"/>
                                                            </Grid>
                                                        </Viewbox>
                                                    </Button>
                                                    <Button Style="{StaticResource TranscriptOverlayActionButtonStyle}"
                                                            Click="DeleteTranscriptRow_Click"
                                                            Margin="0"
                                                            ToolTip="Delete this row">
                                                        <Viewbox Width="14"
                                                                 Height="14">
                                                            <Path Fill="#FF234F61"
                                                                  Data="M6,1.8 H10 L10.7,2.9 H14 V4.4 H2 V2.9 H5.3 Z M4.1,5.1 H11.9 L11.2,14.2 H4.8 Z M6,6.6 V12.4 H7.4 V6.6 Z M8.6,6.6 V12.4 H10 V6.6 Z"/>
                                                        </Viewbox>
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </DockPanel>

        <Border x:Name="CopyToastHost"
                Panel.ZIndex="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,48"
                Opacity="0"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <Border.RenderTransform>
                <TranslateTransform x:Name="CopyToastTransform"
                                    Y="-14"/>
            </Border.RenderTransform>
            <Border Background="#FFFDFEFF"
                    BorderBrush="#FFD2E2E7"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14,12"
                    MaxWidth="320">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="26"
                                      ShadowDepth="0"
                                      Opacity="0.2"
                                      Color="#FF7F97A6"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="CopyToastIconHost"
                            Width="34"
                            Height="34"
                            CornerRadius="17"
                            Background="{StaticResource AccentSurfaceBrush}"
                            BorderBrush="{StaticResource AccentBorderBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Top">
                        <Viewbox Width="15"
                                 Height="15"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center">
                            <Path x:Name="CopyToastIconPath"
                                  Stroke="{StaticResource AccentBrush}"
                                  StrokeThickness="2.6"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Data="M2.5,8.5 L6.2,12.2 L13.5,4.5"/>
                        </Viewbox>
                    </Border>
                    <StackPanel Grid.Column="1"
                                Margin="12,0,0,0">
                        <TextBlock x:Name="CopyToastTitleText"
                                   Text="Copied to clipboard"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock x:Name="CopyToastMessageText"
                                   Text="Finalized transcript is ready to paste."
                                   Margin="0,3,0,0"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="11"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
