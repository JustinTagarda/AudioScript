                                                <DataTrigger Binding="{Binding IsTranscriptionInteractionLocked, RelativeSource={RelativeSource AncestorType=Window}}"
                                                             Value="True">
                                                    <Setter Property="IsEnabled"
                                                            Value="False"/>
                                                    <Setter Property="Opacity"
