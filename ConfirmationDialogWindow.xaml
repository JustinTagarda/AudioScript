<Window x:Class="VoxTranscribe.ConfirmationDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Confirm Action"
        Icon="pack://application:,,,/Assets/VoxTranscribe.ico"
        Width="420"
        MinWidth="360"
        MinHeight="170"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#FFD7A14B"
                        CornerRadius="3" />

                <Grid Grid.Column="1"
                      Margin="10,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="DialogTitleText"
                               Grid.Row="0"
                               FontFamily="Bahnschrift"
                               FontSize="18" />
                    <ScrollViewer Grid.Row="1"
                                  Margin="0,8,0,0"
                                  MaxHeight="180"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  CanContentScroll="False">
                        <TextBlock x:Name="DialogMessageText"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="11"
                                   TextWrapping="Wrap" />
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>

            <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button x:Name="CancelButton"
                    Width="88"
                    MinHeight="28"
                    FontSize="12"
                    Click="CancelButton_Click" />
            <Button x:Name="ProceedButton"
                    Width="88"
                    MinHeight="28"
                    FontSize="12"
                    Click="ProceedButton_Click" />
        </StackPanel>
    </Grid>
</Window>


